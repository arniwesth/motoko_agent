module sunholo/motoko_ext_scratchpad/types

export func tool_name() -> string = "scratchpad"

export func schema_json() -> string {
  "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"cells\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"language\": {\"type\": \"string\", \"enum\": [\"py\", \"js\", \"ail\", \"lean\"], \"description\": \"py/js are persistent mutable REPL kernels; ail is a persistent source-backed AILANG scratchpad gated by ailang check (+ optional Z3 verify); lean is a persistent Lean 4 proof scratchpad.\"},\n          \"code\": {\"type\": \"string\"},\n          \"title\": {\"type\": \"string\"},\n          \"timeout\": {\"type\": \"number\"},\n          \"reset\": {\"type\": \"boolean\"},\n          \"verify\": {\"type\": \"string\", \"enum\": [\"auto\", \"required\", \"off\"], \"description\": \"AILANG only. auto: verify when requires/ensures present, do not block on unproven; required: must prove every contract or the cell is rejected; off: type-check only.\"},\n          \"prove\": {\"type\": \"string\", \"enum\": [\"auto\", \"required\", \"off\"], \"description\": \"Lean only. auto: audit proofs but commit elaborated cells; required: every named theorem/lemma must be verified or the cell is rejected; off: elaborate only.\"},\n          \"mathlib\": {\"type\": \"boolean\", \"description\": \"Lean only. Use the prebuilt Mathlib-enabled Lean project; changing this resets the Lean session.\"},\n          \"run\": {\"type\": \"boolean\", \"description\": \"AILANG only. Execute the entrypoint after a successful check/verify.\"},\n          \"entry\": {\"type\": \"string\", \"description\": \"AILANG only. Entrypoint to run (default main). Entrypoints are ephemeral, never committed to the session.\"},\n          \"caps\": {\"type\": \"string\", \"description\": \"AILANG only. Comma-separated capabilities for run (e.g. IO,FS). Intersected with the host-allowed ceiling.\"}\n        },\n        \"required\": [\"language\", \"code\"]\n      }\n    }\n  },\n  \"required\": [\"cells\"]\n}"
}
