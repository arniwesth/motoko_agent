module sunholo/motoko_ext_eval/register

import std/env (getEnvOr)
import std/string (stringToInt)
import std/option (Some, None)
import pkg/sunholo/motoko_ext_abi/types (ExtensionHooks)
import pkg/sunholo/motoko_ext_eval/eval (make_hooks)

func parse_int_or(s: string, fallback: int) -> int {
  match stringToInt(s) {
    Some(n) => n,
    None    => fallback
  }
}

export func register_with_config(_cfg: a) -> ExtensionHooks ! {Env, Net} {
  let timeout_secs = parse_int_or(getEnvOr("MOTOKO_EVAL_TIMEOUT_SECS", "30"), 30);
  make_hooks(timeout_secs)
}
