module sunholo/motoko_ext_eval/types

export func tool_name() -> string = "eval"

export func schema_json() -> string {
  "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"cells\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"language\": {\"type\": \"string\", \"enum\": [\"py\", \"js\", \"ail\"], \"description\": \"py/js are persistent mutable REPL kernels; ail is a persistent source-backed AILANG scratchpad gated by ailang check (+ optional Z3 verify).\"},\n          \"code\": {\"type\": \"string\"},\n          \"title\": {\"type\": \"string\"},\n          \"timeout\": {\"type\": \"number\"},\n          \"reset\": {\"type\": \"boolean\"},\n          \"verify\": {\"type\": \"string\", \"enum\": [\"auto\", \"required\", \"off\"], \"description\": \"AILANG only. auto: verify when requires/ensures present, do not block on unproven; required: must prove every contract or the cell is rejected; off: type-check only.\"},\n          \"run\": {\"type\": \"boolean\", \"description\": \"AILANG only. Execute the entrypoint after a successful check/verify.\"},\n          \"entry\": {\"type\": \"string\", \"description\": \"AILANG only. Entrypoint to run (default main). Entrypoints are ephemeral, never committed to the session.\"},\n          \"caps\": {\"type\": \"string\", \"description\": \"AILANG only. Comma-separated capabilities for run (e.g. IO,FS). Intersected with the host-allowed ceiling.\"}\n        },\n        \"required\": [\"language\", \"code\"]\n      }\n    }\n  },\n  \"required\": [\"cells\"]\n}"
}
