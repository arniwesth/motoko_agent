module sunholo/motoko_ext_autoresearch/compaction

import std/string (contains)

import pkg/sunholo/motoko_ext_abi/types (Msg, PreStepDecision, PassThrough, Compacted)
import pkg/sunholo/motoko_ext_autoresearch/db as DB
import pkg/sunholo/motoko_ext_autoresearch/state (derive_state)
import pkg/sunholo/motoko_ext_autoresearch/prompts (build_state_summary)

func has_summary_msg(msgs: [Msg]) -> bool {
  match msgs {
    [] => false,
    m :: rest =>
      if contains(m.content, "autoresearch summary:") then true
      else has_summary_msg(rest)
  }
}

func summary_msg(content: string) -> Msg {
  {
    role: "user",
    content: content,
    tool_calls: [],
    tool_call_id: ""
  }
}

export func pre_step(session_dir: string, msgs: [Msg]) -> PreStepDecision ! {Process, FS} {
  if not DB.has_db(session_dir) then PassThrough
  else if has_summary_msg(msgs) then PassThrough
  else {
    let state = derive_state(session_dir);
    let summary = build_state_summary(session_dir, state);
    Compacted(msgs ++ [summary_msg(summary)], "autoresearch: session state reconstructed from DB")
  }
}
