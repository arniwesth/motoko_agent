module sunholo/motoko_ext_autoresearch/db

import std/bytes (toString)
import std/clock (now)
import std/fs (mkdirAll, fileExists)
import std/json (Json, decode, asArray, get, asString, asNumber, asBool)
import std/option (Option, Some, None)
import std/process (exec, ProcessError)
import std/result (Result, Ok, Err)
import std/string (trim, replace)

import pkg/sunholo/motoko_ext_autoresearch/types (PendingRun)

export type DB = { path: string }
export type Row = Json

export pure func db_path(session_dir: string) -> string =
  "${session_dir}/autoresearch.db"

export pure func open(session_dir: string) -> DB =
  { path: db_path(session_dir) }

export pure func sanitize_sql_string(s: string) -> string =
  replace(s, "'", "''")

func process_error_to_string(err: ProcessError) -> string {
  match err {
    NotAllowed(cmd) => "not allowed: ${cmd}",
    NotFound(cmd) => "not found: ${cmd}",
    PermissionDenied(cmd) => "permission denied: ${cmd}",
    Timeout(ms) => "timeout after ${show(ms)}ms",
    OutputLimitExceeded(n) => "output limit exceeded: ${show(n)} bytes",
    SpawnFailed(msg) => "spawn failed: ${msg}",
    AbnormalExit(sig, name) => "abnormal exit signal ${show(sig)} (${name})"
  }
}

func run_sql(db: DB, sql: string) -> Result[[Row], string] ! {Process} {
  match exec("duckdb", [db.path, "-json", "-c", sql]) {
    Err(e) => Err(process_error_to_string(e)),
    Ok(out) => {
      if out.exitCode != 0 then Err(trim(toString(out.stderr)))
      else {
        let raw = trim(toString(out.stdout));
        if raw == "" then Ok([])
        else match decode(raw) {
          Err(msg) => Err("decode failed: ${msg}"),
          Ok(j) => match asArray(j) {
            None => Ok([]),
            Some(rows) => Ok(rows)
          }
        }
      }
    }
  }
}

func run_exec(db: DB, sql: string) -> Result[(), string] ! {Process} {
  match run_sql(db, sql) {
    Err(e) => Err(e),
    Ok(_) => Ok(())
  }
}

func first_row(rows: [Row]) -> Option[Row] {
  match rows {
    [] => None,
    r :: _ => Some(r)
  }
}

func safe_i(v: Option[Json], fallback: int) -> int {
  match v {
    None => fallback,
    Some(j) => match asNumber(j) {
      Some(n) => _float_to_int(n),
      None => fallback
    }
  }
}

func safe_s(v: Option[Json], fallback: string) -> string {
  match v {
    None => fallback,
    Some(j) => match asString(j) {
      Some(s) => s,
      None => fallback
    }
  }
}

func safe_b(v: Option[Json], fallback: bool) -> bool {
  match v {
    None => fallback,
    Some(j) => match asBool(j) {
      Some(b) => b,
      None => fallback
    }
  }
}

func row_i(row: Row, key: string, fallback: int) -> int =
  safe_i(get(row, key), fallback)

func row_s(row: Row, key: string, fallback: string) -> string =
  safe_s(get(row, key), fallback)

func row_b(row: Row, key: string, fallback: bool) -> bool =
  safe_b(get(row, key), fallback)

export func ensure_schema(session_dir: string) -> Result[(), string] ! {FS, Process} {
  let _ = mkdirAll(session_dir);
  let db = open(session_dir);
  let schema = "
CREATE SEQUENCE IF NOT EXISTS seq_sessions START 1;
CREATE SEQUENCE IF NOT EXISTS seq_runs START 1;
CREATE TABLE IF NOT EXISTS sessions (
  id INTEGER DEFAULT nextval('seq_sessions') PRIMARY KEY,
  segment INTEGER,
  objective TEXT,
  metrics_json TEXT,
  scope_paths_json TEXT,
  off_limits_json TEXT,
  constraints_json TEXT,
  max_iterations INTEGER,
  patience INTEGER DEFAULT 3,
  init_dirty_json TEXT,
  status TEXT DEFAULT 'active',
  done_reason TEXT,
  baseline_commit TEXT,
  branch TEXT,
  ts BIGINT
);
CREATE TABLE IF NOT EXISTS runs (
  id INTEGER DEFAULT nextval('seq_runs') PRIMARY KEY,
  session_id INTEGER,
  segment INTEGER,
  run_number INTEGER,
  decision TEXT,
  metrics_json TEXT,
  samples_json TEXT,
  asi_json TEXT,
  changes_summary TEXT,
  reasoning TEXT,
  learnings TEXT,
  scope_deviations_json TEXT,
  justification TEXT,
  flagged BOOLEAN DEFAULT FALSE,
  flagged_reason TEXT,
  confidence_json TEXT,
  git_sha TEXT,
  checks_passed BOOLEAN,
  improved BOOLEAN,
  duration_ms INTEGER,
  iteration_changes_json TEXT,
  ts BIGINT
);
CREATE TABLE IF NOT EXISTS pending_runs (
  session_id INTEGER,
  segment INTEGER,
  run_number INTEGER,
  metrics_json TEXT,
  samples_json TEXT,
  asi_json TEXT,
  checks_passed BOOLEAN,
  exit_code INTEGER,
  duration_ms INTEGER,
  ts BIGINT
);";
  run_exec(db, schema)
}

export func has_db(session_dir: string) -> bool =
  fileExists(db_path(session_dir))

export func current_session_row(session_dir: string) -> Result[Option[Row], string] ! {Process} {
  let db = open(session_dir);
  match run_sql(db, "SELECT * FROM sessions ORDER BY id DESC LIMIT 1") {
    Err(e) => Err(e),
    Ok(rows) => Ok(first_row(rows))
  }
}

export func current_segment(session_dir: string) -> Result[int, string] ! {Process} {
  match current_session_row(session_dir) {
    Err(e) => Err(e),
    Ok(None) => Ok(0),
    Ok(Some(row)) => Ok(row_i(row, "segment", 0))
  }
}

export func current_status(session_dir: string) -> Result[string, string] ! {Process} {
  match current_session_row(session_dir) {
    Err(e) => Err(e),
    Ok(None) => Ok(""),
    Ok(Some(row)) => Ok(row_s(row, "status", ""))
  }
}

export func current_max_iterations(session_dir: string) -> Result[int, string] ! {Process} {
  match current_session_row(session_dir) {
    Err(e) => Err(e),
    Ok(None) => Ok(20),
    Ok(Some(row)) => Ok(row_i(row, "max_iterations", 20))
  }
}

export func current_patience(session_dir: string) -> Result[int, string] ! {Process} {
  match current_session_row(session_dir) {
    Err(e) => Err(e),
    Ok(None) => Ok(3),
    Ok(Some(row)) => Ok(row_i(row, "patience", 3))
  }
}

