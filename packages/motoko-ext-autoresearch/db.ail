export func insert_session(
  session_dir: string,
  segment: int,
  objective: string,
  metrics_json: string,
  scope_paths_json: string,
  off_limits_json: string,
  constraints_json: string,
  max_iterations: int,
  patience: int,
  init_dirty_json: string,
  baseline_commit: string,
  branch: string
) -> Result[(), string] ! {Process} {
  let db = open(session_dir);
  let sql = "INSERT INTO sessions (segment, objective, metrics_json, scope_paths_json, off_limits_json, constraints_json, max_iterations, patience, init_dirty_json, status, baseline_commit, branch, ts)
VALUES (
${show(segment)},
'${sanitize_sql_string(objective)}',
'${sanitize_sql_string(metrics_json)}',
'${sanitize_sql_string(scope_paths_json)}',
'${sanitize_sql_string(off_limits_json)}',
'${sanitize_sql_string(constraints_json)}',
${show(max_iterations)},
${show(patience)},
'${sanitize_sql_string(init_dirty_json)}',
'active',
'${sanitize_sql_string(baseline_commit)}',
'${sanitize_sql_string(branch)}',
${show(now())}
)";
  run_exec(db, sql)
}

export func mark_current_session(session_dir: string, status: string, done_reason: string) -> Result[(), string] ! {Process} {
  let db = open(session_dir);
  run_exec(db, "UPDATE sessions SET status='${sanitize_sql_string(status)}', done_reason='${sanitize_sql_string(done_reason)}' WHERE id = (SELECT id FROM sessions ORDER BY id DESC LIMIT 1)")
}

export func current_run_number(session_dir: string, segment: int) -> Result[int, string] ! {Process} {
  let db = open(session_dir);
  match run_sql(db, "SELECT COALESCE(MAX(run_number), 0) AS n FROM runs WHERE segment = ${show(segment)}") {
    Err(e) => Err(e),
    Ok(rows) => match first_row(rows) {
      None => Ok(0),
      Some(r) => Ok(row_i(r, "n", 0))
    }
  }
}

export func insert_pending_run(
  session_dir: string,
  session_id: int,
  segment: int,
  run_number: int,
  metrics_json: string,
  samples_json: string,
  asi_json: string,
  checks_passed: bool,
  exit_code: int,
  duration_ms: int
) -> Result[(), string] ! {Process} {
  let db = open(session_dir);
  let _ = run_exec(db, "DELETE FROM pending_runs WHERE segment = ${show(segment)}");
  run_exec(
    db,
    "INSERT INTO pending_runs (session_id, segment, run_number, metrics_json, samples_json, asi_json, checks_passed, exit_code, duration_ms, ts)
VALUES (${show(session_id)}, ${show(segment)}, ${show(run_number)}, '${sanitize_sql_string(metrics_json)}', '${sanitize_sql_string(samples_json)}', '${sanitize_sql_string(asi_json)}', ${if checks_passed then "TRUE" else "FALSE"}, ${show(exit_code)}, ${show(duration_ms)}, ${show(now())})"
  )
}

export func read_pending_run(session_dir: string, segment: int) -> Result[Option[PendingRun], string] ! {Process} {
  let db = open(session_dir);
  match run_sql(db, "SELECT * FROM pending_runs WHERE segment = ${show(segment)} ORDER BY ts DESC LIMIT 1") {
    Err(e) => Err(e),
    Ok(rows) => match first_row(rows) {
      None => Ok(None),
      Some(row) =>
        Ok(Some({
          run_number: row_i(row, "run_number", 0),
          metrics_json: row_s(row, "metrics_json", "{}"),
          samples_json: row_s(row, "samples_json", "{}"),
          asi_json: row_s(row, "asi_json", "{}"),
          checks_passed: row_b(row, "checks_passed", false),
          exit_code: row_i(row, "exit_code", 1),
          duration_ms: row_i(row, "duration_ms", 0)
        }))
    }
  }
}

export func clear_pending_run(session_dir: string, segment: int) -> Result[(), string] ! {Process} {
  run_exec(open(session_dir), "DELETE FROM pending_runs WHERE segment = ${show(segment)}")
}

export func has_pending_run(session_dir: string, segment: int) -> Result[bool, string] ! {Process} {
  match run_sql(open(session_dir), "SELECT COUNT(*) AS n FROM pending_runs WHERE segment = ${show(segment)}") {
    Err(e) => Err(e),
    Ok(rows) => match first_row(rows) {
      None => Ok(false),
      Some(row) => Ok(row_i(row, "n", 0) > 0)
    }
  }
}

export func insert_run(
  session_dir: string,
  session_id: int,
  segment: int,
  run_number: int,
  decision: string,
  metrics_json: string,
  samples_json: string,
  asi_json: string,
  changes_summary: string,
  reasoning: string,
  learnings: string,
  scope_deviations_json: string,
  justification: string,
  confidence_json: string,
  git_sha: string,
  checks_passed: bool,
  improved: bool,
  duration_ms: int,
  iteration_changes_json: string
) -> Result[(), string] ! {Process} {
  run_exec(
    open(session_dir),
    "INSERT INTO runs (session_id, segment, run_number, decision, metrics_json, samples_json, asi_json, changes_summary, reasoning, learnings, scope_deviations_json, justification, confidence_json, git_sha, checks_passed, improved, duration_ms, iteration_changes_json, ts)
VALUES (
${show(session_id)},
${show(segment)},
${show(run_number)},
'${sanitize_sql_string(decision)}',
'${sanitize_sql_string(metrics_json)}',
'${sanitize_sql_string(samples_json)}',
'${sanitize_sql_string(asi_json)}',
'${sanitize_sql_string(changes_summary)}',
'${sanitize_sql_string(reasoning)}',
'${sanitize_sql_string(learnings)}',
'${sanitize_sql_string(scope_deviations_json)}',
'${sanitize_sql_string(justification)}',
'${sanitize_sql_string(confidence_json)}',
'${sanitize_sql_string(git_sha)}',
${if checks_passed then "TRUE" else "FALSE"},
${if improved then "TRUE" else "FALSE"},
${show(duration_ms)},
'${sanitize_sql_string(iteration_changes_json)}',
${show(now())}
)"
  )
}

export func run_count(session_dir: string, segment: int) -> Result[int, string] ! {Process} {
  match run_sql(open(session_dir), "SELECT COUNT(*) AS n FROM runs WHERE segment = ${show(segment)}") {
    Err(e) => Err(e),
    Ok(rows) => match first_row(rows) {
      None => Ok(0),
      Some(row) => Ok(row_i(row, "n", 0))
    }
  }
}

export func recent_improved_flags(session_dir: string, segment: int) -> Result[[bool], string] ! {Process} {
  match run_sql(open(session_dir), "SELECT improved FROM runs WHERE segment = ${show(segment)} ORDER BY run_number DESC") {
    Err(e) => Err(e),
    Ok(rows) => Ok(improved_flags_rec(rows))
  }
}

func improved_flags_rec(rows: [Row]) -> [bool] {
  match rows {
    [] => [],
    r :: rest =>
      row_b(r, "improved", false) :: improved_flags_rec(rest)
  }
}

export func best_metric_value(session_dir: string, segment: int, metric_name: string, direction: string) -> Result[Option[float], string] ! {Process} {
  let agg = if direction == "maximize" then "MAX" else "MIN";
  let key = sanitize_sql_string(metric_name);
  let sql = "SELECT ${agg}(CAST(json_extract(metrics_json, '$.${key}') AS DOUBLE)) AS v FROM runs WHERE segment = ${show(segment)} AND decision='keep'";
  match run_sql(open(session_dir), sql) {
    Err(e) => Err(e),
    Ok(rows) => match first_row(rows) {
      None => Ok(None),
      Some(row) => match get(row, "v") {
        None => Ok(None),
        Some(v) => match asNumber(v) {
          Some(n) => Ok(Some(n)),
          None => Ok(None)
        }
      }
    }
  }
}
