{
  "name": "Motoko Agent",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/motoko_agent",
  "runServices": ["app", "clickstack"],
  "remoteUser": "motoko",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8081": {
      "onAutoForward": "ignore"
    }
  },
  "postCreateCommand": "cd src/tui && bun install && bun run build && cd ../.. && echo 'Motoko ready. Run: make run'",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go"
      ],
      "settings": {
        "go.lintTool": "golangci-lint",
        "go.formatTool": "gofmt"
      }
    }
  }
}
