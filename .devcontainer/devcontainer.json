{
  "name": "Motoko Agent",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [8080],
  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "GOOGLE_API_KEY": "${localEnv:GOOGLE_API_KEY}"
  },
  "postCreateCommand": "cd src/tui && bun install && bun run build && cd ../.. && echo 'Motoko ready. Run: make run'",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go"
      ],
      "settings": {
        "go.lintTool": "golangci-lint",
        "go.formatTool": "gofmt"
      }
    }
  }
}
