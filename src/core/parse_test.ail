module src/core/parse_test

-- M-MOTOKO-RPC-LOOP-FULL-MIGRATION M10b cutover (2026-05-06):
-- Tests for parse_tool_calls, indicates_continuation_intent,
-- split_think_answer, assistant_history_content, assistant_visible_output,
-- and extract_ailang were removed alongside the deletion of those
-- functions. Only the survivors that hybrid mode still relies on are
-- exercised here: extract_bash, extract_fence, first_shell_line.

import src/core/parse (extract_bash, extract_fence, first_shell_line)
import std/option (Some, None)

func ef_some(text: string, fence: string) -> bool
  tests [
    (("```bash\necho hello\n```",    "```bash"), true),
    (("```python\nprint(1)\n```",    "```bash"), false),
    (("```bash\necho hello",         "```bash"), false),
    (("",                            "```bash"), false)
  ]
  { match extract_fence(text, fence) { Some(_) => true, None => false } }

func ef_value(text: string, fence: string) -> string
  tests [
    (("```bash\necho hello\n```",      "```bash"), "echo hello"),
    (("```bash\n  echo hello  \n```",  "```bash"), "echo hello"),
    (("```bash\n```",                  "```bash"), "")
  ]
  { match extract_fence(text, fence) { Some(v) => v, None => "__none__" } }

func fsl_some(lines: [string]) -> bool
  tests [
    (["echo hello"],                     true),
    (["  ls -la  "],                     true),
    (["The answer is 42", "git status"], true),
    ([],                                 false),
    (["This is prose", "So is this"],    false)
  ]
  { match first_shell_line(lines) { Some(_) => true, None => false } }

func eb_some(text: string) -> bool
  tests [
    ("Here is the fix:\n```bash\necho hello\n```\nDone.", true),
    ("```sh\ngit status\n```",                            true),
    ("```shell\nls -la\n```",                             true),
    ("```\ncd /tmp\n```",                                 true),
    ("Let me check:\ngit log --oneline",                  true),
    ("```\nThis is prose.\n```",                          false),
    ("The answer is 42.",                                  false)
  ]
  { match extract_bash(text) { Some(_) => true, None => false } }
