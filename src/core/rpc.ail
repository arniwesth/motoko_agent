module src/core/rpc

-- M-MOTOKO-RPC-LOOP-FULL-MIGRATION M10b cutover (2026-05-06):
-- The legacy text-based agent loop has been deleted. This module is now
-- a thin runtime entry point: load config, build the system prompt +
-- initial messages, compute the budget plan, then hand off to
-- src/core/agent_loop_v2's run_v2_with_conversation which drives the
-- typed std/ai.step() tool-use loop and the multi-turn conversation
-- driver.
--
-- For history of what was here before, see the M-MOTOKO-RPC-LOOP-FULL-
-- MIGRATION sprint plan + CHANGELOG.md and git log around 2026-05-06.

import src/core/agent_loop_v2 (run_v2_with_conversation)
import src/core/test/stub_step (LiveAI)
import std/io     (println, exit)
import std/json   (Json, encode, jo, ja, kv, js, jb, jnum)
import std/list   (foldl)
import std/string (length)
import std/fs     (readFile, fileExists)
import src/core/types  (Msg, version)
import src/core/prompts (with_cache_hint, with_agents_context)
import src/core/cache   (get_hint)
import src/core/config  (RuntimeConfig, InvocationConfig, load_runtime_config, load_invocation_config, CostRates)
import src/core/ext/types (BudgetPlan, ExtRuntime)
import src/core/ext/runtime (init_runtime_with_config, loaded_extension_names, dispatch_build_system_prompt, dispatch_budget_plan)

-- RunSettings carries the agent's runtime knobs from RuntimeConfig into
-- compute_budget_plan and the v2 entry point. Preserved post-M10 because
-- the existing config + delegation tunables are still relevant for
-- ohmy_pi-mode deployments and for the budget plan's max_steps clamping.
type RunSettings = {
  task: string,
  ailang_built: string,
  snippet_caps: string,
  workdir: string,
  ohmy_pi: bool,
  delegated_timeout_ms: int,
  delegated_poll_ms: int,
  delegated_timeout_slack_ms: int,
  max_retries: int,
  retry_base_ms: int,
  retry_cap_ms: int,
  max_steps: int,
  verifier_mode: bool,
  max_cost_millicents: int,
  cost_rates: CostRates
}

func emit(obj: string) -> () ! {IO} {
  println(obj)
}

func json_string_values(xs: [string]) -> [Json] {
  match xs {
    [] => [],
    x :: rest => js(x) :: json_string_values(rest)
  }
}

func clamp_positive(n: int, fallback: int) -> int {
  if n > 0 then n else fallback
}

func clamp_non_negative(n: int) -> int {
  if n < 0 then 0 else n
}

func clamp_range(n: int, lo: int, hi: int) -> int {
  if n < lo then lo else if n > hi then hi else n
}

func default_budget_plan(total: int, verifier_mode: bool) -> BudgetPlan {
  if verifier_mode then {
    let v0 = total / 4;
    let verifier = if v0 < 1 then 1 else v0;
    { total: total, solver: total - verifier, verifier: verifier }
  } else {
    { total: total, solver: total, verifier: 0 }
  }
}

func clamp_budget_plan(plan: BudgetPlan, max_total: int) -> BudgetPlan {
  let total = clamp_range(plan.total, 1, max_total);
  let solver0 = clamp_non_negative(plan.solver);
  let verifier0 = clamp_non_negative(plan.verifier);
  let solver = clamp_range(solver0, 0, total);
  let verifier = clamp_range(verifier0, 0, total - solver);
  { total: total, solver: solver, verifier: verifier }
}

func compute_budget_plan(
  ext_runtime: ExtRuntime,
  task: string,
  model: string,
  cwd: string,
  hybrid_enabled: bool,
  step: int,
  settings: RunSettings
) -> BudgetPlan ! {Env, IO, Clock} {
  let max_steps = clamp_positive(settings.max_steps, 50);
  let verifier_mode = settings.verifier_mode;
  let base = default_budget_plan(max_steps, verifier_mode);
  let remaining = if base.total - step < 0 then 0 else base.total - step;
  let ctx = {
    task: task,
    step: step,
    model: model,
    cwd: cwd,
    hybrid_tools: hybrid_enabled,
    budget: base,
    mode: if verifier_mode then "verifier" else "default",
    workdir: cwd,
    env_server_url: "",
    budget_remaining: remaining,
    history_slice: [],
    state_key: "core:ext:budget"
  };
  let patched = dispatch_budget_plan(ext_runtime, ctx, base);
  clamp_budget_plan(patched, max_steps)
}

func join_csv(xs: [string]) -> string {
  match xs {
    [] => "",
    x :: [] => x,
    x :: rest => "${x},${join_csv(rest)}"
  }
}

-- M-MOTOKO-OHMY-PI-DEFAULT-FLIP (2026-05-08): fail fast at startup if the
-- caller has set tools.ohmy_pi=true. The env-server inbox-based delegation
-- pipeline was deleted at M10b and the proper wire-up is tracked in
-- design_docs/planned/m-motoko-m65-ohmy-pi-delegation.md. Until that lands,
-- ohmy_pi=true causes every BashExec to return delegated_backend_not_wired
-- and the model thrashes 10-13 wasted steps per task. Emit a structured
-- error event and exit 2 — silent token waste is worse than a clear startup
-- error. When M6.5 lands, remove this guard.
func reject_if_ohmy_pi_unsupported(cfg: RuntimeConfig) -> () ! {IO} {
  if cfg.tools.ohmy_pi then {
    let _ = emit(encode(jo([
      kv("type", js("session_start_error")),
      kv("error_code", js("ohmy_pi_unsupported")),
      kv("config_profile", js(cfg.profile)),
      kv("config_dir", js(cfg.profile_dir)),
      kv("message", js("tools.ohmy_pi=true but the env-server inbox-based delegation pipeline is not yet wired in this build. Every BashExec would fail with delegated_backend_not_wired:true. Set tools.ohmy_pi=false in your profile (or unset OHMY_PI_TOOLS=1). See design_docs/planned/m-motoko-m65-ohmy-pi-delegation.md for the planned wire-up."))
    ])));
    exit(2)
  } else {
    ()
  }
}

export func run_with_config(cfg: RuntimeConfig, inv: InvocationConfig) -> () ! {Net, AI, SharedMem, IO, Env, FS, Clock, Process, Stream} {
  let _ = reject_if_ohmy_pi_unsupported(cfg);
  let env_url = cfg.backend.url;
  let task = inv.task;
  let model = if inv.model_override != "" then inv.model_override else cfg.agent.model;
  let hybrid_enabled = cfg.tools.hybrid;
  let ext_runtime = init_runtime_with_config(cfg);
  let ailang_built = inv.ailang_built;
  let cwd = if inv.workdir_override != "" then inv.workdir_override else cfg.agent.workdir;
  let settings = {
    task: task,
    ailang_built: ailang_built,
    snippet_caps: join_csv(cfg.tools.snippet_caps),
    workdir: cwd,
    ohmy_pi: cfg.tools.ohmy_pi,
    delegated_timeout_ms: cfg.tools.delegated_timeout_ms,
    delegated_poll_ms: cfg.tools.delegated_poll_ms,
    delegated_timeout_slack_ms: cfg.tools.delegated_timeout_slack_ms,
    max_retries: cfg.agent.max_retries,
    retry_base_ms: cfg.agent.retry_base_ms,
    retry_cap_ms: cfg.agent.retry_cap_ms,
    max_steps: cfg.agent.max_steps,
    verifier_mode: cfg.agent.semi_formal_verifier_mode,
    max_cost_millicents: cfg.agent.max_cost_millicents,
    cost_rates: cfg.cost_rates
  };
  let bv = version();
  let _ = emit(encode(jo([
    kv("type", js("session_start")),
    kv("task", js(task)),
    kv("model", js(model)),
    kv("brainVersion", js(bv)),
    kv("ailangBuilt", js(ailang_built)),
    kv("config_profile", js(cfg.profile)),
    kv("config_dir", js(cfg.profile_dir)),
    kv("backend_mode", js(cfg.backend.mode)),
    kv("loaded_extensions", ja(json_string_values(loaded_extension_names(ext_runtime))))
  ])));

  let hint = get_hint(task);
  let system_md_path = cfg.agent.system_prompt;
  let raw_system =
    if system_md_path == "" then ""
    else if fileExists(system_md_path)
    then readFile(system_md_path)
    else {
      let _ = emit(encode(jo([
        kv("type", js("warning")),
        kv("message", js("system prompt file not found at '${system_md_path}'; running without a system prompt."))])));
      ""
    };
  let budget = compute_budget_plan(ext_runtime, task, model, cwd, hybrid_enabled, 0, settings);
  let remaining = budget.total;
  let system_with_agents = with_agents_context(raw_system, cwd);
  let system_with_hint = with_cache_hint(system_with_agents, hint);
  let system_ctx = {
    task: task,
    step: 0,
    model: model,
    cwd: cwd,
    hybrid_tools: hybrid_enabled,
    budget: budget,
    mode: "default",
    workdir: cwd,
    env_server_url: env_url,
    budget_remaining: remaining,
    history_slice: [],
    state_key: "core:ext:system"
  };
  let system = dispatch_build_system_prompt(ext_runtime, system_ctx, system_with_hint);

  let init: [Msg] = [
    { role: "system", content: system, tool_calls: [], tool_call_id: "" },
    { role: "user", content: task, tool_calls: [], tool_call_id: "" }
  ];

  let _ = emit(encode(jo([
    kv("type", js("v2_mode")),
    kv("note", js("running with upstream std/ai.step (typed tool_calls) — M-MOTOKO-RPC-LOOP-FULL-MIGRATION cutover complete"))
  ])));
  run_v2_with_conversation(ext_runtime, task, env_url, hybrid_enabled, budget, model, init, settings.workdir, budget.total, settings.ohmy_pi, settings.max_cost_millicents, settings.cost_rates, LiveAI)
}

export func main() -> () ! {Net, AI, SharedMem, IO, Env, FS, Clock, Process, Stream} {
  let cfg = load_runtime_config();
  let inv = load_invocation_config();
  run_with_config(cfg, inv)
}
