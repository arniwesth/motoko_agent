type RunSettings = {
  task: string,
  ailang_built: string,
  snippet_caps: string,
  workdir: string,
  ohmy_pi: bool,
  delegated_timeout_ms: int,
  delegated_poll_ms: int,
  delegated_timeout_slack_ms: int,
  max_retries: int,
  retry_base_ms: int,
  retry_cap_ms: int,
  max_steps: int,
  verifier_mode: bool
}

func emit(obj: string) -> () ! {IO} {
  println(obj)
}

func get_str(obj: Json, key: string) -> string {
  match get(obj, key) {
    None    => "",
    Some(j) => match asString(j) { None => "", Some(s) => s }
  }
}

func get_num(obj: Json, key: string, fallback: int) -> int {
  match get(obj, key) {
    None => fallback,
    Some(j) => match asNumber(j) { None => fallback, Some(n) => _float_to_int(n) }
  }
}

func get_bool(obj: Json, key: string, fallback: bool) -> bool {
  match get(obj, key) {
    None => fallback,
    Some(j) => match asBool(j) { None => fallback, Some(b) => b }
  }
}

func json_string_values(xs: [string]) -> [Json] {
  match xs {
    [] => [],
    x :: rest => js(x) :: json_string_values(rest)
  }
}

-- AILANG v0.15.x migration regression: the fork's `_io_poll_stdin()` builtin
-- (non-blocking stdin read) doesn't exist upstream. The stdin-polling abort
-- + model-change feature relied on it. As a temporary workaround, this stub
-- returns None (no pending control command), which means:
--   - The agent CANNOT be aborted mid-turn via stdin "abort" message
--   - The agent CANNOT receive runtime model changes via stdin
-- Other control paths (fault-tolerant retries, normal turn completion) work.
-- Tracked as a separate concern from the main streaming migration; needs
-- either an upstream `_io_poll_stdin` builtin or a non-blocking-read
-- equivalent built atop `std/process` polling (sigtimedwait pattern).
func poll_cmd() -> Option[string] ! {IO} {
  None
}

func emit_context_usage(state: AgentState, model: string) -> () ! {IO} {
  let system = match state.msgs {
    m :: rest =>
      if m.role == "system"
      then m.content
      else "",
    [] => ""
  };
  let history = match state.msgs {
    m :: rest =>
      if m.role == "system"
      then rest
      else state.msgs,
    [] => []
  };
  let tokens_est = estimate_tokens(history, system);
  let limit = context_limit_for(model);
  emit(encode(jo([
    kv("type", js("context_usage")),
    kv("step", jnum(_int_to_float(state.step))),
    kv("tokens_est", jnum(_int_to_float(tokens_est))),
    kv("limit", jnum(_int_to_float(limit)))
  ])))
}

type DrainOutcome = { state: AgentState, model: string, aborted: bool }

func queue_inbox(state: AgentState, raw: string) -> AgentState {
  {
    env_url: state.env_url,
    msgs: state.msgs,
    cwd: state.cwd,
    step: state.step,
    inbox: state.inbox ++ [raw]
  }
}

func persist_current_model(model: string) -> () ! {SharedMem} {
  let bytes = _bytes_from_string(model);
  _sharedmem_put("core:current_model", bytes)
}

func drain_cmds(state: AgentState, model: string) -> DrainOutcome ! {IO, SharedMem} {
  match poll_cmd() {
    None => { state: state, model: model, aborted: false },
    Some(raw) =>
      match decode(raw) {
        Err(_) => drain_cmds(queue_inbox(state, raw), model),
        Ok(obj) => {
          let t = get_str(obj, "type");
          if t == "abort" then {
            { state: state, model: model, aborted: true }
          } else if t == "model_change" then {
            let new_model = get_str(obj, "model");
            let _ = persist_current_model(new_model);
            drain_cmds(state, new_model)
          } else {
            drain_cmds(queue_inbox(state, raw), model)
          }
        }
      }
  }
}

func task_from_msgs(msgs: [Msg]) -> string {
  match msgs {
    _ :: user :: _ => user.content,
    _ => ""
  }
}

func last_user_prompt(msgs: [Msg]) -> string {
  foldl(\acc m. if m.role == "user" then m.content else acc, "", msgs)
}

func tool_call_id(call_req: ToolCallEnvelope) -> string {
  call_req.id
}

func tool_result_item_to_display(item: ToolResultItem) -> Json {
  match item {
    ReadFileResult(r)  => jo([kv("tool_call_id", js(r.id)), kv("exit_code", jnum(0.0))]),
    SearchResult(r)    => jo([kv("tool_call_id", js(r.id)), kv("exit_code", jnum(0.0))]),
    WriteFileResult(r) => jo([
      kv("tool_call_id", js(r.id)),
      kv("exit_code", jnum(0.0)),
      kv("stdout", js(r.diff)),
      kv("stderr", js("")),
      kv("truncated", jb(false))
    ]),
    EditFileResult(r) => jo([
      kv("tool_call_id", js(r.id)),
      kv("exit_code", jnum(0.0)),
      kv("stdout", js(r.diff)),
      kv("stderr", js("")),
      kv("truncated", jb(false))
    ]),
    BashExecResult(r)  => jo([kv("tool_call_id", js(r.id)), kv("exit_code", jnum(_int_to_float(r.exit_code)))]),
    RunTestsResult(r)  => jo([kv("tool_call_id", js(r.id)), kv("exit_code", jnum(_int_to_float(r.exit_code)))]),
    ToolErrorResult(r) => jo([
      kv("tool_call_id", js(r.id)),
      kv("exit_code", jnum(1.0)),
      kv("tool", js(r.tool)),
      kv("message", js(r.message)),
      kv("stdout", js("")),
      kv("stderr", js(r.message)),
      kv("truncated", jb(false))
    ])
  }
}

func tool_result_items_to_display_json(items: [ToolResultItem]) -> [Json] {
  match items {
    [] => [],
    item :: rest => tool_result_item_to_display(item) :: tool_result_items_to_display_json(rest)
  }
}

func tool_calls_to_json(calls: [ToolCallEnvelope]) -> [Json] {
  match calls {
    [] => [],
    c :: rest => call_to_json(c) :: tool_calls_to_json(rest)
  }
}

func is_native_tool_name(name: string) -> bool {
  name == "ReadFile"
    || name == "Search"
    || name == "WriteFile"
    || name == "EditFile"
    || name == "BashExec"
    || name == "RunTests"
}

func is_extension_tool_call(call_req: ToolCallEnvelope) -> bool {
  not is_native_tool_name(call_req.tool)
}

func filter_extension_calls(calls: [ToolCallEnvelope]) -> [ToolCallEnvelope] {
  match calls {
    [] => [],
    c :: rest => {
      let tail = filter_extension_calls(rest);
      if is_extension_tool_call(c) then c :: tail else tail
    }
  }
}

func tool_result_envelopes_to_json(items: [ToolResultEnvelope]) -> [Json] {
  match items {
    [] => [],
    x :: rest => result_to_json(x) :: tool_result_envelopes_to_json(rest)
  }
}

func has_envelope_items(xs: [ToolResultEnvelope]) -> bool {
  match xs {
    [] => false,
    _ :: _ => true
  }
}

func one_ext_result_line(r: ToolResultEnvelope) -> string {
  let stderr_block = if r.stderr == "" then "" else "\n[stderr]\n${r.stderr}";
  let meta_json = encode(r.metadata);
  let meta_block = if meta_json == "{}" then "" else "\n[metadata]\n${meta_json}";
  "[${r.tool_call_id}] ${r.tool}\n[exit ${show(r.exit_code)}]\n${r.stdout}${stderr_block}${meta_block}"
}

func join_ext_result_lines(xs: [ToolResultEnvelope]) -> string {
  match xs {
    [] => "",
    r :: [] => one_ext_result_line(r),
    r :: rest => "${one_ext_result_line(r)}\n\n${join_ext_result_lines(rest)}"
  }
}

func fmt_ext_tool_obs(results: [ToolResultEnvelope]) -> string {
  if has_envelope_items(results) then "\n\nExtension tool results:\n\n${join_ext_result_lines(results)}" else ""
}

func is_tool_results_for(raw: string, request_id: string) -> bool {
  match decode(raw) {
    Err(_) => false,
    Ok(obj) => get_str(obj, "type") == "tool_results" && get_str(obj, "request_id") == request_id
  }
}

func pull_tool_results(inbox: [string], request_id: string, acc: [string]) -> Option[{ raw: string, rest: [string] }] {
  match inbox {
    [] => None,
    x :: rest =>
      if is_tool_results_for(x, request_id)
      then Some({ raw: x, rest: concat(reverse(acc), rest) })
      else pull_tool_results(rest, request_id, x :: acc)
  }
}

type DelegatedWait
  = DelegatedReceived({ state: AgentState, model: string, raw: string })
  | DelegatedTimedOut({ state: AgentState, model: string })
  | DelegatedAborted({ state: AgentState, model: string })

func wait_for_tool_results(
  state: AgentState,
  model: string,
  request_id: string,
  attempts: int
) -> DelegatedWait ! {IO, SharedMem} {
  match pull_tool_results(state.inbox, request_id, []) {
    Some(hit) =>
      DelegatedReceived({
        state: {
          env_url: state.env_url,
          msgs: state.msgs,
          cwd: state.cwd,
          step: state.step,
          inbox: hit.rest
        },
        model: model,
        raw: hit.raw
      }),
    None => {
      if attempts <= 0 then DelegatedTimedOut({ state: state, model: model })
      else {
        let raw = readLine();
        if raw == "" then DelegatedTimedOut({ state: state, model: model })
        else
          match decode(trim(raw)) {
            Err(_) => wait_for_tool_results(queue_inbox(state, raw), model, request_id, attempts - 1),
            Ok(obj) => {
              let t = get_str(obj, "type");
              if t == "abort" then DelegatedAborted({ state: state, model: model })
              else if t == "model_change" then {
                let new_model = get_str(obj, "model");
                let _ = persist_current_model(new_model);
                wait_for_tool_results(state, new_model, request_id, attempts - 1)
              } else if t == "tool_results" && get_str(obj, "request_id") == request_id then {
                DelegatedReceived({ state: state, model: model, raw: trim(raw) })
              } else {
                wait_for_tool_results(queue_inbox(state, raw), model, request_id, attempts - 1)
              }
            }
          }
      }
    }
  }
}

func meta_from(stdout: string, stderr: string, truncated: bool) -> ToolResultMeta {
  {
    truncated: truncated,
    stdout_bytes: length(stdout),
    stdout_total_bytes: length(stdout),
    stderr_bytes: length(stderr),
    stderr_total_bytes: length(stderr),
    stdout_sha256: sha256Hex(stdout),
    stderr_sha256: sha256Hex(stderr)
  }
}

func find_exec_result(entries: [Json], id: string) -> Option[Json] {
  match entries {
    [] => None,
    x :: rest =>
      if get_str(x, "tool_call_id") == id then Some(x) else find_exec_result(rest, id)
  }
}

func delegated_result_for_call(call_req: ToolCallEnvelope, entries: [Json]) -> ToolResultItem {
  let id = tool_call_id(call_req);
  match find_exec_result(entries, id) {
    None => ToolErrorResult({ id: id, tool: "delegated", message: "missing delegated result" }),
    Some(item) => {
      let stdout = get_str(item, "stdout");
      let stderr = get_str(item, "stderr");
      let exit_code = get_num(item, "exit_code", 1);
      let truncated = get_bool(item, "truncated", false);
      let meta = meta_from(stdout, stderr, truncated);
      if call_req.tool == "ReadFile" then
        ReadFileResult({
          id: call_req.id,
          path: string_field(call_req.arguments, "path", ""),
          content: stdout,
          line_count: if stdout == "" then 0 else list_len(split(stdout, "\n")),
          truncated: truncated,
          sha256: sha256Hex(stdout)
        })
      else if call_req.tool == "WriteFile" then
        WriteFileResult({
          id: call_req.id,
          path: string_field(call_req.arguments, "path", ""),
          bytes_written: length(string_field(call_req.arguments, "content", "")),
          sha256: sha256Hex(string_field(call_req.arguments, "content", "")),
          diff: stdout
        })
      else if call_req.tool == "EditFile" then
        EditFileResult({
          id: call_req.id,
          path: string_field(call_req.arguments, "path", ""),
          bytes_written: 0,
          sha256: "",
          diff: stdout,
          first_changed_line: 0,
          applied_edits: parse_applied_edits(stdout),
          dry_run: get_bool(call_req.arguments, "dry_run", false),
          match_strategy: "delegated"
        })
      else if call_req.tool == "Search" then
        SearchResult({
          id: call_req.id,
          pattern: string_field(call_req.arguments, "pattern", ""),
          matches: search_matches_from_stdout(stdout)
        })
      else if call_req.tool == "BashExec" then
          BashExecResult({
            id: call_req.id,
            cmd: string_field(call_req.arguments, "cmd", ""),
            stdout: stdout,
            stderr: stderr,
            exit_code: exit_code,
            meta: meta
          })
      else if call_req.tool == "RunTests" then {
          let failed = if exit_code == 0 then 0 else 1;
          RunTestsResult({
            id: call_req.id,
            cmd: string_field(call_req.arguments, "cmd", ""),
            stdout: stdout,
            stderr: stderr,
            exit_code: exit_code,
            passed: if failed == 0 then 1 else 0,
            failed: failed,
            failures: if failed == 0 then [] else [{ test: "delegated", message: "non-zero exit" }],
            meta: meta
          })
        }
      else
        ToolErrorResult({ id: id, tool: "delegated", message: "invalid delegated tool kind" })
    }
  }
}

func list_len[a](xs: [a]) -> int {
  match xs {
    [] => 0,
    _ :: rest => 1 + list_len(rest)
  }
}

func parse_applied_edits(stdout: string) -> int {
  let parts = split(stdout, "applied_edits=");
  match parts {
    _ :: rest =>
      match rest {
        value_part :: rest2 =>
          match split(value_part, " ") {
            n :: rest3 =>
              match _stringToInt(trim(n)) {
                Some(v) => if v < 0 then 0 else v,
                None => 0
              },
            _ => 0
          },
        _ => 0
      },
    _ => 0
  }
}

func non_empty_lines(xs: [string]) -> [string] {
  match xs {
    [] => [],
    x :: rest =>
      if trim(x) == "" then non_empty_lines(rest) else x :: non_empty_lines(rest)
  }
}

func lines_to_search_matches(lines: [string], idx: int) -> [SearchMatch] {
  match lines {
    [] => [],
    line :: rest =>
      ({
        path: ".",
        line_number: idx,
        line_text: line,
        context: []
      }) :: lines_to_search_matches(rest, idx + 1)
  }
}

func search_matches_from_stdout(stdout: string) -> [SearchMatch] {
  lines_to_search_matches(non_empty_lines(split(stdout, "\n")), 1)
}

func delegated_results_from_entries(calls: [ToolCallEnvelope], entries: [Json]) -> [ToolResultItem] {
  match calls {
    [] => [],
    c :: rest => delegated_result_for_call(c, entries) :: delegated_results_from_entries(rest, entries)
  }
}

func decode_delegated_results(raw: string, delegated_calls: [ToolCallEnvelope]) -> [ToolResultItem] {
  match decode(raw) {
    Err(err) => [ToolErrorResult({ id: "delegated", tool: "tool_results", message: "decode failed: ${err}" })],
    Ok(obj) =>
      match get(obj, "results") {
        None => [ToolErrorResult({ id: "delegated", tool: "tool_results", message: "missing results array" })],
        Some(j) =>
          match asArray(j) {
            None => [ToolErrorResult({ id: "delegated", tool: "tool_results", message: "results must be an array" })],
            Some(entries) => delegated_results_from_entries(delegated_calls, entries)
          }
      }
  }
}

func delegated_timeout_results(calls: [ToolCallEnvelope]) -> [ToolResultItem] {
  match calls {
    [] => [],
    c :: rest =>
      ToolErrorResult({
        id: tool_call_id(c),
        tool: "delegated",
        message: "timed out waiting for tool_results"
      }) :: delegated_timeout_results(rest)
  }
}

func delegated_aborted_results(calls: [ToolCallEnvelope]) -> [ToolResultItem] {
  match calls {
    [] => [],
    c :: rest =>
      ToolErrorResult({
        id: tool_call_id(c),
        tool: "delegated",
        message: "aborted"
      }) :: delegated_aborted_results(rest)
  }
}

func clamp_positive(n: int, fallback: int) -> int {
  if n > 0 then n else fallback
}

func clamp_non_negative(n: int) -> int {
  if n < 0 then 0 else n
}

func clamp_range(n: int, lo: int, hi: int) -> int {
  if n < lo then lo else if n > hi then hi else n
}

func tool_parse_error_feedback(err: string) -> string {
  if contains(err, "likely unescaped quote") then
    "Tool parse error: ${err}\nFix and retry with ONLY a JSON tool_calls block.\nFor WriteFile/EditFile strings, escape inner quotes as \\\" and keep newlines as \\n.\nIf content is long markdown/text, use BashExec heredoc: bash -lc 'cat > path << '\\''EOF'\\'' ... EOF'."
  else
    "Tool parse error: ${err}\nRespond with valid JSON tool_calls only (no prose around JSON)."
}

func continuation_intent_marker() -> string =
  "MOTOKO_CONTINUATION_INTENT_REPAIR"

func continuation_intent_feedback() -> string =
  "MOTOKO_CONTINUATION_INTENT_REPAIR: You said you intend to continue, but emitted no tool call or command. In Motoko, a prose-only response ends the run. If you intend to continue, emit the next JSON tool_calls block now. If the task is complete, provide a final answer without promising future tool use."

func default_budget_plan(total: int, verifier_mode: bool) -> BudgetPlan {
  if verifier_mode then {
    let v0 = total / 4;
    let verifier = if v0 < 1 then 1 else v0;
    { total: total, solver: total - verifier, verifier: verifier }
  } else {
    { total: total, solver: total, verifier: 0 }
  }
}

func clamp_budget_plan(plan: BudgetPlan, max_total: int) -> BudgetPlan {
  let total = clamp_range(plan.total, 1, max_total);
  let solver0 = clamp_non_negative(plan.solver);
  let verifier0 = clamp_non_negative(plan.verifier);
  let solver = clamp_range(solver0, 0, total);
  let verifier = clamp_range(verifier0, 0, total - solver);
  { total: total, solver: solver, verifier: verifier }
}

func mk_ext_ctx(
  state: AgentState,
  model: string,
  hybrid_enabled: bool,
  budget: BudgetPlan,
  mode: string
) -> ExtCtx {
  let remaining = if budget.total - state.step < 0 then 0 else budget.total - state.step;
  {
    task: task_from_msgs(state.msgs),
    step: state.step,
    model: model,
    cwd: state.cwd,
    hybrid_tools: hybrid_enabled,
    budget: budget,
    mode: mode,
    workdir: state.cwd,
    env_server_url: state.env_url,
    budget_remaining: remaining,
    history_slice: state.msgs,
    state_key: "core:ext:${mode}"
  }
}

func compute_budget_plan(
  ext_runtime: ExtRuntime,
  task: string,
  model: string,
  cwd: string,
  hybrid_enabled: bool,
  step: int,
  settings: RunSettings
) -> BudgetPlan ! {Env, IO, Clock} {
  let max_steps = clamp_positive(settings.max_steps, 50);
  let verifier_mode = settings.verifier_mode;
  let base = default_budget_plan(max_steps, verifier_mode);
  let remaining = if base.total - step < 0 then 0 else base.total - step;
  let ctx = {
    task: task,
    step: step,
    model: model,
    cwd: cwd,
    hybrid_tools: hybrid_enabled,
    budget: base,
    mode: if verifier_mode then "verifier" else "default",
    workdir: cwd,
    env_server_url: "",
    budget_remaining: remaining,
    history_slice: [],
    state_key: "core:ext:budget"
  };
  let patched = dispatch_budget_plan(ext_runtime, ctx, base);
  clamp_budget_plan(patched, max_steps)
}

func ceil_ticks(timeout_ms: int, poll_ms: int, acc: int) -> int {
  if timeout_ms <= 0 then acc
  else ceil_ticks(timeout_ms - poll_ms, poll_ms, acc + 1)
}

func delegated_wait_attempts(delegated_count: int, settings: RunSettings) -> int {
  let count = clamp_non_negative(delegated_count);
  let per_call_ms = clamp_positive(settings.delegated_timeout_ms, 30000);
  let poll_ms = clamp_positive(settings.delegated_poll_ms, 100);
  let slack_ms = clamp_non_negative(settings.delegated_timeout_slack_ms);
  let batch_timeout_ms = (count * per_call_ms) + slack_ms;
  let attempts = ceil_ticks(batch_timeout_ms, poll_ms, 0);
  if attempts <= 0 then 1 else attempts
}

func warnings_prefix(warnings: [string]) -> string {
  match warnings {
    [] => "",
    _ => "Tool warnings:\n${join_lines(warnings)}\n\n"
  }
}

func join_lines(xs: [string]) -> string {
  match xs {
    [] => "",
    x :: [] => x,
    x :: rest => "${x}\n${join_lines(rest)}"
  }
}

func join_csv(xs: [string]) -> string {
  match xs {
    [] => "",
    x :: [] => x,
    x :: rest => "${x},${join_csv(rest)}"
  }
}

-- Count consecutive AILANG type-check failures at the current step
-- by scanning backward through messages for our retry feedback marker.
func count_ailang_retries(msgs: [Msg]) -> int {
  count_ailang_retries_rev(reverse(msgs), 0)
}

func count_ailang_retries_rev(msgs: [Msg], acc: int) -> int {
  match msgs {
    [] => acc,
    m :: rest =>
      if m.role == "user" && contains(m.content, "AILANG type-check failed (retry ") then
        count_ailang_retries_rev(rest, acc + 1)
      else if m.role == "user" && contains(m.content, "AILANG type-check failed (3/3)") then
        acc
      else acc
  }
}

func has_recent_continuation_intent_repair(msgs: [Msg]) -> bool =
  has_recent_continuation_intent_repair_loop(reverse(msgs), 6)

func has_recent_continuation_intent_repair_loop(msgs: [Msg], remaining: int) -> bool {
  if remaining <= 0 then false
  else match msgs {
    [] => false,
    m :: rest =>
      if contains(m.content, continuation_intent_marker()) then true
      else has_recent_continuation_intent_repair_loop(rest, remaining - 1)
  }
}

func fmt_ailang_obs(result: AilangExecResult) -> string {
  let stderr_block =
    if result.stderr == "" then ""
    else "\n[stderr]\n${result.stderr}";
  "AILANG snippet result:\n[exit ${show(result.exit_code)}]\n${result.stdout}${stderr_block}"
}

func non_empty_lines(xs: [string]) -> [string] {
  match xs {
    [] => [],
    x :: rest =>
      if trim(x) == "" then non_empty_lines(rest) else x :: non_empty_lines(rest)
  }
}

func run_ailang_step(
  state: AgentState,
  model2: string,
  code: string,
  msgs1: [Msg],
  depth: int,
  step_delay: int,
  hybrid_enabled: bool,
  ext_runtime: ExtRuntime,
  budget: BudgetPlan,
  check_attempt: int,
  settings: RunSettings
) -> AgentState ! {Net, AI, SharedMem, IO, Clock, FS, Process, Env} {
  let caps = settings.snippet_caps;
  let task = settings.task;
  -- The last user message in the conversation is the immediate trigger for this snippet.
  -- foldl keeps overwriting whenever it sees a "user" role, so the final value is the last one.
  let prompt = foldl(\acc m. if m.role == "user" then m.content else acc, "", msgs1);
  let result = exec_ailang(state.env_url, code, caps, 30, task, prompt);

  -- Emit proposed_ailang event
  let _ = emit(encode(jo([
    kv("type", js("proposed_ailang")),
    kv("step", jnum(_int_to_float(state.step))),
    kv("code", js(code))])));

  if not result.check_passed then {
    -- Type-check failed — emit ailang_check event
    let _ = emit(encode(jo([
      kv("type",         js("ailang_check")),
      kv("step",         jnum(_int_to_float(state.step))),
      kv("passed",       jb(false)),
      kv("errors",       js(result.check_errors)),
      kv("attempt",      jnum(_int_to_float(check_attempt))),
      kv("max_attempts", jnum(3.0))])));

    if check_attempt >= 3 then {
      -- Budget exhausted: step IS decremented, fall back to normal flow
      let feedback = "AILANG type-check failed (3/3), falling back to bash/tool calls. Error:\n${result.check_errors}\nUse bash or JSON tool calls instead.";
      let msgs2 = msgs1 ++ [{ role: "user", content: feedback }];
      rpc_loop({
        env_url: state.env_url,
        msgs: msgs2,
        cwd: state.cwd,
        step: state.step + 1,
        inbox: state.inbox
      }, model2, depth - 1, step_delay, hybrid_enabled, ext_runtime, budget, settings)
    } else {
      -- Free retry: step NOT decremented
      let doc_hint = ailang_error_doc_section(result.check_errors);
      let feedback = "AILANG type-check failed (retry ${show(check_attempt)}/3):\n${result.check_errors}${doc_hint}\nFix the snippet and re-emit it in a ```ailang fenced block.";
      let msgs2 = msgs1 ++ [{ role: "user", content: feedback }];
      -- Recurse back into rpc_loop with same depth (no step cost)
      rpc_loop({
        env_url: state.env_url,
        msgs: msgs2,
        cwd: state.cwd,
        step: state.step,
        inbox: state.inbox
      }, model2, depth, step_delay, hybrid_enabled, ext_runtime, budget, settings)
    }
  } else {
    -- Type-check passed — emit check event then observation
    let _ = emit(encode(jo([
      kv("type",         js("ailang_check")),
      kv("step",         jnum(_int_to_float(state.step))),
      kv("passed",       jb(true)),
      kv("errors",       js("")),
      kv("attempt",      jnum(_int_to_float(check_attempt))),
      kv("max_attempts", jnum(3.0))])));

    let _ = emit(encode(jo([
      kv("type",      js("obs")),
      kv("step",      jnum(_int_to_float(state.step))),
      kv("cmd",       js("ailang snippet")),
      kv("stdout",    js(result.stdout)),
      kv("stderr",    js(result.stderr)),
      kv("exit_code", jnum(_int_to_float(result.exit_code)))])));

    if is_done(result.stdout) then {
      let _ = emit(encode(jo([
        kv("type",   js("done")),
        kv("step",   jnum(_int_to_float(state.step))),
        kv("output", js(result.stdout))])));
      let _ = put_trajectory(task_from_msgs(state.msgs), result.stdout);
      {
        env_url: state.env_url,
        msgs: msgs1,
        cwd: state.cwd,
        step: state.step,
        inbox: state.inbox
      }
    } else {
      let obs_text = fmt_ailang_obs(result);
      let msgs2 = msgs1 ++ [{ role: "user", content: obs_text }];
      rpc_loop({
        env_url: state.env_url,
        msgs: msgs2,
        cwd: state.cwd,
        step: state.step + 1,
        inbox: state.inbox
      }, model2, depth - 1, step_delay, hybrid_enabled, ext_runtime, budget, settings)
    }
  }
}

func run_legacy_step(
  state: AgentState,
  model2: string,
  response: string,
  msgs1: [Msg],
  depth: int,
  step_delay: int,
  hybrid_enabled: bool,
  ext_runtime: ExtRuntime,
  budget: BudgetPlan,
  settings: RunSettings
) -> AgentState ! {Net, AI, SharedMem, IO, Clock, FS, Process, Env} {
  match extract_bash(response) {
    None => {
      let ctx = mk_ext_ctx(state, model2, hybrid_enabled, budget, "default");
      match dispatch_solver_candidate(ext_runtime, ctx, response) {
        ContinueWithFeedback(feedback) => {
          let msgs2 = msgs1 ++ [{ role: "user", content: feedback }];
          rpc_loop({
            env_url: state.env_url,
            msgs: msgs2,
            cwd: state.cwd,
            step: state.step + 1,
            inbox: state.inbox
          }, model2, depth - 1, step_delay, hybrid_enabled, ext_runtime, budget, settings)
        },
        Accept(output) => {
          let _ = emit(encode(jo([
            kv("type",   js("done")),
            kv("step",   jnum(_int_to_float(state.step))),
            kv("output", js(output))])));
          let _ = put_trajectory(task_from_msgs(state.msgs), output);
          {
            env_url: state.env_url,
            msgs: msgs1,
            cwd: state.cwd,
            step: state.step,
            inbox: state.inbox
          }
        },
        NoDecision => {
          let visible = assistant_visible_output(response);
          if indicates_continuation_intent(visible) && not has_recent_continuation_intent_repair(state.msgs) then {
            let msgs2 = msgs1 ++ [{ role: "user", content: continuation_intent_feedback() }];
            rpc_loop({
              env_url: state.env_url,
              msgs: msgs2,
              cwd: state.cwd,
              step: state.step + 1,
              inbox: state.inbox
            }, model2, depth - 1, step_delay, hybrid_enabled, ext_runtime, budget, settings)
          } else {
            let _ = emit(encode(jo([
              kv("type",   js("done")),
              kv("step",   jnum(_int_to_float(state.step))),
              kv("output", js(visible))])));
            let _ = if trim(visible) == "" then () else put_trajectory(task_from_msgs(state.msgs), visible);
            {
              env_url: state.env_url,
              msgs: msgs1,
              cwd: state.cwd,
              step: state.step,
              inbox: state.inbox
            }
          }
        }
      }
    },
    Some(raw_cmd) => {
      let _ = emit(encode(jo([
        kv("type", js("proposed_cmd")),
        kv("step", jnum(_int_to_float(state.step))),
        kv("cmd",  js(raw_cmd))])));

      let cmd = "cd ${state.cwd} && ${raw_cmd}";
      let result = exec_in(state.env_url, cmd, 30);

      let _ = emit(encode(jo([
        kv("type",      js("obs")),
        kv("step",      jnum(_int_to_float(state.step))),
        kv("cmd",       js(raw_cmd)),
        kv("stdout",    js(result.stdout)),
        kv("stderr",    js(result.stderr)),
        kv("exit_code", jnum(_int_to_float(result.exit_code)))])));

      if is_done(result.stdout) then {
        let _ = emit(encode(jo([
          kv("type",   js("done")),
          kv("step",   jnum(_int_to_float(state.step))),
          kv("output", js(result.stdout))])));
        let _ = put_trajectory(task_from_msgs(state.msgs), result.stdout);
        {
          env_url: state.env_url,
          msgs: msgs1,
          cwd: state.cwd,
          step: state.step,
          inbox: state.inbox
        }
      } else {
        let msgs2 = msgs1 ++ [{ role: "user", content: fmt_obs(raw_cmd, result) }];
        rpc_loop({
          env_url: state.env_url,
          msgs: msgs2,
          cwd: parse_cwd(raw_cmd, state.cwd),
          step: state.step + 1,
          inbox: state.inbox
        }, model2, depth - 1, step_delay, hybrid_enabled, ext_runtime, budget, settings)
      }
    }
  }
}

func tool_name(call_req: ToolCallEnvelope) -> string {
  call_req.tool
}

func apply_tool_policy(
  calls: [ToolCallEnvelope],
  ext_runtime: ExtRuntime,
  ctx: ExtCtx
) -> { allowed: [ToolCallEnvelope], denied: [ToolResultItem] } ! {IO, Clock, Env} {
  match calls {
    [] => { allowed: [], denied: [] },
    c :: rest => {
      let current = dispatch_tool_policy(ext_runtime, ctx, c);
      let next = apply_tool_policy(rest, ext_runtime, ctx);
      match current {
        Deny(msg) => {
          let denied = ToolErrorResult({ id: tool_call_id(c), tool: tool_name(c), message: msg });
          { allowed: next.allowed, denied: denied :: next.denied }
        },
        _ => {
          { allowed: c :: next.allowed, denied: next.denied }
        }
      }
    }
  }
}

func route_tool_handles(
  calls: [ToolCallEnvelope],
  ext_runtime: ExtRuntime,
  ctx: ExtCtx
) -> { handled: [ToolResultEnvelope], passthrough: [ToolCallEnvelope] } ! {IO, Process, FS, AI, Env, Net, SharedMem, Clock, Stream} {
  match calls {
    [] => { handled: [], passthrough: [] },
    c :: rest => {
      let next = route_tool_handles(rest, ext_runtime, ctx);
      match dispatch_tool_handle(ext_runtime, ctx, c) {
        Handled(item) => { handled: item :: next.handled, passthrough: next.passthrough },
        Delegate => { handled: next.handled, passthrough: c :: next.passthrough }
      }
    }
  }
}

func run_hybrid_step(
  state: AgentState,
  model2: string,
  response: string,
  msgs1: [Msg],
  depth: int,
  step_delay: int,
  hybrid_enabled: bool,
  ext_runtime: ExtRuntime,
  budget: BudgetPlan,
  settings: RunSettings
) -> AgentState ! {Net, AI, SharedMem, IO, Clock, FS, Process, Env, Stream} {
  let ctx = mk_ext_ctx(state, model2, hybrid_enabled, budget, "default");
  match dispatch_response_intercept(ext_runtime, ctx, response) {
    InterceptHandled(item) => {
      let obs_text = fmt_ext_tool_obs([item]);
      let msgs2 = msgs1 ++ [{ role: "user", content: obs_text }];
      rpc_loop({
        env_url: state.env_url,
        msgs: msgs2,
        cwd: state.cwd,
        step: state.step + 1,
        inbox: state.inbox
      }, model2, depth - 1, step_delay, hybrid_enabled, ext_runtime, budget, settings)
    },
    NoIntercept => {
  match parse_tool_calls(response) {
    NoToolCalls => {
      let ctx = mk_ext_ctx(state, model2, hybrid_enabled, budget, "default");
      match dispatch_solver_candidate(ext_runtime, ctx, response) {
        ContinueWithFeedback(feedback) => {
          let msgs2 = msgs1 ++ [{ role: "user", content: feedback }];
          rpc_loop({
            env_url: state.env_url,
            msgs: msgs2,
            cwd: state.cwd,
            step: state.step + 1,
            inbox: state.inbox
          }, model2, depth - 1, step_delay, hybrid_enabled, ext_runtime, budget, settings)
        },
        Accept(output) => {
          let _ = emit(encode(jo([
            kv("type",   js("done")),
            kv("step",   jnum(_int_to_float(state.step))),
            kv("output", js(output))])));
          let _ = put_trajectory(task_from_msgs(state.msgs), output);
          {
            env_url: state.env_url,
            msgs: msgs1,
            cwd: state.cwd,
            step: state.step,
            inbox: state.inbox
          }
        },
        NoDecision => {
          let visible = assistant_visible_output(response);
          if indicates_continuation_intent(visible) && not has_recent_continuation_intent_repair(state.msgs) then {
            let msgs2 = msgs1 ++ [{ role: "user", content: continuation_intent_feedback() }];
            rpc_loop({
              env_url: state.env_url,
              msgs: msgs2,
              cwd: state.cwd,
              step: state.step + 1,
              inbox: state.inbox
            }, model2, depth - 1, step_delay, hybrid_enabled, ext_runtime, budget, settings)
          } else {
            let _ = emit(encode(jo([
              kv("type",   js("done")),
              kv("step",   jnum(_int_to_float(state.step))),
              kv("output", js(visible))])));
            let _ = if trim(visible) == "" then () else put_trajectory(task_from_msgs(state.msgs), visible);
            {
              env_url: state.env_url,
              msgs: msgs1,
              cwd: state.cwd,
              step: state.step,
              inbox: state.inbox
            }
          }
        }
      }
    },
    ToolParseError(err) => {
      let msgs2 = msgs1 ++ [{
        role: "user",
        content: tool_parse_error_feedback(err)
      }];
      rpc_loop({
        env_url: state.env_url,
        msgs: msgs2,
        cwd: state.cwd,
        step: state.step + 1,
        inbox: state.inbox
      }, model2, depth - 1, step_delay, hybrid_enabled, ext_runtime, budget, settings)
    },
    ParsedToolCalls(parsed) => {
      let gated = apply_tool_policy(parsed.calls, ext_runtime, ctx);
      let ext_planned = filter_extension_calls(parsed.calls);
      let ext_req_id = "ext-${show(state.step)}";
      let _ = if _list_length(ext_planned) > 0 then
        emit(encode(jo([
          kv("type", js("ext_tool_calls")),
          kv("request_id", js(ext_req_id)),
          kv("tool_calls", ja(tool_calls_to_json(ext_planned)))
        ])))
      else ();
      let handled = route_tool_handles(gated.allowed, ext_runtime, ctx);
      let by_backend: { native: [ToolCallEnvelope], delegated: [ToolCallEnvelope] } = split_by_backend(handled.passthrough, settings.ohmy_pi);
      let native_req_id = "native-${show(state.step)}";
      let _ = if _list_length(by_backend.native) > 0 then
        emit(encode(jo([
          kv("type",       js("native_tool_calls")),
          kv("request_id", js(native_req_id)),
          kv("tool_calls", ja(tool_calls_to_json(by_backend.native)))
        ])))
      else ();
      let native_results: [ToolResultItem] = run_native_batch(by_backend.native, settings.workdir);
      let ext_results: [ToolResultEnvelope] = handled.handled;
      let base_results: [ToolResultItem] = gated.denied;
      let _ = if has_envelope_items(ext_results) then
        emit(encode(jo([
          kv("type", js("ext_tool_results")),
          kv("request_id", js(ext_req_id)),
          kv("results", ja(tool_result_envelopes_to_json(ext_results)))
        ])))
      else ();
      let native_results_with_denied: [ToolResultItem] = concat(base_results, native_results);
      let _ = if _list_length(by_backend.native) > 0 then
        emit(encode(jo([
          kv("type",       js("native_tool_results")),
          kv("request_id", js(native_req_id)),
          kv("results",    ja(tool_result_items_to_display_json(native_results)))
        ])))
      else ();
      if _list_length(by_backend.delegated) == 0 then {
        let all_results = native_results_with_denied;
        let obs_text = "${warnings_prefix(parsed.warnings)}${fmt_tool_obs(all_results)}${fmt_ext_tool_obs(ext_results)}";
        let msgs2 = msgs1 ++ [{ role: "user", content: obs_text }];
        rpc_loop({
          env_url: state.env_url,
          msgs: msgs2,
          cwd: state.cwd,
          step: state.step + 1,
          inbox: state.inbox
        }, model2, depth - 1, step_delay, hybrid_enabled, ext_runtime, budget, settings)
      } else {
        let request_id = "req-${show(state.step)}";
        let delegated_count = _list_length(by_backend.delegated);
        let attempts = delegated_wait_attempts(delegated_count, settings);
        let _ = emit(encode(jo([
          kv("type", js("tool_calls")),
          kv("request_id", js(request_id)),
          kv("tool_calls", ja(tool_calls_to_json(by_backend.delegated)))
        ])));
        match wait_for_tool_results(state, model2, request_id, attempts) {
          DelegatedReceived(hit) => {
            let delegated_results = decode_delegated_results(hit.raw, by_backend.delegated);
            let all_results = concat(native_results_with_denied, delegated_results);
            let obs_text = "${warnings_prefix(parsed.warnings)}${fmt_tool_obs(all_results)}${fmt_ext_tool_obs(ext_results)}";
            let msgs2 = msgs1 ++ [{ role: "user", content: obs_text }];
            rpc_loop({
              env_url: state.env_url,
              msgs: msgs2,
              cwd: state.cwd,
              step: state.step + 1,
              inbox: state.inbox
            }, model2, depth - 1, step_delay, hybrid_enabled, ext_runtime, budget, settings)
          },
          DelegatedTimedOut(_) => {
            let delegated_results = delegated_timeout_results(by_backend.delegated);
            let all_results = concat(native_results_with_denied, delegated_results);
            let obs_text = "${warnings_prefix(parsed.warnings)}${fmt_tool_obs(all_results)}${fmt_ext_tool_obs(ext_results)}";
            let msgs2 = msgs1 ++ [{ role: "user", content: obs_text }];
            rpc_loop({
              env_url: state.env_url,
              msgs: msgs2,
              cwd: state.cwd,
              step: state.step + 1,
              inbox: state.inbox
            }, model2, depth - 1, step_delay, hybrid_enabled, ext_runtime, budget, settings)
          },
          DelegatedAborted(ab) => {
            let _ = emit(encode(jo([
              kv("type", js("error")),
              kv("message", js("aborted"))
            ])));
            let aborted_results = delegated_aborted_results(by_backend.delegated);
            let all_results = concat(native_results_with_denied, aborted_results);
            let obs_text = "${warnings_prefix(parsed.warnings)}${fmt_tool_obs(all_results)}${fmt_ext_tool_obs(ext_results)}\n\n[turn aborted by user before all tool results returned]";
            let msgs2 = msgs1 ++ [{ role: "user", content: obs_text }];
            {
              env_url: ab.state.env_url,
              msgs: msgs2,
              cwd: ab.state.cwd,
              step: state.step,
              inbox: ab.state.inbox
            }
          }
        }
      }
    }
  }
  }
  }
}

-- ---------------------------------------------------------------------------
-- AI retry helpers
-- ---------------------------------------------------------------------------

pure func int_min(a: int, b: int) -> int
  tests [
    ((3, 5),    3),
    ((5, 3),    3),
    ((4, 4),    4),
    ((0, 1),    0),
    ((-1, 0),  -1)
  ]
  { if a < b then a else b }

-- 2^n via recursion (capped at 30 to avoid overflow)
pure func pow2(n: int) -> int
  tests [
    (0,   1),
    (1,   2),
    (2,   4),
    (3,   8),
    (10,  1024),
    (-1,  1),
    (30,  1073741824),
    (31,  1073741824)
  ]
  {
    if n <= 0 then 1
    else if n >= 30 then 1073741824
    else 2 * pow2(n - 1)
  }

-- Exponential backoff: min(base * 2^attempt, cap)
pure func retry_wait_ms(base: int, cap: int, attempt: int) -> int
  tests [
    ((1000, 30000, 0),  1000),
    ((1000, 30000, 1),  2000),
    ((1000, 30000, 2),  4000),
    ((1000, 30000, 3),  8000),
    ((1000, 30000, 4),  16000),
    ((1000, 30000, 5),  30000),
    ((1000, 30000, 10), 30000),
    ((500,  2000,  0),  500),
    ((500,  2000,  2),  2000),
    ((1000, 1000,  0),  1000),
    ((1000, 1000,  5),  1000)
  ]
  { int_min(base * pow2(attempt), cap) }

func delegated_aborted_results_empty() -> bool
  tests [((), true)]
  {
    match delegated_aborted_results([]) {
      [] => true,
      _ => false
    }
  }

func delegated_aborted_results_marks_all_calls() -> bool
  tests [((), true)]
  {
    let calls = [
      { id: "c1", tool: "BashExec", arguments: jo([]) },
      { id: "c2", tool: "RunTests", arguments: jo([]) }
    ];
    let rendered = encode(ja(tool_result_items_to_display_json(delegated_aborted_results(calls))));
    contains(rendered, "\"tool_call_id\":\"c1\"")
      && contains(rendered, "\"tool_call_id\":\"c2\"")
      && contains(rendered, "\"message\":\"aborted\"")
  }

func retry_from_settings(settings: RunSettings) -> { max_retries: int, base_ms: int, cap_ms: int } {
  let max_retries = clamp_non_negative(settings.max_retries);
  let base_ms = clamp_positive(settings.retry_base_ms, 1000);
  let cap_ms = clamp_positive(settings.retry_cap_ms, 30000);
  { max_retries: max_retries, base_ms: base_ms, cap_ms: cap_ms }
}

func stream_attempt_id(stream_id: string, attempt: int) -> string {
  if attempt <= 0 then stream_id else "${stream_id}-r${show(attempt)}"
}

func ai_stream_call_with_retry(
  input: string,
  step: int,
  stream_id: string,
  model: string,
  max_retries: int,
  base_ms: int,
  cap_ms: int,
  attempt: int
) -> Result[string, AIError] ! {AI, Clock} {
  let att_stream_id = stream_attempt_id(stream_id, attempt);
  let r = callStreamResult(input, step, att_stream_id, model);
  if r.ok then Ok(r.output)
  else {
    let e = {
      message: r.error_message,
      provider: r.provider,
      statusCode: r.status_code,
      retryable: r.retryable,
      code: r.error_code
    };
    let got_delta = _list_length(r.chunks) > 0;
    if e.retryable && attempt < max_retries && not got_delta then {
        let wait = retry_wait_ms(base_ms, cap_ms, attempt);
        let _ = sleep(wait);
        ai_stream_call_with_retry(input, step, stream_id, model, max_retries, base_ms, cap_ms, attempt + 1)
      } else {
        Err(e)
      }
  }
}

func rpc_loop(
  state: AgentState,
  model: string,
  depth: int,
  step_delay: int,
  hybrid_enabled: bool,
  ext_runtime: ExtRuntime,
  budget: BudgetPlan,
  settings: RunSettings
) -> AgentState ! {Net, AI, SharedMem, IO, Clock, FS, Process, Env, Stream} {
  if depth == 0 then {
    let _ = emit(encode(jo([
      kv("type", js("error")),
      kv("message", js("step limit reached"))
    ])));
    state
  } else {
    let drained = drain_cmds(state, model);
    if drained.aborted then {
      let _ = emit(encode(jo([
        kv("type", js("error")),
        kv("message", js("aborted"))
      ])));
      drained.state
    } else {
      let model2 = drained.model;
      let state2 = drained.state;
      let _ = emit_context_usage(state2, model2);

      let _ = if step_delay > 0 then sleep(step_delay) else ();
      let retry_cfg = retry_from_settings(settings);
      let stream_id = "step-${show(state2.step)}";
      match ai_stream_call_with_retry(fmt_msgs(state2.msgs), state2.step, stream_id, model2, retry_cfg.max_retries, retry_cfg.base_ms, retry_cfg.cap_ms, 0) {
        Err(e) => {
          let _ = emit(encode(jo([
            kv("type", js("error")),
            kv("message", js(e.message))
          ])));
          state2
        },
        Ok(response) => {
          let think_split = split_think_answer(response);
          let history_content = assistant_history_content(response);
          let msgs1 = state2.msgs ++ [{ role: "assistant", content: history_content }];
          let _ = emit(encode(jo([
            kv("type",   js("thinking")),
            kv("step",   jnum(_int_to_float(state2.step))),
            kv("text",   js(response)),
            kv("think",  js(think_split.think)),
            kv("answer", js(think_split.answer))
          ])));

          if hybrid_enabled
          then run_hybrid_step(state2, model2, response, msgs1, depth, step_delay, hybrid_enabled, ext_runtime, budget, settings)
          else run_legacy_step(state2, model2, response, msgs1, depth, step_delay, hybrid_enabled, ext_runtime, budget, settings)
        }
      }
    }
  }
}

func conversation_loop(
  state: AgentState,
  model: string,
  step_delay: int,
  hybrid_enabled: bool,
  ext_runtime: ExtRuntime,
  settings: RunSettings
) -> () ! {Net, AI, SharedMem, IO, Env, Clock, FS, Process, Stream} {
  let raw = readLine();
  if raw == "" then ()
  else
    match decode(raw) {
      Err(_) => conversation_loop(queue_inbox(state, raw), model, step_delay, hybrid_enabled, ext_runtime, settings),
      Ok(obj) => {
        let cmd_type = get_str(obj, "type");
        if cmd_type == "abort" || cmd_type == "exit" then ()
        else if cmd_type == "model_change" then {
          let new_model = get_str(obj, "model");
          let _ = persist_current_model(new_model);
          conversation_loop(state, new_model, step_delay, hybrid_enabled, ext_runtime, settings)
        } else if cmd_type == "user_message" then {
          let content = get_str(obj, "content");
          let msgs1 = state.msgs ++ [{ role: "user", content: content }];
          let next_state = {
            env_url: state.env_url,
            msgs: msgs1,
            cwd: state.cwd,
            step: state.step + 1,
            inbox: state.inbox
          };
          let ailang_built = settings.ailang_built;
          let bv = version();
          let _ = emit(encode(jo([
            kv("type", js("session_start")),
            kv("task", js(content)),
            kv("model", js(model)),
            kv("brainVersion", js(bv)),
            kv("ailangBuilt", js(ailang_built)),
            kv("loaded_extensions", ja(json_string_values(loaded_extension_names(ext_runtime))))
          ])));
          let budget = compute_budget_plan(ext_runtime, content, model, state.cwd, hybrid_enabled, next_state.step, settings);
          let final_state = rpc_loop(next_state, model, budget.total, step_delay, hybrid_enabled, ext_runtime, budget, settings);
          conversation_loop(final_state, model, step_delay, hybrid_enabled, ext_runtime, settings)
        } else {
          conversation_loop(queue_inbox(state, raw), model, step_delay, hybrid_enabled, ext_runtime, settings)
        }
      }
    }
}

export func run_with_config(cfg: RuntimeConfig, inv: InvocationConfig) -> () ! {Net, AI, SharedMem, IO, Env, FS, Clock, Process, Stream} {
  let env_url = cfg.backend.url;
  let task = inv.task;
  let model = if inv.model_override != "" then inv.model_override else cfg.agent.model;
  let hybrid_enabled = cfg.tools.hybrid;
  let ext_runtime = init_runtime_with_config(cfg);
  let ailang_built = inv.ailang_built;
  let cwd = if inv.workdir_override != "" then inv.workdir_override else cfg.agent.workdir;
  let settings = {
    task: task,
    ailang_built: ailang_built,
    snippet_caps: join_csv(cfg.tools.snippet_caps),
    workdir: cwd,
    ohmy_pi: cfg.tools.ohmy_pi,
    delegated_timeout_ms: cfg.tools.delegated_timeout_ms,
    delegated_poll_ms: cfg.tools.delegated_poll_ms,
    delegated_timeout_slack_ms: cfg.tools.delegated_timeout_slack_ms,
    max_retries: cfg.agent.max_retries,
    retry_base_ms: cfg.agent.retry_base_ms,
    retry_cap_ms: cfg.agent.retry_cap_ms,
    max_steps: cfg.agent.max_steps,
    verifier_mode: cfg.agent.semi_formal_verifier_mode
  };
  let bv = version();
  let _ = emit(encode(jo([
    kv("type", js("session_start")),
    kv("task", js(task)),
    kv("model", js(model)),
    kv("brainVersion", js(bv)),
    kv("ailangBuilt", js(ailang_built)),
    kv("config_profile", js(cfg.profile)),
    kv("config_dir", js(cfg.profile_dir)),
    kv("backend_mode", js(cfg.backend.mode)),
    kv("loaded_extensions", ja(json_string_values(loaded_extension_names(ext_runtime))))
  ])));

  let step_delay = cfg.agent.step_delay_ms;

  let hint = get_hint(task);
  let system_md_path = cfg.agent.system_prompt;
  let raw_system =
    if system_md_path == "" then ""
    else if fileExists(system_md_path)
    then readFile(system_md_path)
    else {
      let _ = emit(encode(jo([
        kv("type", js("warning")),
        kv("message", js("system prompt file not found at '${system_md_path}'; running without a system prompt."))])));
      ""
    };
  let budget = compute_budget_plan(ext_runtime, task, model, cwd, hybrid_enabled, 0, settings);
  let remaining = budget.total;
  let system_with_agents = with_agents_context(raw_system, cwd);
  let system_with_hint = with_cache_hint(system_with_agents, hint);
  let system_ctx = {
    task: task,
    step: 0,
    model: model,
    cwd: cwd,
    hybrid_tools: hybrid_enabled,
    budget: budget,
    mode: "default",
    workdir: cwd,
    env_server_url: env_url,
    budget_remaining: remaining,
    history_slice: [],
    state_key: "core:ext:system"
  };
  let system = dispatch_build_system_prompt(ext_runtime, system_ctx, system_with_hint);

  let init = [
    { role: "system", content: system },
    { role: "user", content: task }
  ];
  let state = {
    env_url: env_url,
    msgs: init,
    cwd: cwd,
    step: 0,
    inbox: []
  };

  -- M10 cutover (2026-05-06): v2 is now the DEFAULT and ONLY agent loop.
  -- Uses upstream std/ai.step() with TYPED tool_calls (provider-native
  -- protocols: Anthropic tool_use, OpenAI tool_calls, Gemini functionCall),
  -- replacing the legacy text-based parse_tool_calls heuristic.
  --
  -- All 6 rpc_loop decision points are migrated and validated by the M9
  -- 25/25 provider matrix (Claude / Gemini / GPT-5 / GLM / MiniMax × 5
  -- task variants). See M-MOTOKO-RPC-LOOP-FULL-MIGRATION sprint plan and
  -- AILANG design_docs/implemented/v0_17_0/m-agent-loop-architecture.md.
  --
  -- The MOTOKO_AGENT_V2 env var is no longer consulted. Setting it has no
  -- effect; the legacy rpc_loop and conversation_loop functions remain in
  -- this file as unreachable code pending a follow-up cleanup commit
  -- (sized separately to keep this cutover diff reviewable).
  let _ = println(encode(jo([
    kv("type", js("v2_mode")),
    kv("note", js("running with upstream std/ai.step (typed tool_calls); legacy rpc_loop deleted at M10"))
  ])));
  let _ = state;  -- legacy AgentState construction kept for now; unused post-M10
  run_v2_with_conversation(ext_runtime, task, env_url, hybrid_enabled, budget, model, init, settings.workdir, budget.total, settings.ohmy_pi)
}

export func main() -> () ! {Net, AI, SharedMem, IO, Env, FS, Clock, Process, Stream} {
  let cfg = load_runtime_config();
  let inv = load_invocation_config();
  run_with_config(cfg, inv)
}
