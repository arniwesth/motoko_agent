-- src/core/tool_catalog.ail
-- ToolSchema definitions for motoko_agent's 6 native tools, in the
-- shape upstream `std/ai.runTools` expects (M-AI-TOOL-LOOP, target
-- AILANG v0.17.0):
--
--   ToolSchema = { name: string, description: string, parameters: string }
--
-- `parameters` is a JSON Schema string — same shape as the existing
-- non-streaming AI providers' tool definitions. The model uses these to
-- decide which tool to call and with what arguments; runTools wraps each
-- emitted ToolCall and forwards it to the dispatch callback (provided by
-- src/core/tool_dispatch_adapter).
--
-- These schemas mirror the fork's existing tool argument shapes (look at
-- src/core/tool_runtime.ail's `arg_string`/`arg_number`/`arg_bool` calls
-- per-tool to see the field names). Keeping them aligned means the
-- adapter's argument-decoding layer doesn't need a translation step.

module src/core/tool_catalog

import std/ai (ToolSchema)
import std/list as List (length)
import src/core/config (VerificationConfig)
import pkg/sunholo/motoko_ext_abi/types (ExtRuntime, ExtensionHooks)

-- Each schema's `parameters` field is a JSON-Schema-shaped string. To keep
-- the strings readable AILANG-side, we build them in helper functions
-- rather than inline. Strings carry no escape problems at this size, but
-- if a schema grows past ~30 lines, factor it into its own pure func.

pure func read_file_schema() -> ToolSchema = {
  name: "ReadFile",
  description: "Read a file from the workdir. Use start/end to read a line range; default reads up to 200 lines.",
  parameters: "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\",\"description\":\"Relative path within the workdir.\"},\"start\":{\"type\":\"integer\",\"description\":\"1-indexed first line (default 1)\"},\"end\":{\"type\":\"integer\",\"description\":\"1-indexed last line (default 200)\"}},\"required\":[\"path\"]}"
}

pure func write_file_schema() -> ToolSchema = {
  name: "WriteFile",
  description: "Write the given content to a file in the workdir. Creates parent directories if needed.",
  parameters: "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"}},\"required\":[\"path\",\"content\"]}"
}

pure func edit_file_schema() -> ToolSchema = {
  name: "EditFile",
  description: "Apply a sequence of substring edits to a file. Supports dry-run mode and SHA-256 guard for optimistic concurrency.",
  parameters: "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"},\"edits\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"old\":{\"type\":\"string\"},\"new\":{\"type\":\"string\"}},\"required\":[\"old\",\"new\"]}},\"dry_run\":{\"type\":\"boolean\"},\"expected_sha256\":{\"type\":\"string\"}},\"required\":[\"path\",\"edits\"]}"
}

pure func bash_exec_schema() -> ToolSchema = {
  name: "BashExec",
  description: "Run a shell command in the workdir with capability gating. Output is captured to stdout/stderr with truncation past a configured byte cap.",
  parameters: "{\"type\":\"object\",\"properties\":{\"cmd\":{\"type\":\"string\"},\"args\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"timeout_secs\":{\"type\":\"integer\"}},\"required\":[\"cmd\"]}"
}

pure func run_tests_schema() -> ToolSchema = {
  name: "RunTests",
  description: "Run the project's test suite (e.g. make test, pytest). Returns exit code, stdout, stderr.",
  parameters: "{\"type\":\"object\",\"properties\":{\"cmd\":{\"type\":\"string\",\"description\":\"Test command, defaults to 'make test'\"},\"args\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}}},\"required\":[]}"
}

pure func search_schema() -> ToolSchema = {
  name: "Search",
  description: "Search files in the workdir for a regex pattern. Returns line-level matches with file path + line number.",
  parameters: "{\"type\":\"object\",\"properties\":{\"pattern\":{\"type\":\"string\"},\"dir\":{\"type\":\"string\",\"description\":\"Subdirectory to scope the search (default '.')\"}},\"required\":[\"pattern\"]}"
}

-- The full tool catalog motoko_agent advertises to the model. Pass this
-- to upstream `runTools(model, msgs, tools(), dispatch, budget)`.
pure func edit_decl_schema() -> ToolSchema = {
  name: "EditDecl",
  description: "Replace ONE top-level declaration (function/type) by name via its parsed AST span; the rest of the file is preserved byte-for-byte. Prefer this for whole-decl rewrites in a large file (far cheaper than re-emitting the file with WriteFile). Use EditFile for small intra-decl substring edits; WriteFile for new files.",
  parameters: "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"},\"decl\":{\"type\":\"string\",\"description\":\"Top-level declaration name to replace\"},\"new_body\":{\"type\":\"string\",\"description\":\"Full new source text for the declaration\"}},\"required\":[\"path\",\"decl\",\"new_body\"]}"
}

export pure func tools() -> [ToolSchema] {
  [
    read_file_schema(),
    write_file_schema(),
    edit_file_schema(),
    bash_exec_schema(),
    run_tests_schema(),
    search_schema(),
    edit_decl_schema()
  ]
}

-- Minimal ToolSchema for an extension-provided tool. Extensions supply only
-- a name string; we synthesise a description and an empty JSON Schema so the
-- model can emit the call and the dispatcher can route it.
pure func ext_tool_schema(name: string) -> ToolSchema {
  {
    name: name,
    description: "Extension tool: ${name}",
    parameters: "{\"type\":\"object\",\"properties\":{},\"required\":[]}"
  }
}

pure func collect_hook_schemas(names: [string]) -> [ToolSchema] {
  match names {
    [] => [],
    n :: rest => ext_tool_schema(n) :: collect_hook_schemas(rest)
  }
}

-- Prefer hook-declared schemas when available; fall back to name-only synthesis.
pure func hook_schemas(h: ExtensionHooks) -> [ToolSchema] {
  let declared = h.on_describe_tools();
  match declared {
    [] => collect_hook_schemas(h.provided_tools),
    _ => declared
  }
}

pure func collect_ext_schemas(hooks: [ExtensionHooks]) -> [ToolSchema] {
  match hooks {
    [] => [],
    h :: rest => hook_schemas(h) ++ collect_ext_schemas(rest)
  }
}

-- Full tool catalog including any tools registered by active extensions.
-- Use this instead of `tools()` when an ExtRuntime is available so that
-- extension-provided tools appear in the LLM's tool list.
export pure func tools_with_extensions(rt: ExtRuntime) -> [ToolSchema] {
  tools() ++ collect_ext_schemas(rt.registry.hooks)
}

-- Inline tests

pure func test_base_tools_count() -> bool
  tests [((), true)]
  { List.length(tools()) == 6 }

pure func test_no_extensions_returns_base_tools() -> bool
  tests [((), true)]
  {
    let v: VerificationConfig = { enabled: false, command: "make check_core" };
    let rt: ExtRuntime = { registry: { hooks: [] }, strict_mode: false, verification: v };
    List.length(tools_with_extensions(rt)) == 6
  }

pure func test_ext_schema_synthesised_name() -> bool
  tests [((), true)]
  {
    let s = ext_tool_schema("MyTool");
    s.name == "MyTool"
  }
