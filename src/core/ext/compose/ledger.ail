module src/core/ext/compose/ledger

import std/string (trim, contains, find, substring)

export type LedgerEntry = {
  tool: string,
  path: string,
  args_hash: string,
  content_excerpt: string,
  ts: int,
  truncated: bool,
  bytes: int
}

export type PremiseLedger = {
  entries: [LedgerEntry],
  budget_used: int,
  budget_cap: int
}

export type PremiseBinding = {
  ledger_bound: int,
  snippet_bound: int,
  unbound: int,
  malformed: int
}

export func init_ledger(cap: int) -> PremiseLedger {
  { entries: [], budget_used: 0, budget_cap: cap }
}

export func with_budget_cap(ledger: PremiseLedger, cap: int) -> PremiseLedger {
  { entries: ledger.entries, budget_used: ledger.budget_used, budget_cap: cap }
}

export func remaining_budget(ledger: PremiseLedger) -> int {
  let rem = ledger.budget_cap - ledger.budget_used;
  if rem < 0 then 0 else rem
}

export func consume_budget(ledger: PremiseLedger) -> PremiseLedger {
  { entries: ledger.entries, budget_used: ledger.budget_used + 1, budget_cap: ledger.budget_cap }
}

export func append_entry(ledger: PremiseLedger, entry: LedgerEntry) -> PremiseLedger {
  { entries: ledger.entries ++ [entry], budget_used: ledger.budget_used, budget_cap: ledger.budget_cap }
}

func replace_all(text: string, old: string, repl: string) -> string {
  replace_all_rec(text, old, repl, 0, "")
}

func replace_all_rec(text: string, old: string, repl: string, pos: int, acc: string) -> string {
  if old == "" then text
  else {
    let idx = find(substring(text, pos, _str_len(text)), old);
    if idx < 0 then "${acc}${substring(text, pos, _str_len(text))}"
    else {
      let at = pos + idx;
      let next_pos = at + _str_len(old);
      replace_all_rec(text, old, repl, next_pos, "${acc}${substring(text, pos, at)}${repl}")
    }
  }
}

func collapse_spaces(s: string) -> string {
  let t = replace_all(replace_all(replace_all(trim(s), "\n", " "), "\t", " "), "\r", " ");
  collapse_spaces_rec(t)
}

func collapse_spaces_rec(s: string) -> string {
  if contains(s, "  ") then collapse_spaces_rec(replace_all(s, "  ", " ")) else s
}

export func quote_seen_for_path(ledger: PremiseLedger, path: string, quote: string) -> bool {
  quote_seen_for_path_rec(ledger.entries, trim(path), collapse_spaces(quote))
}

func quote_seen_for_path_rec(entries: [LedgerEntry], path: string, quote_norm: string) -> bool {
  if quote_norm == "" then false
  else match entries {
    [] => false,
    e :: rest => {
      if trim(e.path) == path && contains(collapse_spaces(e.content_excerpt), quote_norm) then true
      else quote_seen_for_path_rec(rest, path, quote_norm)
    }
  }
}

func summary_lines_rec(entries: [LedgerEntry]) -> [string] {
  match entries {
    [] => [],
    e :: rest => {
      let line = "- ${e.tool} ${e.path} bytes=${show(e.bytes)}${if e.truncated then " truncated" else ""}";
      line :: summary_lines_rec(rest)
    }
  }
}

func join_lines(xs: [string]) -> string {
  match xs {
    [] => "",
    x :: [] => x,
    x :: rest => "${x}\n${join_lines(rest)}"
  }
}

export func prior_reads_summary(ledger: PremiseLedger) -> string {
  if _list_length(ledger.entries) == 0 then ""
  else "Prior reads summary (from earlier attempts in this compose invocation):\n${join_lines(summary_lines_rec(ledger.entries))}"
}

func claimcheck_entries_rec(entries: [LedgerEntry], n: int) -> [string] {
  if n <= 0 then []
  else match entries {
    [] => [],
    e :: rest => {
      let ex = if _str_len(e.content_excerpt) <= 240 then e.content_excerpt else "${substring(e.content_excerpt, 0, 240)}...[truncated]";
      ("${e.tool} | ${e.path} | ${ex}") :: claimcheck_entries_rec(rest, n - 1)
    }
  }
}

export func claimcheck_ledger_summary(ledger: PremiseLedger) -> string {
  if _list_length(ledger.entries) == 0 then ""
  else join_lines(claimcheck_entries_rec(ledger.entries, 12))
}
