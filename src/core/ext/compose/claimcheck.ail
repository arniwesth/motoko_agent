module src/core/ext/compose/claimcheck

import std/ai/streaming (callStream)
import std/io (println)
import std/json (decode, get, asString, jo, ja, kv, js, jb, jnum, encode)
import std/result (Ok, Err)
import std/string (trim, split, startsWith)

func emit_line(line: string) -> () ! {IO} {
  let _ = println(line);
  ()
}

func emit_event(event_type: string, step: int, compose_id: string, attempt: int, kvs: [string]) -> () ! {IO} {
  let base = "{\"type\":\"${event_type}\",\"step\":${show(step)},\"compose_id\":\"${compose_id}\",\"attempt\":${show(attempt)}";
  emit_event_tail(base, kvs)
}

func emit_event_tail(base: string, kvs: [string]) -> () ! {IO} {
  match kvs {
    [] => {
      let _ = emit_line("${base}}");
      ()
    },
    x :: rest => emit_event_tail("${base},${x}", rest)
  }
}

func json_escape(s: string) -> string {
  encode(js(s))
}

func build_single_message(prompt: string) -> string {
  encode(ja([jo([kv("role", js("user")), kv("content", js(prompt))])]))
}

func join_provider_model(parts: [string]) -> string {
  match parts {
    [] => "",
    x :: [] => x,
    x :: rest => "${x}/${join_provider_model(rest)}"
  }
}

func split_provider_model(model_str: string) -> { provider: string, model: string } {
  match split(model_str, "/") {
    [] => { provider: "openai", model: model_str },
    provider :: [] => { provider: "openai", model: provider },
    provider :: rest => { provider: provider, model: join_provider_model(rest) }
  }
}

func call_single_prompt(prompt: string, model: string) -> string ! {AI, Net, Stream} {
  let route = split_provider_model(model);
  match callStream(route.provider, route.model, build_single_message(prompt)) {
    Ok(text) => text,
    Err(_) => ""
  }
}

func informalizer_prompt(observed: string, ledger_summary: string, include_ledger: bool) -> string {
  "Read the observed program output below.\nIn <=40 words, summarize what it actually demonstrates.\nIf a structured certificate (PREMISES/TRACE/CONCLUSION) exists, prioritize that.\nOtherwise summarize concrete observed content only. Do not speculate.\n\n${if include_ledger && trim(ledger_summary) != "" then "Author ledger summary:\n${ledger_summary}\n\n" else ""}Observed output:\n${observed}"
}

func comparator_prompt(intent: string, informalization: string) -> string {
  "Original request: ${intent}\nObserved summary:  ${informalization}\n\nDoes the observed summary describe the same conclusion the request was asking for?\nRespond with JSON:\n{\n  \"verdict\": \"confirmed\" | \"disputed\" | \"vacuous\" | \"surprising_restriction\" | \"inconclusive\",\n  \"confidence\": \"high\" | \"low\",\n  \"reason\": \"<one sentence>\"\n}"
}

func comparator_repair_prompt(raw: string) -> string {
  "Repair this output into strict JSON with keys verdict, confidence, reason.\nOutput JSON only.\n\nRaw output:\n${raw}"
}

func is_runtime_boilerplate_line(line: string) -> bool {
  let t = trim(line);
  t == "" ||
  startsWith(t, "→ Type checking") ||
  startsWith(t, "→ Effect checking") ||
  startsWith(t, "✓ Running ")
}

func drop_runtime_boilerplate(lines: [string]) -> [string] {
  match lines {
    [] => [],
    x :: rest =>
      if is_runtime_boilerplate_line(x) then drop_runtime_boilerplate(rest)
      else x :: drop_runtime_boilerplate(rest)
  }
}

func join_lines(lines: [string]) -> string {
  match lines {
    [] => "",
    x :: [] => x,
    x :: rest => "${x}\n${join_lines(rest)}"
  }
}

export func normalized_observed_output(raw: string) -> string {
  join_lines(drop_runtime_boilerplate(split(raw, "\n")))
}

func parse_verdict(raw: string) -> { ok: bool, verdict: string, confidence: string, reason: string } {
  let t = trim(raw);
  if t == "" then { ok: false, verdict: "inconclusive", confidence: "low", reason: "empty comparator output" }
  else {
    match decode(t) {
      Err(_) => {
        let i = _str_find(t, "{");
        let j = _str_find(t, "}");
        if i >= 0 && j > i then parse_verdict(_str_slice(t, i, j + 1))
        else { ok: false, verdict: "inconclusive", confidence: "low", reason: "comparator malformed JSON" }
      },
      Ok(obj) => {
        let verdict = match get(obj, "verdict") { Some(vj) => match asString(vj) { Some(v) => v, None => "" }, None => "" };
        let confidence = match get(obj, "confidence") { Some(cj) => match asString(cj) { Some(v) => v, None => "" }, None => "" };
        let reason0 = match get(obj, "reason") { Some(rj) => match asString(rj) { Some(v) => v, None => "" }, None => "" };
        let reason = if trim(reason0) == "" then "no reason provided" else trim(reason0);
        let valid_verdict = verdict == "confirmed" || verdict == "disputed" || verdict == "vacuous" || verdict == "surprising_restriction" || verdict == "inconclusive";
        let valid_conf = confidence == "high" || confidence == "low";
        if valid_verdict && valid_conf then { ok: true, verdict: verdict, confidence: confidence, reason: reason }
        else { ok: false, verdict: "inconclusive", confidence: "low", reason: "comparator malformed JSON" }
      }
    }
  }
}

export func run_claimcheck(
  enabled: bool,
  intent_kind: string,
  intent: string,
  certificate_stdout: string,
  ledger_summary: string,
  include_ledger_in_informalizer: bool,
  informalizer_model: string,
  comparator_model: string,
  timeout_ms: int,
  max_invocations: int,
  invocations_used: int,
  step: int,
  compose_id: string,
  attempt: int
) -> { ran: bool, should_retry: bool, verdict: string, confidence: string, reason: string, corrective_hint: string, invocations_used: int } ! {AI, IO, Net, Stream} {
  if not enabled || intent_kind != "analyze" then {
    { ran: false, should_retry: false, verdict: "inconclusive", confidence: "low", reason: "claimcheck disabled or non-analysis intent", corrective_hint: "", invocations_used: invocations_used }
  } else if invocations_used >= max_invocations then {
    { ran: false, should_retry: false, verdict: "inconclusive", confidence: "low", reason: "sf5 budget exhausted", corrective_hint: "", invocations_used: invocations_used }
  } else {
    let _ = timeout_ms;
    let observed = trim(normalized_observed_output(certificate_stdout));
    if observed == "" then {
      {
        ran: true,
        should_retry: true,
        verdict: "vacuous",
        confidence: "high",
        reason: "no substantive output after runtime boilerplate",
        corrective_hint:
          "The previous run produced no substantive stdout.\nEmit a concise evidence-backed analysis result (not just execution logs).\nFor analyze intents, print a short structured certificate with PREMISES, TRACE, and CONCLUSION.",
        invocations_used: invocations_used + 1
      }
    } else {
    let inv_next = invocations_used + 1;
    let inf = call_single_prompt(informalizer_prompt(observed, ledger_summary, include_ledger_in_informalizer), informalizer_model);
    let _ = emit_event("compose_claimcheck_informalize_delta", step, compose_id, attempt, ["\"delta\":${json_escape(inf)}"]);
    let informalization = trim(inf);
    let _ = emit_event("compose_claimcheck_informalize_result", step, compose_id, attempt, ["\"informalization\":${json_escape(informalization)}"]);
    if informalization == "" then {
      { ran: true, should_retry: false, verdict: "inconclusive", confidence: "low", reason: "informalizer empty output", corrective_hint: "", invocations_used: inv_next }
    } else {
      let cmp = call_single_prompt(comparator_prompt(intent, informalization), comparator_model);
      let _ = emit_event("compose_claimcheck_compare_delta", step, compose_id, attempt, ["\"delta\":${json_escape(cmp)}"]);
      let parsed0 = parse_verdict(cmp);
      let parsed = if parsed0.ok then parsed0 else {
        let repaired = call_single_prompt(comparator_repair_prompt(cmp), comparator_model);
        parse_verdict(repaired)
      };
      let _ = emit_event(
        "compose_claimcheck_compare_result",
        step,
        compose_id,
        attempt,
        [
          "\"verdict\":${json_escape(parsed.verdict)}",
          "\"confidence\":${json_escape(parsed.confidence)}",
          "\"reason\":${json_escape(parsed.reason)}",
          "\"informalization\":${json_escape(informalization)}"
        ]
      );
      let force_retry = parsed.confidence == "high" && (parsed.verdict == "disputed" || parsed.verdict == "vacuous" || parsed.verdict == "surprising_restriction");
      let hint = if force_retry then
        "ClaimCheck flagged the previous certificate as off-target.\nObserved summary from certificate: ${informalization}\nRevise premises/trace/conclusion so the conclusion directly answers the original intent."
      else "";
      {
        ran: true,
        should_retry: force_retry,
        verdict: parsed.verdict,
        confidence: parsed.confidence,
        reason: parsed.reason,
        corrective_hint: hint,
        invocations_used: inv_next
      }
    }
    }
  }
}
