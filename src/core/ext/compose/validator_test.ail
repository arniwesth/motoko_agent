module src/core/ext/compose/validator_test

import src/core/ext/compose/validator (validate_expected_output_with_context)
import src/core/ext/compose/ledger (init_ledger)

func expected_certificate_spec() -> string {
  "{\"kind\":\"certificate\",\"min_premises\":2,\"require_trace\":true,\"require_conclusion\":true}"
}

func snippet_with_fs() -> string {
  "export func main() -> () ! {IO, FS} { println(\"ok\") }"
}

func t_certificate_accepts_legacy_arrow_premises() -> bool
  tests [((), true)]
  {
    let out =
      "PREMISES\n" ++
      "  src/core/rpc.ail -> rpc loop exists\n" ++
      "  src/core/env_client.ail -> exec_ailang exists\n" ++
      "TRACE\n" ++
      "  premises support architecture flow\n" ++
      "CONCLUSION\n" ++
      "  flow validated";
    let r = validate_expected_output_with_context(expected_certificate_spec(), out, snippet_with_fs(), init_ledger(10));
    r.validation.decided && r.validation.satisfied
  }

func t_certificate_accepts_mixed_premise_styles() -> bool
  tests [((), true)]
  {
    let out =
      "PREMISES\n" ++
      "  src/core/rpc.ail | \"rpc_loop\" | loop exists\n" ++
      "  src/core/env_client.ail -> exec_ailang exists\n" ++
      "TRACE\n" ++
      "  mixed premises still support conclusion\n" ++
      "CONCLUSION\n" ++
      "  mixed parsing validated";
    let r = validate_expected_output_with_context(expected_certificate_spec(), out, snippet_with_fs(), init_ledger(10));
    r.validation.decided && r.validation.satisfied
  }

func t_certificate_still_rejects_bad_premise_lines() -> bool
  tests [((), true)]
  {
    let out =
      "PREMISES\n" ++
      "  src/core/rpc.ail : malformed\n" ++
      "TRACE\n" ++
      "  bad premise\n" ++
      "CONCLUSION\n" ++
      "  should fail";
    let r = validate_expected_output_with_context(expected_certificate_spec(), out, snippet_with_fs(), init_ledger(10));
    r.validation.decided && not r.validation.satisfied
  }
