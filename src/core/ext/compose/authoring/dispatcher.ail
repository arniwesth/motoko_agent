module src/core/ext/compose/authoring/dispatcher

import std/bytes (toString)
import std/clock (now)
import std/crypto (sha256Hex)
import std/fs (writeFile, mkdirAll, removeFile)
import std/json (Json, decode, get, asString, asBool, asArray, encode, jo, kv, js, jb)
import std/process (exec)
import std/string (trim, find, substring)

import src/core/ext/compose/authoring/state (ProgramState, FuncDecl, init_program_state, set_module_path, add_import_decl, upsert_func, add_type_alias_line, add_type_def_line)
import src/core/ext/compose/authoring/render (render_program)

export type AuthoringToolResult = {
  ok: bool,
  tool: string,
  error_class: string,
  detail: string,
  suggestion: string,
  payload_json: string,
  state: ProgramState,
  finalized: bool,
  finalize_ok: bool,
  snippet: string,
  check_errors: string
}

func mk_err(st: ProgramState, tool: string, error_class: string, detail: string, suggestion: string, did_you_mean: [string]) -> AuthoringToolResult {
  {
    ok: false,
    tool: tool,
    error_class: error_class,
    detail: detail,
    suggestion: suggestion,
    payload_json: encode(jo([
      kv("tool", js(tool)),
      kv("ok", jb(false)),
      kv("error_class", js(error_class)),
      kv("detail", js(detail)),
      kv("suggestion", js(suggestion)),
      kv("did_you_mean", js(show(did_you_mean)))
    ])),
    state: st,
    finalized: false,
    finalize_ok: false,
    snippet: "",
    check_errors: ""
  }
}

func mk_ok(st: ProgramState, tool: string, result_json: Json) -> AuthoringToolResult {
  {
    ok: true,
    tool: tool,
    error_class: "",
    detail: "",
    suggestion: "",
    payload_json: encode(jo([
      kv("tool", js(tool)),
      kv("ok", jb(true)),
      kv("result", result_json)
    ])),
    state: st,
    finalized: false,
    finalize_ok: false,
    snippet: "",
    check_errors: ""
  }
}

func json_string_field(obj: Json, key: string, fallback: string) -> string {
  match get(obj, key) {
    None => fallback,
    Some(v) => match asString(v) {
      Some(s) => s,
      None => fallback
    }
  }
}

func json_bool_field(obj: Json, key: string, fallback: bool) -> bool {
  match get(obj, key) {
    None => fallback,
    Some(v) => match asBool(v) {
      Some(b) => b,
      None => fallback
    }
  }
}

func json_string_list(value: Json) -> [string] {
  match asArray(value) {
    None => [],
    Some(xs) => json_string_list_rec(xs)
  }
}

func json_string_list_rec(xs: [Json]) -> [string] {
  match xs {
    [] => [],
    x :: rest => {
      match asString(x) {
        Some(s) => trim(s) :: json_string_list_rec(rest),
        None => json_string_list_rec(rest)
      }
    }
  }
}

func required_non_empty(value: string, field_name: string) -> { ok: bool, msg: string } {
  if trim(value) == "" then { ok: false, msg: "missing_${field_name}" }
  else { ok: true, msg: "" }
}

func join_with(xs: [string], sep: string) -> string {
  match xs {
    [] => "",
    x :: [] => x,
    x :: rest => "${x}${sep}${join_with(rest, sep)}"
  }
}

func parse_effects(args: Json) -> [string] {
  match get(args, "effects") {
    None => [],
    Some(v) => json_string_list(v)
  }
}

func replace_all(text: string, old: string, repl: string) -> string {
  replace_all_rec(text, old, repl, 0, "")
}

func replace_all_rec(text: string, old: string, repl: string, pos: int, acc: string) -> string {
  if old == "" then text
  else {
    let idx = find(substring(text, pos, _str_len(text)), old);
    if idx < 0 then "${acc}${substring(text, pos, _str_len(text))}"
    else {
      let at = pos + idx;
      let next_pos = at + _str_len(old);
      replace_all_rec(text, old, repl, next_pos, "${acc}${substring(text, pos, at)}${repl}")
    }
  }
}

func update_func_body_rec(funcs: [FuncDecl], name: string, new_body: string, found: bool) -> { funcs: [FuncDecl], found: bool } {
  match funcs {
    [] => { funcs: [], found: found },
    f :: rest => {
      if trim(f.name) == trim(name) then {
        let next = { name: f.name, params_sig: f.params_sig, return_type: f.return_type, effects: f.effects, body: new_body, is_pure: f.is_pure, is_export: f.is_export };
        let tail = update_func_body_rec(rest, name, new_body, true);
        { funcs: next :: tail.funcs, found: true }
      } else {
        let tail = update_func_body_rec(rest, name, new_body, found);
        { funcs: f :: tail.funcs, found: tail.found }
      }
    }
  }
}

func update_func_effect_rec(funcs: [FuncDecl], name: string, effect: string, add: bool, found: bool) -> { funcs: [FuncDecl], found: bool } {
  match funcs {
    [] => { funcs: [], found: found },
    f :: rest => {
      if trim(f.name) == trim(name) then {
        let has = list_contains_trim(f.effects, effect);
        let next_effects = if add then (if has then f.effects else f.effects ++ [trim(effect)]) else remove_effect_trim(f.effects, effect);
        let next = { name: f.name, params_sig: f.params_sig, return_type: f.return_type, effects: next_effects, body: f.body, is_pure: f.is_pure, is_export: f.is_export };
        let tail = update_func_effect_rec(rest, name, effect, add, true);
        { funcs: next :: tail.funcs, found: true }
      } else {
        let tail = update_func_effect_rec(rest, name, effect, add, found);
        { funcs: f :: tail.funcs, found: tail.found }
      }
    }
  }
}

func list_contains_trim(xs: [string], target: string) -> bool {
  match xs {
    [] => false,
    x :: rest => if trim(x) == trim(target) then true else list_contains_trim(rest, target)
  }
}

func remove_effect_trim(xs: [string], target: string) -> [string] {
  match xs {
    [] => [],
    x :: rest => if trim(x) == trim(target) then remove_effect_trim(rest, target) else x :: remove_effect_trim(rest, target)
  }
}

func rename_var_in_funcs_rec(funcs: [FuncDecl], name: string, from: string, to: string) -> [FuncDecl] {
  match funcs {
    [] => [],
    f :: rest => {
      if trim(f.name) == trim(name) then {
        let next = {
          name: f.name,
          params_sig: f.params_sig,
          return_type: f.return_type,
          effects: f.effects,
          body: replace_all(f.body, from, to),
          is_pure: f.is_pure,
          is_export: f.is_export
        };
        next :: rename_var_in_funcs_rec(rest, name, from, to)
      } else f :: rename_var_in_funcs_rec(rest, name, from, to)
    }
  }
}

func check_snippet(snippet: string) -> { ok: bool, errors: string } ! {FS, Process, Clock} {
  let _ = mkdirAll(".motoko-store/tmp");
  let stamp = show(now());
  let path = ".motoko-store/tmp/compose_structured_${sha256Hex("${stamp}${snippet}")}.ail";
  let _ = writeFile(path, snippet);
  let checked =
    match exec("ailang", ["check", path]) {
      Ok(out) => {
        if out.exitCode == 0 then { ok: true, errors: "" }
        else {
          let stderr = trim(toString(out.stderr));
          let stdout = trim(toString(out.stdout));
          let msg = if stderr != "" then stderr else stdout;
          { ok: false, errors: msg }
        }
      },
      Err(e) => { ok: false, errors: show(e) }
    };
  let _ = removeFile(path);
  checked
}

func handle_set_module(st: ProgramState, args: Json) -> AuthoringToolResult {
  let path = json_string_field(args, "path", "");
  let req = required_non_empty(path, "path");
  if not req.ok then mk_err(st, "set_module", "invalid_arguments", req.msg, "provide args.path", [])
  else mk_ok(set_module_path(st, path), "set_module", jo([kv("path", js(trim(path)))]))
}

func handle_add_import(st: ProgramState, args: Json) -> AuthoringToolResult {
  let module_name = json_string_field(args, "module", "");
  let alias = json_string_field(args, "alias", "");
  let symbols = match get(args, "symbols") { Some(v) => json_string_list(v), None => [] };
  let req = required_non_empty(module_name, "module");
  if not req.ok then mk_err(st, "add_import", "invalid_arguments", req.msg, "provide args.module", [])
  else if trim(alias) != "" then mk_err(st, "add_import", "unsupported_argument", "alias not supported in MVP renderer", "set alias to empty string", [])
  else mk_ok(add_import_decl(st, module_name, symbols, alias), "add_import", jo([kv("module", js(trim(module_name))), kv("symbols", js(show(symbols)))]))
}

func handle_add_type_alias(st: ProgramState, args: Json) -> AuthoringToolResult {
  let name = trim(json_string_field(args, "name", ""));
  let definition = trim(json_string_field(args, "definition", ""));
  let req1 = required_non_empty(name, "name");
  let req2 = required_non_empty(definition, "definition");
  if not req1.ok then mk_err(st, "add_type_alias", "invalid_arguments", req1.msg, "provide args.name", [])
  else if not req2.ok then mk_err(st, "add_type_alias", "invalid_arguments", req2.msg, "provide args.definition", [])
  else {
    let line = "type ${name} = ${definition}";
    mk_ok(add_type_alias_line(st, line), "add_type_alias", jo([kv("line", js(line))]))
  }
}

func handle_define_type(st: ProgramState, args: Json) -> AuthoringToolResult {
  let name = trim(json_string_field(args, "name", ""));
  let definition = trim(json_string_field(args, "definition", ""));
  let constructors = match get(args, "constructors") { Some(v) => json_string_list(v), None => [] };
  let derives = match get(args, "derives") { Some(v) => json_string_list(v), None => [] };
  let req = required_non_empty(name, "name");
  if not req.ok then mk_err(st, "define_type", "invalid_arguments", req.msg, "provide args.name", [])
  else {
    let fallback =
      if trim(definition) != "" then definition
      else if _list_length(constructors) == 0 then "" else join_with(constructors, " | ");
    if trim(fallback) == "" then mk_err(st, "define_type", "invalid_arguments", "missing_definition", "provide args.definition or args.constructors", [])
    else {
      let line = "type ${name} = ${fallback}${if _list_length(derives) == 0 then "" else " deriving (${join_with(derives, ", ")})"}";
      mk_ok(add_type_def_line(st, line), "define_type", jo([kv("line", js(line))]))
    }
  }
}

func handle_define_func(st: ProgramState, args: Json) -> AuthoringToolResult {
  let name = trim(json_string_field(args, "name", ""));
  let params_sig = trim(json_string_field(args, "params", ""));
  let return_type = trim(json_string_field(args, "return_type", "()"));
  let body = json_string_field(args, "body", "");
  let is_pure = json_bool_field(args, "is_pure", false);
  let is_export = json_bool_field(args, "is_export", false);
  let effects = parse_effects(args);
  let req1 = required_non_empty(name, "name");
  let req2 = required_non_empty(body, "body");
  if not req1.ok then mk_err(st, "define_func", "invalid_arguments", req1.msg, "provide args.name", [])
  else if not req2.ok then mk_err(st, "define_func", "invalid_arguments", req2.msg, "provide args.body", [])
  else {
    let f: FuncDecl = {
      name: name,
      params_sig: params_sig,
      return_type: return_type,
      effects: effects,
      body: body,
      is_pure: is_pure,
      is_export: is_export
    };
    mk_ok(upsert_func(st, f), "define_func", jo([kv("name", js(name)), kv("is_export", jb(is_export)), kv("is_pure", jb(is_pure))]))
  }
}

func handle_set_main(st: ProgramState, args: Json) -> AuthoringToolResult {
  let body = json_string_field(args, "body", "");
  let effects = parse_effects(args);
  if trim(body) == "" then mk_err(st, "set_main", "invalid_arguments", "missing_body", "provide args.body", [])
  else {
    let f: FuncDecl = {
      name: "main",
      params_sig: "",
      return_type: "()",
      effects: effects,
      body: body,
      is_pure: false,
      is_export: true
    };
    mk_ok(upsert_func(st, f), "set_main", jo([kv("name", js("main")), kv("effects", js(show(effects)))]))
  }
}

func handle_replace_func_body(st: ProgramState, args: Json) -> AuthoringToolResult {
  let name = json_string_field(args, "name", "");
  let new_body = json_string_field(args, "new_body", "");
  if trim(name) == "" || trim(new_body) == "" then mk_err(st, "replace_func_body", "invalid_arguments", "missing_name_or_new_body", "provide args.name and args.new_body", [])
  else {
    let updated = update_func_body_rec(st.funcs, name, new_body, false);
    if not updated.found then mk_err(st, "replace_func_body", "unknown_symbol", "function_not_found", "check function name", [])
    else {
      let next = { module_path: st.module_path, imports: st.imports, type_aliases: st.type_aliases, type_defs: st.type_defs, funcs: updated.funcs };
      mk_ok(next, "replace_func_body", jo([kv("name", js(trim(name)))]))
    }
  }
}

func handle_add_remove_effect(st: ProgramState, args: Json, add: bool) -> AuthoringToolResult {
  let tool_name = if add then "add_effect_to_func" else "remove_effect_from_func";
  let name = json_string_field(args, "name", "");
  let effect = json_string_field(args, "effect", "");
  if trim(name) == "" || trim(effect) == "" then mk_err(st, tool_name, "invalid_arguments", "missing_name_or_effect", "provide args.name and args.effect", [])
  else {
    let updated = update_func_effect_rec(st.funcs, name, effect, add, false);
    if not updated.found then mk_err(st, tool_name, "unknown_symbol", "function_not_found", "check function name", [])
    else {
      let next = { module_path: st.module_path, imports: st.imports, type_aliases: st.type_aliases, type_defs: st.type_defs, funcs: updated.funcs };
      mk_ok(next, tool_name, jo([kv("name", js(trim(name))), kv("effect", js(trim(effect))), kv("add", jb(add))]))
    }
  }
}

func handle_rename_var(st: ProgramState, args: Json) -> AuthoringToolResult {
  let func_name = json_string_field(args, "func_name", "");
  let from = json_string_field(args, "from", "");
  let to = json_string_field(args, "to", "");
  if trim(func_name) == "" || trim(from) == "" || trim(to) == "" then mk_err(st, "rename_var_in_body", "invalid_arguments", "missing_func_name_or_from_or_to", "provide args.func_name/from/to", [])
  else {
    let next = { module_path: st.module_path, imports: st.imports, type_aliases: st.type_aliases, type_defs: st.type_defs, funcs: rename_var_in_funcs_rec(st.funcs, func_name, from, to) };
    mk_ok(next, "rename_var_in_body", jo([kv("func_name", js(trim(func_name))), kv("from", js(trim(from))), kv("to", js(trim(to)))]))
  }
}

func handle_finalize(st: ProgramState) -> AuthoringToolResult ! {FS, Process, Clock} {
  let snippet = render_program(st);
  let checked = check_snippet(snippet);
  if checked.ok then {
    {
      ok: true,
      tool: "finalize",
      error_class: "",
      detail: "",
      suggestion: "",
      payload_json: encode(jo([kv("tool", js("finalize")), kv("ok", jb(true)), kv("snippet", js(snippet))])),
      state: st,
      finalized: true,
      finalize_ok: true,
      snippet: snippet,
      check_errors: ""
    }
  } else {
    {
      ok: false,
      tool: "finalize",
      error_class: "finalize_check_error",
      detail: checked.errors,
      suggestion: "use repair tools then call finalize again",
      payload_json: encode(jo([
        kv("tool", js("finalize")),
        kv("ok", jb(false)),
        kv("error_class", js("finalize_check_error")),
        kv("errors", js(checked.errors))
      ])),
      state: st,
      finalized: true,
      finalize_ok: false,
      snippet: snippet,
      check_errors: checked.errors
    }
  }
}

func unsupported_tool(st: ProgramState, tool: string) -> AuthoringToolResult {
  mk_err(
    st,
    tool,
    "unsupported_tool",
    "tool not supported by structured authoring dispatcher",
    "use one of set_module/add_import/add_type_alias/define_type/define_func/set_main/replace_func_body/add_effect_to_func/remove_effect_from_func/rename_var_in_body/finalize",
    []
  )
}

export func dispatch_authoring_tool(raw_tool_call_json: string, state_in: ProgramState) -> AuthoringToolResult ! {FS, Process, Clock} {
  match decode(raw_tool_call_json) {
    Err(_) => mk_err(state_in, "", "malformed_tool_call", "invalid JSON in tool_call fence", "emit strict JSON object with tool and args", []),
    Ok(obj) => {
      let tool = trim(json_string_field(obj, "tool", ""));
      let args = match get(obj, "args") { Some(v) => v, None => jo([]) };
      if tool == "set_module" then handle_set_module(state_in, args)
      else if tool == "add_import" then handle_add_import(state_in, args)
      else if tool == "add_type_alias" then handle_add_type_alias(state_in, args)
      else if tool == "define_type" then handle_define_type(state_in, args)
      else if tool == "define_func" then handle_define_func(state_in, args)
      else if tool == "set_main" then handle_set_main(state_in, args)
      else if tool == "replace_func_body" then handle_replace_func_body(state_in, args)
      else if tool == "add_effect_to_func" then handle_add_remove_effect(state_in, args, true)
      else if tool == "remove_effect_from_func" then handle_add_remove_effect(state_in, args, false)
      else if tool == "rename_var_in_body" then handle_rename_var(state_in, args)
      else if tool == "finalize" then handle_finalize(state_in)
      else unsupported_tool(state_in, tool)
    }
  }
}

export func empty_program_state() -> ProgramState {
  init_program_state()
}
