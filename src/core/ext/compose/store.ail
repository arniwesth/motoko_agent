module src/core/ext/compose/store

import std/bytes (fromString, length, slice, toString)
import std/fs (mkdirAll, writeFile)
import std/crypto (sha256Hex)

func truncate_utf8_by_bytes(s: string, max_bytes: int) -> string {
  let b = fromString(s);
  let n = length(b);
  if n <= max_bytes then s
  else {
    match slice(b, 0, max_bytes) {
      Some(x) => toString(x),
      None => ""
    }
  }
}

export func store_stdout_and_elide(workdir: string, compose_id: string, stdout: string, max_stdout_bytes: int) -> { stdout: string, truncated: bool, raw_path: string } ! {FS} {
  let compose_store_dir = "${workdir}/.motoko-store/compose";
  let _ = mkdirAll(compose_store_dir);
  let raw_path = "${compose_store_dir}/${compose_id}.stdout";
  let _ = writeFile(raw_path, stdout);
  let out_bytes = length(fromString(stdout));
  if out_bytes > max_stdout_bytes then {
    let clipped = truncate_utf8_by_bytes(stdout, max_stdout_bytes);
    {
      stdout: "${clipped}\n[stdout elided; full output at ${raw_path}]",
      truncated: true,
      raw_path: raw_path
    }
  } else {
    { stdout: stdout, truncated: false, raw_path: raw_path }
  }
}

export func store_snippet(workdir: string, compose_id: string, attempt: int, snippet_full_source: string) -> string ! {FS} {
  let snippets_dir = "${workdir}/.motoko-store/snippets";
  let _ = mkdirAll(snippets_dir);
  let file_name = "compose_${sha256Hex(compose_id)}_attempt_${show(attempt)}.ail";
  let path = "${snippets_dir}/${file_name}";
  let _ = writeFile(path, snippet_full_source);
  path
}

export func store_snippet_with_meta(workdir: string, compose_id: string, attempt: int, snippet_full_source: string, meta_json: string) -> { ail_path: string, meta_path: string } ! {FS} {
  let snippets_dir = "${workdir}/.motoko-store/snippets";
  let _ = mkdirAll(snippets_dir);
  let base_name = "compose_${sha256Hex(compose_id)}_attempt_${show(attempt)}";
  let ail_path = "${snippets_dir}/${base_name}.ail";
  let meta_path = "${snippets_dir}/${base_name}.meta.json";
  let _ = writeFile(ail_path, snippet_full_source);
  let _ = writeFile(meta_path, "${meta_json}\n");
  { ail_path: ail_path, meta_path: meta_path }
}
