module src/core/ext/compose/telemetry

import std/json (Json, jo, kv, js, jb, jnum)

export func init(compose_id: string, max_attempts: int, intent_kind: string, guard_mode: string) -> Json {
  jo([
    kv("compose_id", js(compose_id)),
    kv("max_attempts", jnum(_int_to_float(max_attempts))),
    kv("attempts_started", jnum(0.0)),
    kv("attempts_completed", jnum(0.0)),
    kv("author_failures", jnum(0.0)),
    kv("missing_fence_or_empty", jnum(0.0)),
    kv("check_failures", jnum(0.0)),
    kv("check_error_parse", jnum(0.0)),
    kv("check_error_effect", jnum(0.0)),
    kv("check_error_type", jnum(0.0)),
    kv("check_error_import_or_symbol", jnum(0.0)),
    kv("check_error_other", jnum(0.0)),
    kv("run_failures", jnum(0.0)),
    kv("validator_unsatisfied", jnum(0.0)),
    kv("validator_inconclusive", jnum(0.0)),
    kv("summary_failures", jnum(0.0)),
    kv("succeeded", jb(false)),
    kv("exhausted", jb(false)),
    kv("final_exit_code", jnum(0.0)),
    kv("duration_ms", jnum(0.0)),
    kv("intent_kind", js(intent_kind)),
    kv("guard_mode", js(guard_mode)),
    kv("validator_certificate_structure_failures", jnum(0.0)),
    kv("validator_content_failures", jnum(0.0)),
    kv("sf5", jo([
      kv("invocations", jnum(0.0)),
      kv("budget_exhausted", jb(false)),
      kv("budget_exhausted_emitted", jb(false))
    ]))
  ])
}
