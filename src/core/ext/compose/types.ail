module src/core/ext/compose/types

export type IntentKind
  = Analyze
  | List
  | Transform
  | Compute
  | Fetch
  | Summarize
  deriving (Eq)

export type OutputContract
  = NonEmpty
  | ContainsAll({ tokens: [string], case_sensitive: bool })
  | Certificate({ min_premises: int, require_trace: bool, require_conclusion: bool })
  | LinesRegex({ pattern: string, flags: string, min_lines: int, max_lines: int, has_min: bool, has_max: bool })

export type Verdict
  = Confirmed
  | Disputed
  | Vacuous
  | SurprisingRestriction
  | Inconclusive
  deriving (Eq)

export type Validation = {
  decided: bool,
  satisfied: bool,
  confidence: string,
  reason: string
}

export type ComposeRequest = {
  id: string,
  step: int,
  intent: string,
  intent_kind: string,
  trigger_prompt: string,
  expected_output: string,
  hints_read: [string],
  hints_write: [string],
  hints_avoid: [string],
  model: string,
  max_attempts: int,
  system_prompt: string,
  caps: string
}

export type ComposeTelemetry = {
  compose_id: string,
  max_attempts: int,
  attempts_started: int,
  attempts_completed: int,
  author_failures: int,
  missing_fence_or_empty: int,
  check_failures: int,
  check_error_parse: int,
  check_error_effect: int,
  check_error_type: int,
  check_error_import_or_symbol: int,
  check_error_other: int,
  run_failures: int,
  validator_unsatisfied: int,
  validator_inconclusive: int,
  summary_failures: int,
  succeeded: bool,
  exhausted: bool,
  final_exit_code: int,
  duration_ms: int,
  intent_kind: string,
  guard_mode: string,
  validator_certificate_structure_failures: int,
  validator_content_failures: int
}
