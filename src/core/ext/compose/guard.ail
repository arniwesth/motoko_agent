module src/core/ext/compose/guard

import std/string (split, trim, toLower, contains, find, substring)

func valid_effect_name(x: string) -> bool {
  let n = trim(x);
  n == "IO" || n == "FS" || n == "Process" || n == "Net" || n == "Env" || n == "AI" || n == "SharedMem" || n == "Clock" || n == "Stream"
}

func parse_effect_csv(raw: string) -> [string] {
  let parts = split(raw, ",");
  parse_effect_csv_rec(parts)
}

func parse_effect_csv_rec(parts: [string]) -> [string] {
  match parts {
    [] => [],
    x :: rest => {
      let t = trim(x);
      if t == "" || not valid_effect_name(t) then parse_effect_csv_rec(rest)
      else t :: parse_effect_csv_rec(rest)
    }
  }
}

export func parse_declared_effects(snippet: string) -> [string] {
  let mark = "! {";
  let i = find(snippet, mark);
  if i < 0 then []
  else {
    let after = substring(snippet, i + 3, _str_len(snippet));
    let j = find(after, "}");
    if j < 0 then []
    else parse_effect_csv(substring(after, 0, j))
  }
}

func has_effect(xs: [string], v: string) -> bool {
  match xs {
    [] => false,
    x :: rest => if x == v then true else has_effect(rest, v)
  }
}

export func compose_snippet_guard(mode_raw: string, snippet: string, intent_kind: string) -> string {
  let mode = toLower(trim(mode_raw));
  if mode == "0" then ""
  else {
    let s = toLower(snippet);
    let has_marker =
      contains(s, "simulated analysis") ||
      contains(s, "in a real execution") ||
      contains(s, "would read files") ||
      contains(s, "based on structural inspection") ||
      contains(s, "hypothetical");
    if has_marker then "compose guard: fabricated-analysis marker detected"
    else if intent_kind != "analyze" && intent_kind != "summarize" then ""
    else if mode == "legacy" then {
      let has_read = contains(s, "readfile(") || contains(s, "exec(");
      if has_read then "" else "compose guard: analysis intent requires evidence reads (missing readFile/exec usage)"
    } else {
      let effects = parse_declared_effects(snippet);
      if has_effect(effects, "FS") || has_effect(effects, "Process") then ""
      else "compose guard: analysis intent requires FS or Process effect"
    }
  }
}

export func classify_ailang_error(errors: string) -> string {
  let e = toLower(errors);
  if contains(e, "missing effect") || contains(e, "effect checking") then "effect"
  else if contains(e, "expected next token") || contains(e, "unexpected token") then "parse"
  else if contains(e, "undefined") || contains(e, "not found") then "import_or_symbol"
  else if contains(e, "type mismatch") || contains(e, "cannot unify") then "type"
  else "other"
}

export func targeted_hint(errors: string) -> string {
  let e = toLower(errors);
  if contains(e, "compose guard:") then "Hint: do not fabricate analysis. Read real files with readFile(...) and derive findings from observed content only."
  else if contains(e, "missing effect") || contains(e, "effect checking") then "Hint: add missing effects in main signature, usually ! {IO, FS}."
  else if contains(e, "=>") || contains(e, "expected next token") then "Hint: AILANG uses match arms with => and lambdas as \\x. expr, not (x) => expr."
  else if contains(e, "then") || contains(e, "got {") then "Hint: if syntax is `if cond then a else b` with no braces or parentheses."
  else if contains(e, "unexpected token") && contains(e, ";") then "Hint: do not end import lines with semicolons."
  else if contains(e, "undefined") || contains(e, "not found") then "Hint: import every used function explicitly from std/* modules."
  else "Hint: emit a complete fresh snippet that strictly follows the AILANG skeleton and syntax rules."
}
