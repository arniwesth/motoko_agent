module src/core/ext/openkb/exec

import std/bytes (toString)
import std/json (Json, decode, encode, jo, kv, js)
import std/process (exec, ProcessError)
import std/result (Ok, Err)
import std/string (trim)
import src/core/tool_contract (ToolResultEnvelope)
import src/core/compress (compress_output)

func process_error_to_string(err: ProcessError) -> string {
  match err {
    NotAllowed(cmd) => "not allowed: ${cmd}",
    NotFound(cmd) => "not found: ${cmd} — is openkb installed? (pip install openkb)",
    PermissionDenied(cmd) => "permission denied: ${cmd}",
    Timeout(ms) => "timeout after ${show(ms)}ms",
    OutputLimitExceeded(n) => "output limit exceeded: ${show(n)} bytes",
    SpawnFailed(msg) => "spawn failed: ${msg}",
    AbnormalExit(sig, name) => "abnormal exit signal ${show(sig)} (${name})"
  }
}

func parse_output_json(raw_stdout: string) -> Json {
  let t = trim(raw_stdout);
  if t == "" then jo([kv("output", js(""))])
  else
    match decode(t) {
      Ok(parsed) => parsed,
      Err(_) => jo([kv("output", js(t))])
    }
}

func timeout_seconds(timeout_ms: int) -> int {
  if timeout_ms <= 0 then 0
  else {
    let secs = timeout_ms / 1000;
    if (secs * 1000) < timeout_ms then secs + 1 else secs
  }
}

export func build_shell_argv(args: [string], wiki_dir: string, timeout_ms: int) -> [string] {
  let secs = timeout_seconds(timeout_ms);
  let script = if secs > 0 then
    "set -eu\ncd \"$1\"\nPATH=\"$HOME/.local/bin:$PATH\"\nduration=\"$2\"\nshift 2\ntimeout \"$duration\" openkb \"$@\""
    else
    "set -eu\ncd \"$1\"\nPATH=\"$HOME/.local/bin:$PATH\"\nshift\nopenkb \"$@\"";
  if secs > 0 then ["-lc", script, "motoko-openkb", wiki_dir, "${show(secs)}s"] ++ args
  else ["-lc", script, "motoko-openkb", wiki_dir] ++ args
}

func shell_exec(args: [string], wiki_dir: string, timeout_ms: int) -> Result[{ stdout: string, stderr: string, exit_code: int }, string] ! {Process} {
  let argv = build_shell_argv(args, wiki_dir, timeout_ms);
  match exec("bash", argv) {
    Err(e) => Err(process_error_to_string(e)),
    Ok(out) => Ok({
      stdout: toString(out.stdout),
      stderr: toString(out.stderr),
      exit_code: out.exitCode
    })
  }
}

export func run_openkb(id: string, tool: string, args: [string], wiki_dir: string, timeout_ms: int, max_output_chars: int) -> ToolResultEnvelope ! {Process} {
  match shell_exec(args, wiki_dir, timeout_ms) {
    Err(msg) =>
      {
        tool_call_id: id,
        tool: tool,
        stdout: "",
        stderr: msg,
        exit_code: 1,
        metadata: jo([kv("json_metadata", js(encode(jo([kv("output", js(msg))]))))])
      },
    Ok(out) => {
      let stdout = compress_output(out.stdout, max_output_chars);
      {
        tool_call_id: id,
        tool: tool,
        stdout: stdout,
        stderr: out.stderr,
        exit_code: out.exit_code,
        metadata: jo([kv("json_metadata", js(encode(parse_output_json(stdout))))])
      }
    }
  }
}
