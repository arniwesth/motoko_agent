module src/core/ext/exa_search/types

import src/core/ext/mcp/types (McpServerConfig, McpToolMapping)

export func tool_filter() -> [string] {
  ["web_search_exa", "web_fetch_exa"]
}

export func tool_mappings() -> [McpToolMapping] {
  [
    {
      canonical: "ExaSearch",
      mcp_name: "web_search_exa",
      aliases: ["exa_search", "exa.search", "exa_search.search"]
    },
    {
      canonical: "ExaFetch",
      mcp_name: "web_fetch_exa",
      aliases: ["exa_fetch", "exa.fetch", "exa_search.fetch"]
    },
    {
      canonical: "ExaCrawl",
      mcp_name: "web_fetch_exa",
      aliases: ["exa_crawl", "exa.crawl", "exa_search.crawl"]
    }
  ]
}

export func mcp_config(timeout_ms: int, max_output_chars: int) -> McpServerConfig {
  {
    base_url: "https://mcp.exa.ai/mcp",
    auth_env_var: "EXA_API_KEY",
    auth_style: "query:exaApiKey",
    tool_filter: tool_filter(),
    timeout_ms: timeout_ms,
    max_output_chars: max_output_chars
  }
}
