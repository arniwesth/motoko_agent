module src/core/ext/exa_search/prompts

import std/fs (fileExists, readFile)
import pkg/sunholo/motoko_core/ext/types (PromptPatch)

export func load_agent_prompt(cwd: string) -> string ! {FS} {
  let workspace_path = "${cwd}/src/core/ext/exa_search/AGENT.md";
  let packaged_workspace_path = "${cwd}/.packages/motoko_exa_search/AGENT.md";
  if fileExists(workspace_path) then readFile(workspace_path)
  else if fileExists(packaged_workspace_path) then readFile(packaged_workspace_path)
  else ""
}

export func build_prompt_patch(cached_prompt: string) -> PromptPatch {
  if cached_prompt == "" then { prepend: [], append: [] }
  else { prepend: [], append: [cached_prompt] }
}
