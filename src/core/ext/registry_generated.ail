func with_id(h: ExtensionHooks, id: string) -> ExtensionHooks {
  { h | id: id }
}

func parse_tokens(xs: [string], idx: int, acc: [ExtensionHooks], cfg: RuntimeConfig) -> ExtRegistry ! {Env, FS} {
  match xs {
    [] => { hooks: acc },
    raw :: rest => {
      let name = trim(raw);
      match resolve(name, cfg) {
        None => parse_tokens(rest, idx + 1, acc, cfg),
        Some(hook) => {
          let id = "${name}#${show(idx)}";
          parse_tokens(rest, idx + 1, acc ++ [with_id(hook, id)], cfg)
        }
      }
    }
  }
}

export func parse_core_ext_order(raw: string, cfg: RuntimeConfig) -> ExtRegistry ! {Env, FS} {
  if trim(raw) == "" then { hooks: [] }
  else parse_tokens(split(raw, ","), 0, [], cfg)
}
