module src/core/ext/test_dummy/dummy

import std/option (Option, Some, None)
import std/env (getEnvOr)
import std/json (jo)
import src/core/tool_contract (ToolCallEnvelope)
import src/core/ext/types (ExtCtx, ExtensionHooks, PromptPatch, BudgetPatch, BudgetPlan, ToolPolicyDecision, FinalizeDecision, ToolHandleDecision, ResponseInterceptDecision)

func normalize_decision(s: string) -> string {
  if s == "allow" then "allow"
  else if s == "deny" then "deny"
  else "noop"
}

func normalize_finalize(s: string) -> string {
  if s == "accept" then "accept"
  else if s == "continue" then "continue"
  else "noop"
}

func list_len(xs: [string]) -> int {
  match xs {
    [] => 0,
    _ :: rest => 1 + list_len(rest)
  }
}

func first_or_empty(xs: [string]) -> string {
  match xs {
    [] => "",
    x :: _ => x
  }
}

func is_allow(d: ToolPolicyDecision) -> bool {
  match d {
    Allow => true,
    _ => false
  }
}

func is_noop(d: ToolPolicyDecision) -> bool {
  match d {
    NoOpinion => true,
    _ => false
  }
}

func is_deny_msg(d: ToolPolicyDecision, msg: string) -> bool {
  match d {
    Deny(m) => m == msg,
    _ => false
  }
}

func is_accept_value(d: FinalizeDecision, value: string) -> bool {
  match d {
    Accept(v) => v == value,
    _ => false
  }
}

func is_continue_msg(d: FinalizeDecision, msg: string) -> bool {
  match d {
    ContinueWithFeedback(m) => m == msg,
    _ => false
  }
}

export func on_build_system_prompt(marker: string) -> PromptPatch {
  if marker == "" then { prepend: [], append: [] }
  else { prepend: [], append: [marker] }
}

export func on_budget_plan(total: Option[int]) -> BudgetPatch {
  {
    requested_total: total,
    requested_solver: None,
    requested_verifier: None
  }
}

export func on_tool_policy(setting: string, _call: ToolCallEnvelope) -> ToolPolicyDecision {
  let mode = normalize_decision(setting);
  if mode == "allow" then Allow
  else if mode == "deny" then Deny("dummy deny")
  else NoOpinion
}

export func on_tool_handle(_setting: string, _call: ToolCallEnvelope) -> ToolHandleDecision {
  Delegate
}

export func on_response_intercept(_setting: string, _response: string) -> ResponseInterceptDecision {
  NoIntercept
}

export func on_solver_candidate(setting: string, candidate: string) -> FinalizeDecision {
  let mode = normalize_finalize(setting);
  if mode == "accept" then Accept(candidate)
  else if mode == "continue" then ContinueWithFeedback("dummy feedback")
  else NoDecision
}

type DummyConfig = {
  prompt: string,
  tool_decision: string,
  finalize: string,
  budget_total: Option[int]
}

func parse_optional_int(raw: string) -> Option[int] {
  if raw == "" then None
  else match _stringToInt(raw) {
    Some(n) => Some(n),
    None => None
  }
}

func load_config() -> DummyConfig ! {Env} {
  {
    prompt: getEnvOr("EXT_DUMMY_PROMPT", ""),
    tool_decision: getEnvOr("EXT_DUMMY_TOOL_DECISION", "noop"),
    finalize: getEnvOr("EXT_DUMMY_FINALIZE", "noop"),
    budget_total: parse_optional_int(getEnvOr("EXT_DUMMY_BUDGET_TOTAL", ""))
  }
}

export func register() -> ExtensionHooks ! {Env, FS} {
  let cfg = load_config();
  let handle = func(_ctx: ExtCtx, call: ToolCallEnvelope) -> ToolHandleDecision ! {IO, Process, FS, AI, Env, Net, SharedMem, Clock, Stream} {
    on_tool_handle(cfg.tool_decision, call)
  };
  let intercept = func(_ctx: ExtCtx, response_text: string) -> ResponseInterceptDecision ! {IO, Process, FS, AI, Env, Net, SharedMem, Clock, Stream} {
    on_response_intercept(cfg.tool_decision, response_text)
  };
  let finalize = func(_ctx: ExtCtx, candidate: string) -> FinalizeDecision ! {IO, Process, FS, AI, Env, Net, SharedMem, Clock, Stream} {
    on_solver_candidate(cfg.finalize, candidate)
  };
  {
    id: "test_dummy",
    provided_tools: [],
    on_build_system_prompt: \_ctx. on_build_system_prompt(cfg.prompt),
    on_budget_plan: func(_ctx: ExtCtx, _plan: BudgetPlan) -> BudgetPatch ! {Env, FS} { on_budget_plan(cfg.budget_total) },
    on_tool_policy: \_ctx call. on_tool_policy(cfg.tool_decision, call),
    on_tool_handle: handle,
    on_response_intercept: intercept,
    on_solver_candidate: finalize
  }
}

func prompt_marker_noop() -> bool
  tests [((), true)]
  {
    let p = on_build_system_prompt("");
    list_len(p.prepend) == 0 && list_len(p.append) == 0
  }

func prompt_marker_appends() -> bool
  tests [((), true)]
  {
    let p = on_build_system_prompt("DUMMY_MARKER");
    list_len(p.append) == 1 && first_or_empty(p.append) == "DUMMY_MARKER"
  }

func tool_noop() -> bool
  tests [((), true)]
  {
    let d = on_tool_policy("noop", { id: "x", tool: "ReadFile", arguments: jo([]) });
    is_noop(d)
  }

func tool_allow() -> bool
  tests [((), true)]
  {
    let d = on_tool_policy("allow", { id: "x", tool: "ReadFile", arguments: jo([]) });
    is_allow(d)
  }

func tool_deny() -> bool
  tests [((), true)]
  {
    let d = on_tool_policy("deny", { id: "x", tool: "ReadFile", arguments: jo([]) });
    is_deny_msg(d, "dummy deny")
  }

func finalize_continue() -> bool
  tests [((), true)]
  {
    is_continue_msg(on_solver_candidate("continue", "candidate"), "dummy feedback")
  }

func finalize_accept() -> bool
  tests [((), true)]
  {
    is_accept_value(on_solver_candidate("accept", "candidate"), "candidate")
  }
