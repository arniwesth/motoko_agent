module src/core/ext/mcp/exec

import std/bytes (toString)
import std/json (Json, decode, encode, jo, kv, js, get, asString)
import std/option (Option, Some, None)
import std/process (exec, ProcessError)
import std/string (trim, toLower, contains, join)

import pkg/sunholo/motoko_core/tool_contract (ToolResultEnvelope)
import src/core/compress (compress_output)
import src/core/ext/mcp/types (McpServerConfig)

func process_error_to_string(err: ProcessError) -> string {
  match err {
    NotAllowed(cmd) => "not allowed: ${cmd}",
    NotFound(cmd) => "not found: ${cmd}",
    PermissionDenied(cmd) => "permission denied: ${cmd}",
    Timeout(ms) => "timeout after ${show(ms)}ms",
    OutputLimitExceeded(n) => "output limit exceeded: ${show(n)} bytes",
    SpawnFailed(msg) => "spawn failed: ${msg}",
    AbnormalExit(sig, name) => "abnormal exit signal ${show(sig)} (${name})"
  }
}

func is_binary_missing(err: ProcessError) -> bool {
  match err {
    NotFound(_) => true,
    SpawnFailed(_) => true,
    _ => false
  }
}

export func parse_output_json(raw_stdout: string) -> Json {
  let t = trim(raw_stdout);
  if t == "" then jo([kv("output", js(""))])
  else
    match decode(t) {
      Ok(parsed) => parsed,
      Err(_) => jo([kv("output", js(t))])
    }
}

func timeout_seconds(timeout_ms: int) -> int {
  if timeout_ms <= 0 then 0
  else {
    let secs = timeout_ms / 1000;
    if (secs * 1000) < timeout_ms then secs + 1 else secs
  }
}

export func build_shell_argv(bin: string, args: [string], cwd: string, timeout_ms: int) -> [string] {
  let secs = timeout_seconds(timeout_ms);
  let script = if secs > 0 then
    "set -eu\ncd \"$1\"\nPATH=\"$HOME/.local/bin:$PATH\"\nbin=\"$2\"\nduration=\"$3\"\nshift 3\ntimeout \"$duration\" \"$bin\" \"$@\""
    else
    "set -eu\ncd \"$1\"\nPATH=\"$HOME/.local/bin:$PATH\"\nbin=\"$2\"\nshift 2\n\"$bin\" \"$@\"";
  if secs > 0 then ["-lc", script, "motoko-mcp", cwd, bin, "${show(secs)}s"] ++ args
  else ["-lc", script, "motoko-mcp", cwd, bin] ++ args
}

func shell_exec(bin: string, args: [string], cwd: string, timeout_ms: int) -> Option[{ stdout: string, stderr: string, exit_code: int, err: string }] ! {Process} {
  let argv = build_shell_argv(bin, args, cwd, timeout_ms);
  match exec("bash", argv) {
    Err(e) => {
      if is_binary_missing(e) then None
      else Some({ stdout: "", stderr: "", exit_code: 1, err: process_error_to_string(e) })
    },
    Ok(out) => Some({ stdout: toString(out.stdout), stderr: toString(out.stderr), exit_code: out.exitCode, err: "" })
  }
}

func json_string_field(obj: Json, key: string, fallback: string) -> string {
  match get(obj, key) {
    Some(v) => match asString(v) {
      Some(s) => s,
      None => fallback
    },
    None => fallback
  }
}

func parse_bridge_response(raw_stdout: string) -> { output: string, error: string } {
  let t = trim(raw_stdout);
  if t == "" then { output: "", error: "" }
  else
    match decode(t) {
      Err(_) => { output: t, error: "" },
      Ok(parsed) => {
        let err = json_string_field(parsed, "error", "");
        if err != "" then { output: "", error: err }
        else { output: json_string_field(parsed, "output", t), error: "" }
      }
    }
}

func error_envelope(id: string, tool: string, message: string) -> ToolResultEnvelope {
  {
    tool_call_id: id,
    tool: tool,
    stdout: "",
    stderr: message,
    exit_code: 1,
    metadata: jo([kv("json_metadata", js(encode(jo([kv("output", js(message))]))))])
  }
}

func looks_like_missing_node(stderr: string, exit_code: int) -> bool {
  let s = toLower(stderr);
  exit_code == 127 && (contains(s, "node") && contains(s, "not found") || contains(s, "command not found"))
}

func with_tools_filter(args: [string], cfg: McpServerConfig) -> [string] {
  let tools_csv = join(",", cfg.tool_filter);
  if tools_csv == "" then args
  else args ++ ["--tools", tools_csv]
}

export func bridge_args(workdir: string, cfg: McpServerConfig, mcp_tool_name: string, args_json: string) -> [string] {
  with_tools_filter([
    "${workdir}/scripts/mcp-call.mjs",
    "--base-url", cfg.base_url,
    "--auth-env-var", cfg.auth_env_var,
    "--auth-style", cfg.auth_style,
    "--tool", mcp_tool_name,
    "--args-json", args_json,
    "--timeout-ms", show(cfg.timeout_ms)
  ], cfg)
}

func list_bridge_args(workdir: string, cfg: McpServerConfig) -> [string] {
  with_tools_filter([
    "${workdir}/scripts/mcp-call.mjs",
    "--base-url", cfg.base_url,
    "--auth-env-var", cfg.auth_env_var,
    "--auth-style", cfg.auth_style,
    "--method", "tools/list",
    "--timeout-ms", show(cfg.timeout_ms)
  ], cfg)
}

export func run_mcp_tool(id: string, canonical: string, workdir: string, cfg: McpServerConfig, mcp_tool_name: string, args: Json) -> Option[ToolResultEnvelope] ! {Process} {
  let argv = bridge_args(workdir, cfg, mcp_tool_name, encode(args));
  match shell_exec("node", argv, workdir, cfg.timeout_ms) {
    None => None,
    Some(out) => {
      if out.err != "" then Some(error_envelope(id, canonical, out.err))
      else if looks_like_missing_node(out.stderr, out.exit_code) then None
      else {
        let bridge = parse_bridge_response(out.stdout);
        if bridge.error != "" then Some(error_envelope(id, canonical, bridge.error))
        else {
          let stdout = compress_output(bridge.output, cfg.max_output_chars);
          let stderr = compress_output(out.stderr, cfg.max_output_chars);
          Some({
            tool_call_id: id,
            tool: canonical,
            stdout: stdout,
            stderr: stderr,
            exit_code: out.exit_code,
            metadata: jo([kv("json_metadata", js(encode(parse_output_json(stdout))))])
          })
        }
      }
    }
  }
}

export func list_mcp_tools(workdir: string, cfg: McpServerConfig) -> Option[string] ! {Process} {
  match shell_exec("node", list_bridge_args(workdir, cfg), workdir, cfg.timeout_ms) {
    None => None,
    Some(out) => {
      if out.err != "" then Some("")
      else if looks_like_missing_node(out.stderr, out.exit_code) then None
      else {
        let bridge = parse_bridge_response(out.stdout);
        if bridge.error != "" then Some("")
        else Some(bridge.output)
      }
    }
  }
}
