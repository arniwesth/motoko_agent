module src/core/ext/mcp/resolve

import std/option (Option, Some, None)
import std/string (toLower, trim)
import src/core/ext/mcp/types (McpToolMapping)

func normalize(name: string) -> string {
  toLower(trim(name))
}

func alias_matches(raw_norm: string, aliases: [string]) -> bool {
  match aliases {
    [] => false,
    x :: rest =>
      if normalize(x) == raw_norm then true
      else alias_matches(raw_norm, rest)
  }
}

func mapping_matches(raw_norm: string, m: McpToolMapping) -> bool {
  normalize(m.canonical) == raw_norm || alias_matches(raw_norm, m.aliases)
}

func resolve_rec(raw_norm: string, mappings: [McpToolMapping]) -> Option[McpToolMapping] {
  match mappings {
    [] => None,
    m :: rest =>
      if mapping_matches(raw_norm, m) then Some(m)
      else resolve_rec(raw_norm, rest)
  }
}

export func resolve_tool(raw: string, mappings: [McpToolMapping]) -> Option[McpToolMapping] {
  let raw_norm = normalize(raw);
  if raw_norm == "" then None else resolve_rec(raw_norm, mappings)
}

export func all_tool_names(mappings: [McpToolMapping]) -> [string] {
  match mappings {
    [] => [],
    m :: rest => [m.canonical] ++ m.aliases ++ all_tool_names(rest)
  }
}

func eq_string_list(a: [string], b: [string]) -> bool {
  match (a, b) {
    ([], []) => true,
    (x :: xs, y :: ys) => x == y && eq_string_list(xs, ys),
    _ => false
  }
}

func fixture_mappings() -> [McpToolMapping] {
  [
    {
      canonical: "GenericSearch",
      mcp_name: "search_tool",
      aliases: ["generic_search", "generic.search"]
    },
    {
      canonical: "GenericDeepSearch",
      mcp_name: "deep_search_tool",
      aliases: ["generic_deep_search", "generic.deep_search"]
    }
  ]
}

func resolve_matches_canonical_case_insensitive() -> bool
  tests [((), true)]
  {
    match resolve_tool("  genericsearch  ", fixture_mappings()) {
      Some(m) => m.mcp_name == "search_tool",
      None => false
    }
  }

func resolve_matches_alias() -> bool
  tests [((), true)]
  {
    match resolve_tool("GENERIC.SEARCH", fixture_mappings()) {
      Some(m) => m.canonical == "GenericSearch",
      None => false
    }
  }

func resolve_miss_returns_none() -> bool
  tests [((), true)]
  {
    match resolve_tool("read_file", fixture_mappings()) {
      Some(_) => false,
      None => true
    }
  }

func all_names_flattens_canonical_then_aliases() -> bool
  tests [((), true)]
  {
    eq_string_list(all_tool_names(fixture_mappings()), [
      "GenericSearch", "generic_search", "generic.search",
      "GenericDeepSearch", "generic_deep_search", "generic.deep_search"
    ])
  }
