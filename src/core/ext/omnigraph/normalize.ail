module src/core/ext/omnigraph/normalize

import std/json (Json, encode, jo, kv, js, get, asString)
import std/option (Option, Some, None)
import std/string (toLower, trim)
import pkg/sunholo/motoko_core/tool_contract (ToolCallEnvelope)

func canonical_omnigraph_tool(raw: string) -> string {
  let t = toLower(trim(raw));
  if t == "omnigraphread" || t == "omnigraph_read" || t == "omnigraph.read" || t == "omnigraphquery" || t == "omnigraph_query" then "OmnigraphRead"
  else if t == "omnigraphmutate" || t == "omnigraph_mutate" || t == "omnigraph.mutate" then "OmnigraphMutate"
  else if t == "omnigraphbranch" || t == "omnigraph_branch" || t == "omnigraph.branch" || t == "omnigraphcreatebranch" || t == "omnigraph_create_branch" || t == "list_branches" || t == "omnigraph_list_branches" then "OmnigraphBranch"
  else if t == "omnigraphstatus" || t == "omnigraph_status" || t == "omnigraph.status" then "OmnigraphStatus"
  else ""
}

func string_arg(args: Json, key: string, fallback: string) -> string {
  match get(args, key) {
    None => fallback,
    Some(j) => match asString(j) {
      Some(v) => v,
      None => fallback
    }
  }
}

func optional_arg(args: Json, key: string) -> Option[string] {
  let v = string_arg(args, key, "");
  if v == "" then None else Some(v)
}

func infer_mutation_query_file(name: string) -> string {
  let n = toLower(trim(name));
  if n == "insert_decision" || n == "update_decision_status" then "mutations/decisions.gq"
  else if n == "insert_component" || n == "insert_dependency" || n == "insert_governs" then "mutations/components.gq"
  else ""
}

func infer_read_query_file(name: string) -> string {
  let n = toLower(trim(name));
  if n == "list_decisions" || n == "decisions_by_status" || n == "decisions_governing" then "queries/decisions.gq"
  else if n == "list_components" || n == "component_dependencies" then "queries/components.gq"
  else ""
}

func infer_branch_action(call_tool: string, args: Json) -> string {
  let explicit = string_arg(args, "action", "");
  if explicit != "" then explicit
  else {
    let tool = toLower(trim(call_tool));
    let new_branch = string_arg(args, "new_branch", "");
    let branch_name = string_arg(args, "branch_name", "");
    let target_branch = string_arg(args, "target_branch", "");
    if tool == "list_branches" || tool == "omnigraph_list_branches" then "list"
    else if new_branch != "" || branch_name != "" then "create"
    else if target_branch != "" then "merge"
    else ""
  }
}

func branch_name(args: Json) -> Option[string] {
  match optional_arg(args, "name") {
    Some(v) => Some(v),
    None =>
      match optional_arg(args, "new_branch") {
        Some(v) => Some(v),
        None => optional_arg(args, "branch_name")
      }
  }
}

func branch_from(args: Json) -> Option[string] {
  match optional_arg(args, "from") {
    Some(v) => Some(v),
    None => optional_arg(args, "source_branch")
  }
}

func branch_into(args: Json) -> Option[string] {
  match optional_arg(args, "into") {
    Some(v) => Some(v),
    None => optional_arg(args, "target_branch")
  }
}

func read_args(args: Json) -> Json {
  let name0 = string_arg(args, "name", "");
  let name = if name0 != "" then name0 else string_arg(args, "query", "");
  let query_file0 = string_arg(args, "query_file", "");
  let query_file = if query_file0 != "" then query_file0 else infer_read_query_file(name);
  jo([
    kv("query_file", js(query_file)),
    kv("name", js(name)),
    kv("params", js(match optional_arg(args, "params") { Some(v) => v, None => "" })),
    kv("branch", js(match optional_arg(args, "branch") { Some(v) => v, None => "" }))
  ])
}

func mutate_args(args: Json) -> Json {
  let name0 = string_arg(args, "name", "");
  let name = if name0 != "" then name0 else string_arg(args, "mutation", "");
  let query_file0 = string_arg(args, "query_file", "");
  let query_file = if query_file0 != "" then query_file0 else infer_mutation_query_file(name);
  let params_raw = string_arg(args, "params", "");
  let params =
    if params_raw != "" then params_raw
    else match get(args, "args") {
      Some(v) => encode(v),
      None => "{}"
    };
  jo([
    kv("query_file", js(query_file)),
    kv("name", js(name)),
    kv("params", js(params)),
    kv("branch", js(string_arg(args, "branch", "")))
  ])
}

func branch_args(call_tool: string, args: Json) -> Json {
  jo([
    kv("action", js(infer_branch_action(call_tool, args))),
    kv("name", js(match branch_name(args) { Some(v) => v, None => "" })),
    kv("from", js(match branch_from(args) { Some(v) => v, None => "" })),
    kv("into", js(match branch_into(args) { Some(v) => v, None => "" }))
  ])
}

export func normalize_call(call: ToolCallEnvelope) -> Option[ToolCallEnvelope] {
  let canonical = canonical_omnigraph_tool(call.tool);
  if canonical == "" then None
  else if canonical == "OmnigraphRead" then
    Some({ id: call.id, tool: canonical, arguments: read_args(call.arguments) })
  else if canonical == "OmnigraphMutate" then
    Some({ id: call.id, tool: canonical, arguments: mutate_args(call.arguments) })
  else if canonical == "OmnigraphBranch" then
    Some({ id: call.id, tool: canonical, arguments: branch_args(call.tool, call.arguments) })
  else if canonical == "OmnigraphStatus" then
    Some({ id: call.id, tool: canonical, arguments: jo([]) })
  else None
}
