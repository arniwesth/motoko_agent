module src/core/parse

import std/option (Option, Some, None)
import std/result (Ok, Err)
import std/string (split, trim, contains, startsWith, find, substring, length, toLower)
import std/json   (Json, decode, encode, jo, kv, js, jb, ja, jnum, get, asString, asNumber, asBool, asArray)
import src/core/types  (ProcessExecReq, ToolParseStatus, EditOp)
import src/core/tool_contract (ToolCallEnvelope)

export func extract_fence(text: string, fence: string) -> Option[string] {
  let parts = split(text, fence);
  match parts {
    []              => None,
    _ :: []         => None,
    _ :: rest :: _ => {
      if fence == "```json" then {
        -- Quote-aware scan: backticks inside JSON strings do not close the fence.
        let body_pos =
          if length(rest) > 0 && substring(rest, 0, 1) == "\n"
          then 1 else 0;
        let close_idx = find_json_fence_close(rest, body_pos, false, false);
        if close_idx == -1 then None
        else Some(trim(substring(rest, body_pos, close_idx)))
      }
      else {
        let inner_parts = split(rest, "```");
        match inner_parts {
          []              => None,
          _ :: []         => None,
          cmd :: _ :: _   => Some(trim(cmd))
        }
      }
    }
  }
}

func looks_like_shell(cmd: string) -> bool {
  let c = trim(cmd);
  if startsWith(c, "cd ") then true
  else if startsWith(c, "git ") then true
  else if startsWith(c, "ls ") then true
  else if startsWith(c, "ls\n") then true
  else if startsWith(c, "cat ") then true
  else if startsWith(c, "echo ") then true
  else if startsWith(c, "grep ") then true
  else if startsWith(c, "find ") then true
  else if startsWith(c, "mkdir") then true
  else if startsWith(c, "curl ") then true
  else if startsWith(c, "pip ") then true
  else if startsWith(c, "python") then true
  else if startsWith(c, "npm ") then true
  else if startsWith(c, "make ") then true
  else if startsWith(c, "#!/") then true
  else if startsWith(c, "export ") then true
  else if startsWith(c, "source ") then true
  else if startsWith(c, "chmod ") then true
  else if startsWith(c, "cp ") then true
  else if startsWith(c, "mv ") then true
  else if startsWith(c, "rm ") then true
  else false
}

export func first_shell_line(lines: [string]) -> Option[string] {
  match lines {
    []             => None,
    line :: rest   =>
      if looks_like_shell(trim(line))
      then Some(trim(line))
      else first_shell_line(rest)
  }
}

-- Extract an ```ailang fenced block from LLM response text.
-- Ignores ailang blocks that fall inside <think>...</think> spans.
export func extract_ailang(text: string) -> Option[string] {
  let spans = reasoning_spans(text);
  extract_ailang_search(text, spans, 0)
}

func extract_ailang_search(text: string, spans: [Span], pos: int) -> Option[string] {
  let fence = "```ailang";
  let fence_len = 9;
  let idx = find_from(text, fence, pos);
  if idx == -1 then None
  else if in_any_span(idx, spans) then
    extract_ailang_search(text, spans, idx + fence_len)
  else {
    let body_start = idx + fence_len;
    let body_pos =
      if body_start < length(text) && substring(text, body_start, body_start + 1) == "\n"
      then body_start + 1
      else body_start;
    let close_idx = find_from(text, "```", body_pos);
    if close_idx == -1 then None
    else Some(trim(substring(text, body_pos, close_idx)))
  }
}

export func extract_bash(text: string) -> Option[string] {
  match extract_fence(text, "```bash") {
    Some(cmd) => Some(cmd),
    None =>
      match extract_fence(text, "```sh\n") {
        Some(cmd) => Some(cmd),
        None =>
          match extract_fence(text, "```shell") {
            Some(cmd) => Some(cmd),
            None =>
              match extract_fence(text, "```\n") {
                Some(cmd) => if looks_like_shell(cmd) then Some(cmd) else None,
                None => first_shell_line(split(text, "\n"))
              }
          }
      }
  }
}

export func is_done(stdout: string) -> bool {
  contains(stdout, "COMPLETE_TASK_AND_SUBMIT_FINAL_OUTPUT")
}

export func parse_cwd(cmd: string, current_cwd: string) -> string {
  let c = trim(cmd);
  if contains(c, "cd /") then {
    let after_cd = split(c, "cd /");
    match after_cd {
      [] => current_cwd,
      _ :: [] => current_cwd,
      _ :: path_part :: _ => {
        let tokens = split(path_part, " ");
        match tokens {
          [] => current_cwd,
          dir :: _ => "/${trim(dir)}"
        }
      }
    }
  } else
    current_cwd
}

func json_string(obj: Json, key: string, fallback: string) -> string {
  match get(obj, key) {
    None => fallback,
    Some(j) => match asString(j) {
      None => fallback,
      Some(s) => s
    }
  }
}

func json_number(obj: Json, key: string, fallback: int) -> int {
  match get(obj, key) {
    None => fallback,
    Some(j) => match asNumber(j) {
      None => fallback,
      Some(n) => _float_to_int(n)
    }
  }
}

func json_bool(obj: Json, key: string, fallback: bool) -> bool {
  match get(obj, key) {
    None => fallback,
    Some(j) => match asBool(j) {
      None => fallback,
      Some(b) => b
    }
  }
}

func json_field(obj: Json, key: string) -> Option[Json] {
  match get(obj, key) {
    Some(v) => Some(v),
    None =>
      match get(obj, "args") {
        Some(args_obj) => get(args_obj, key),
        None =>
          match get(obj, "arguments") {
            Some(args_obj) => get(args_obj, key),
            None =>
              match get(obj, "params") {
                Some(args_obj) => get(args_obj, key),
                None => None
              }
          }
      }
  }
}

func json_string_flex(obj: Json, key: string, fallback: string) -> string {
  match json_field(obj, key) {
    None => fallback,
    Some(j) => match asString(j) {
      None => fallback,
      Some(s) => s
    }
  }
}

func json_number_flex(obj: Json, key: string, fallback: int) -> int {
  match json_field(obj, key) {
    None => fallback,
    Some(j) => match asNumber(j) {
      None => fallback,
      Some(n) => _float_to_int(n)
    }
  }
}

func json_bool_flex(obj: Json, key: string, fallback: bool) -> bool {
  match json_field(obj, key) {
    None => fallback,
    Some(j) => match asBool(j) {
      None => fallback,
      Some(b) => b
    }
  }
}

func json_string_list(value: Json) -> [string] {
  match asArray(value) {
    None => [],
    Some(xs) => json_string_list_rec(xs)
  }
}

func json_string_list_rec(xs: [Json]) -> [string] {
  match xs {
    [] => [],
    x :: rest =>
      match asString(x) {
        None => json_string_list_rec(rest),
        Some(s) => s :: json_string_list_rec(rest)
      }
  }
}

func parse_exec_req(obj: Json) -> ProcessExecReq {
  let cmd_raw = json_string(obj, "cmd", "");
  let command_raw = json_string(obj, "command", "");
  let args_raw = match get(obj, "args") {
    None => [],
    Some(j) => json_string_list(j)
  };
  let cmd_top =
    if cmd_raw != "" then cmd_raw
    else if command_raw != "" then "bash"
    else "";
  let args_top =
    if cmd_raw != "" then args_raw
    else if command_raw != "" then ["-lc", command_raw]
    else args_raw;
  let streaming = json_bool(obj, "streaming", false);
  let stderr_live = json_bool(obj, "needs_stderr_live", false);
  let hard_cancel = json_bool(obj, "needs_hard_cancel", false);
  let cwd_opt = match get(obj, "cwd") {
    Some(j) => match asString(j) {
      Some(s) => Some(s),
      None => None
    },
    None => None
  };
  {
    cmd: cmd_top,
    args: args_top,
    cwd: cwd_opt,
    streaming: streaming,
    needs_stderr_live: stderr_live,
    needs_hard_cancel: hard_cancel
  }
}

func parse_exec_from_call(obj: Json) -> ProcessExecReq {
  match get(obj, "exec") {
    Some(exec_obj) => parse_exec_req(exec_obj),
    None =>
      match get(obj, "args") {
        None =>
          match get(obj, "arguments") {
            Some(args_obj) =>
              match get(args_obj, "exec") {
                Some(exec_obj) => parse_exec_req(exec_obj),
                None => parse_exec_req(args_obj)
              },
            None =>
              match get(obj, "params") {
                Some(args_obj) =>
                  match get(args_obj, "exec") {
                    Some(exec_obj) => parse_exec_req(exec_obj),
                    None => parse_exec_req(args_obj)
                  },
                None => parse_exec_req(obj)
              }
          },
        Some(args_obj) =>
          match get(args_obj, "exec") {
            Some(exec_obj) => parse_exec_req(exec_obj),
            None => parse_exec_req(args_obj)
          }
      }
  }
}

func parse_edit_ops(value: Json) -> [EditOp] {
  match asArray(value) {
    None => [],
    Some(xs) => parse_edit_ops_rec(xs)
  }
}

func parse_edit_ops_rec(xs: [Json]) -> [EditOp] {
  match xs {
    [] => [],
    x :: rest => {
      let item = {
        old: json_string(x, "old", ""),
        new: json_string(x, "new", ""),
        replace_all: json_bool(x, "replace_all", false)
      };
      item :: parse_edit_ops_rec(rest)
    }
  }
}

func canonical_tool_name(raw: string) -> string {
  let t = toLower(trim(raw));
  if t == "readfile" || t == "read_file" || t == "cat" then "ReadFile"
  else if t == "search" || t == "grep" then "Search"
  else if t == "writefile" || t == "write_file" then "WriteFile"
  else if t == "compose" then "Compose"
  else if t == "editfile" || t == "edit_file" then "EditFile"
  else if t == "bashexec" || t == "bash_exec" || t == "bash" || t == "exec" || t == "ls" || t == "run_command" || t == "terminal_run_command" || t == "terminal_ls" then "BashExec"
  else if t == "runtests" || t == "run_tests" then "RunTests"
  else trim(raw)
}

func raw_tool_name(obj: Json) -> string {
  let tool = json_string(obj, "tool", "");
  if tool != "" then tool
  else {
    let tool_name = json_string(obj, "tool_name", "");
    if tool_name != "" then tool_name
    else {
    let call = json_string(obj, "call", "");
    if call != "" then call
    else {
      let name = json_string(obj, "name", "");
      if name != "" then name
      else {
        let typ = json_string(obj, "type", "");
        if typ != "" then typ else json_string(obj, "method", "")
      }
    }
    }
  }
}

func fallback_tool_id(tool: string, obj: Json) -> string {
  let path = json_string_flex(obj, "path", "");
  let pattern = json_string_flex(obj, "pattern", "");
  let intent = json_string_flex(obj, "intent", "");
  let cmd =
    match json_field(obj, "cmd") {
      Some(j) => match asString(j) { Some(s) => s, None => "" },
      None => ""
    };
  let command =
    match json_field(obj, "command") {
      Some(j) => match asString(j) { Some(s) => s, None => "" },
      None => ""
    };

  let suffix =
    if path != "" then path
    else if pattern != "" then pattern
    else if intent != "" then intent
    else if cmd != "" then cmd
    else if command != "" then command
    else "auto";

  "${tool}:${suffix}"
}

func normalize_args_obj(obj: Json) -> Json {
  match get(obj, "arguments") {
    Some(j) => j,
    None =>
      match get(obj, "args") {
        Some(j) => j,
        None =>
          match get(obj, "params") {
            Some(j) => j,
            None => obj
          }
      }
  }
}

func parse_one_tool_call(obj: Json) -> Option[ToolCallEnvelope] {
  let raw_tool = raw_tool_name(obj);
  let tool = canonical_tool_name(raw_tool);
  let explicit_id = json_string(obj, "id", "");
  let id = if explicit_id == "" then fallback_tool_id(tool, obj) else explicit_id;
  if tool == "BashExec" then {
    let low_raw = toLower(trim(raw_tool));
    if low_raw == "ls" then {
      let path = json_string_flex(obj, "path", ".");
      Some({
        id: id,
        tool: "BashExec",
        arguments: jo([
          kv("cmd", js("ls")),
          kv("args", as_json_string_list([path])),
          kv("streaming", jb(false)),
          kv("needs_stderr_live", jb(false)),
          kv("needs_hard_cancel", jb(false))
        ])
      })
    } else {
      let exec_req = parse_exec_from_call(obj);
      let cwd_json = match exec_req.cwd { Some(c) => js(c), None => js("") };
      Some({
        id: id,
        tool: "BashExec",
        arguments: jo([
          kv("cmd", js(exec_req.cmd)),
          kv("args", as_json_string_list(exec_req.args)),
          kv("cwd", cwd_json),
          kv("streaming", jb(exec_req.streaming)),
          kv("needs_stderr_live", jb(exec_req.needs_stderr_live)),
          kv("needs_hard_cancel", jb(exec_req.needs_hard_cancel))
        ])
      })
    }
  }
  else if tool == "RunTests" then
    {
      let exec_req = parse_exec_from_call(obj);
      let cwd_json = match exec_req.cwd { Some(c) => js(c), None => js("") };
      Some({
        id: id,
        tool: "RunTests",
        arguments: jo([
          kv("cmd", js(exec_req.cmd)),
          kv("args", as_json_string_list(exec_req.args)),
          kv("cwd", cwd_json),
          kv("streaming", jb(exec_req.streaming)),
          kv("needs_stderr_live", jb(exec_req.needs_stderr_live)),
          kv("needs_hard_cancel", jb(exec_req.needs_hard_cancel))
        ])
      })
    }
  else if tool == "ReadFile" || tool == "Search" || tool == "WriteFile" || tool == "Compose" || tool == "EditFile" then
    Some({ id: id, tool: tool, arguments: normalize_args_obj(obj) })
  else if raw_tool != "" then
    Some({ id: id, tool: trim(raw_tool), arguments: normalize_args_obj(obj) })
  else None
}

func as_json_string_list(xs: [string]) -> Json {
  ja(as_json_string_list_rec(xs))
}

func as_json_string_list_rec(xs: [string]) -> [Json] {
  match xs {
    [] => [],
    x :: rest => js(x) :: as_json_string_list_rec(rest)
  }
}

func collect_calls(xs: [Json], warnings: [string]) -> { calls: [ToolCallEnvelope], warnings: [string] } {
  match xs {
    [] => { calls: [], warnings: warnings },
    x :: rest => {
      let tool_name = raw_tool_name(x);
      match parse_one_tool_call(x) {
        None => {
          let next = collect_calls(rest, warnings ++ ["unsupported tool: ${tool_name}"]);
          { calls: next.calls, warnings: next.warnings }
        },
        Some(call) => {
          let next = collect_calls(rest, warnings);
          { calls: call :: next.calls, warnings: next.warnings }
        }
      }
    }
  }
}

func extract_named_quoted_arg(raw: string, key: string) -> string {
  let key_idx = find(raw, key);
  if key_idx == -1 then ""
  else {
    let from_key = substring(raw, key_idx, length(raw));
    let colon = find(from_key, ":");
    if colon == -1 then ""
    else {
      let after_colon = substring(from_key, colon + 1, length(from_key));
      let q1 = find(after_colon, "\"");
      if q1 == -1 then ""
      else {
        let after_q1 = substring(after_colon, q1 + 1, length(after_colon));
        let q2 = find(after_q1, "\"");
        if q2 == -1 then "" else substring(after_q1, 0, q2)
      }
    }
  }
}

func parse_legacy_terminal_call(text: string) -> Option[ToolCallEnvelope] {
  let t = trim(text);
  if not startsWith(t, "call:terminal:") then None
  else {
    let rest = substring(t, 14, length(t));
    let split_idx = find(rest, ":{");
    if split_idx == -1 then None
    else {
      let op = trim(substring(rest, 0, split_idx));
      let raw_args = substring(rest, split_idx + 1, length(rest));
      let path = extract_named_quoted_arg(raw_args, "path");
      if op == "ls_r" then {
        let target = if path == "" then "." else path;
        Some({
          id: "legacy-ls_r",
          tool: "BashExec",
          arguments: jo([
            kv("cmd", js("ls")),
            kv("args", as_json_string_list(["-R", target])),
            kv("streaming", jb(false)),
            kv("needs_stderr_live", jb(false)),
            kv("needs_hard_cancel", jb(false))
          ])
        })
      }
      else if op == "read_file" then {
        if path == "" then None
        else Some({
          id: "legacy-read_file",
          tool: "ReadFile",
          arguments: jo([
            kv("path", js(path)),
            kv("start", jnum(1.0)),
            kv("end", jnum(200.0))
          ])
        })
      }
      else if op == "ls" || op == "list_files" || op == "list_dir" || op == "terminal_ls" then {
        let target = if path == "" then "." else path;
        Some({
          id: "legacy-terminal-ls",
          tool: "BashExec",
          arguments: jo([
            kv("cmd", js("ls")),
            kv("args", as_json_string_list([target])),
            kv("streaming", jb(false)),
            kv("needs_stderr_live", jb(false)),
            kv("needs_hard_cancel", jb(false))
          ])
        })
      }
      else if op == "run_command" || op == "terminal_run_command" then {
        let command = extract_named_quoted_arg(raw_args, "command");
        if command == "" then None
        else Some({
          id: "legacy-terminal-run_command",
          tool: "BashExec",
          arguments: jo([
            kv("cmd", js("bash")),
            kv("args", as_json_string_list(["-lc", command])),
            kv("streaming", jb(false)),
            kv("needs_stderr_live", jb(false)),
            kv("needs_hard_cancel", jb(false))
          ])
        })
      }
      else None
    }
  }
}

func parse_legacy_direct_call(text: string) -> Option[ToolCallEnvelope] {
  let t = trim(text);
  if not startsWith(t, "call:") || startsWith(t, "call:terminal:") then None
  else {
    let rest = substring(t, 5, length(t));
    let brace_idx = find(rest, "{");
    if brace_idx == -1 then None
    else {
      let op = trim(substring(rest, 0, brace_idx));
      let raw_args = substring(rest, brace_idx, length(rest));
      let path = extract_named_quoted_arg(raw_args, "path");
      if op == "ls_format" || op == "ls" || op == "list_files" || op == "list_dir" || op == "file_system:list_files" || op == "filesystem:list_files" || op == "file_system:ls" || op == "filesystem:ls" then {
        let target = if path == "" then "." else path;
        Some({
          id: "legacy-ls",
          tool: "BashExec",
          arguments: jo([
            kv("cmd", js("ls")),
            kv("args", as_json_string_list([target])),
            kv("streaming", jb(false)),
            kv("needs_stderr_live", jb(false)),
            kv("needs_hard_cancel", jb(false))
          ])
        })
      }
      else if op == "read_file" || op == "file_system:read_file" || op == "filesystem:read_file" then {
        if path == "" then None
        else Some({
          id: "legacy-read_file",
          tool: "ReadFile",
          arguments: jo([
            kv("path", js(path)),
            kv("start", jnum(1.0)),
            kv("end", jnum(200.0))
          ])
        })
      }
      else None
    }
  }
}

-- ── Think-span helpers ──────────────────────────────────────────────────────

type Span = { start: int, end: int }

-- Return the index of `needle` in `hay` starting at `offset`, or -1.
func find_from(hay: string, needle: string, offset: int) -> int {
  let sub = substring(hay, offset, length(hay));
  let idx = find(sub, needle);
  if idx == -1 then -1 else idx + offset
}

-- Collect all [start,end) spans for <think>...</think> in `text`.
-- An unclosed <think> runs to end-of-string.
func think_spans(text: string) -> [Span] {
  think_spans_loop(text, 0, [])
}

func think_spans_loop(text: string, pos: int, acc: [Span]) -> [Span] {
  let open_idx = find_from(text, "<think>", pos);
  if open_idx == -1 then acc
  else {
    let body_start = open_idx + 7;
    let close_idx  = find_from(text, "</think>", body_start);
    if close_idx == -1 then
      acc ++ [{ start: open_idx, end: length(text) }]
    else {
      let span_end = close_idx + 8;
      think_spans_loop(text, span_end, acc ++ [{ start: open_idx, end: span_end }])
    }
  }
}

func tag_spans(text: string, open_tag: string, close_tag: string) -> [Span] {
  tag_spans_loop(text, open_tag, close_tag, 0, [])
}

func tag_spans_loop(text: string, open_tag: string, close_tag: string, pos: int, acc: [Span]) -> [Span] {
  let open_idx = find_from(text, open_tag, pos);
  if open_idx == -1 then acc
  else {
    let body_start = open_idx + length(open_tag);
    let close_idx  = find_from(text, close_tag, body_start);
    if close_idx == -1 then
      acc ++ [{ start: open_idx, end: length(text) }]
    else {
      let span_end = close_idx + length(close_tag);
      tag_spans_loop(text, open_tag, close_tag, span_end, acc ++ [{ start: open_idx, end: span_end }])
    }
  }
}

func has_spans(spans: [Span]) -> bool {
  match spans {
    [] => false,
    _ :: _ => true
  }
}

-- Prefer known reasoning tags in order.
-- First match wins to preserve monotonic spans for slicing/removal.
func reasoning_spans(text: string) -> [Span] {
  let think = think_spans(text);
  if has_spans(think) then think else {
    let thinking = tag_spans(text, "<thinking>", "</thinking>");
    if has_spans(thinking) then thinking else {
      let analysis = tag_spans(text, "<analysis>", "</analysis>");
      if has_spans(analysis) then analysis
      else tag_spans(text, "<reasoning>", "</reasoning>")
    }
  }
}

func in_any_span(pos: int, spans: [Span]) -> bool {
  match spans {
    [] => false,
    s :: rest => if pos >= s.start && pos < s.end then true else in_any_span(pos, rest)
  }
}

-- ── JSON-fence candidates (quote-aware closing fence) ────────────────────────

type JsonCandidate = { start: int, body: string }

-- Scan forward from `pos` in `hay`, looking for the closing "```" that is NOT
-- inside a JSON double-quoted string.
func find_json_fence_close(hay: string, pos: int, in_str: bool, escaped: bool) -> int {
  let hay_len = length(hay);
  if pos >= hay_len then -1
  else {
    let ch = substring(hay, pos, pos + 1);
    if escaped then
      find_json_fence_close(hay, pos + 1, in_str, false)
    else if in_str then {
      if ch == "\\" then find_json_fence_close(hay, pos + 1, true, true)
      else if ch == "\"" then find_json_fence_close(hay, pos + 1, false, false)
      else find_json_fence_close(hay, pos + 1, true, false)
    }
    else {
      -- not in string: check for closing fence
      if ch == "`" then {
        let remaining = hay_len - pos;
        if remaining >= 3 &&
           substring(hay, pos + 1, pos + 2) == "`" &&
           substring(hay, pos + 2, pos + 3) == "`"
        then pos
        else find_json_fence_close(hay, pos + 1, false, false)
      }
      else if ch == "\"" then find_json_fence_close(hay, pos + 1, true, false)
      else find_json_fence_close(hay, pos + 1, false, false)
    }
  }
}

-- Collect all ```json ... ``` candidates (quote-aware) in source order.
func collect_fenced_candidates(text: string, pos: int, acc: [JsonCandidate]) -> [JsonCandidate] {
  let open_idx = find_from(text, "```json", pos);
  if open_idx == -1 then acc
  else {
    let body_start = open_idx + 7;
    -- skip optional newline after opening fence
    let body_pos =
      if body_start < length(text) && substring(text, body_start, body_start + 1) == "\n"
      then body_start + 1
      else body_start;
    let close_idx = find_json_fence_close(text, body_pos, false, false);
    if close_idx == -1 then acc
    else {
      let body = trim(substring(text, body_pos, close_idx));
      let candidate = { start: open_idx, body: body };
      collect_fenced_candidates(text, close_idx + 3, acc ++ [candidate])
    }
  }
}

-- Scan backward from pos to find the last `{` (JSON object root opener).
func last_open_brace_before(text: string, pos: int) -> int {
  if pos < 0 then -1
  else if substring(text, pos, pos + 1) == "{" then pos
  else last_open_brace_before(text, pos - 1)
}

-- For each occurrence of `"tool_calls"` outside think spans, scan back to the
-- opening `{` and add a candidate starting there.
func collect_obj_candidates(text: string, pos: int, spans: [Span], acc: [JsonCandidate]) -> [JsonCandidate] {
  let tc_idx = find_from(text, "\"tool_calls\"", pos);
  let calls_idx = find_from(text, "\"calls\"", pos);
  let key_idx =
    if tc_idx == -1 then calls_idx
    else if calls_idx == -1 then tc_idx
    else if tc_idx < calls_idx then tc_idx else calls_idx;
  if key_idx == -1 then acc
  else if in_any_span(key_idx, spans) then
    collect_obj_candidates(text, key_idx + 7, spans, acc)
  else {
    let json_start = last_open_brace_before(text, key_idx);
    if json_start == -1 then
      collect_obj_candidates(text, key_idx + 7, spans, acc)
    else {
      let body = substring(text, json_start, length(text));
      collect_obj_candidates(text, key_idx + 7, spans, acc ++ [{ start: json_start, body: body }])
    }
  }
}

-- For direct single-tool JSON objects like {"tool":"Compose",...}, scan
-- occurrences of `"tool"` outside think spans and add object-root candidates.
func collect_single_tool_obj_candidates_for_key(text: string, key: string, pos: int, spans: [Span], acc: [JsonCandidate]) -> [JsonCandidate] {
  let key_idx = find_from(text, key, pos);
  if key_idx == -1 then acc
  else if in_any_span(key_idx, spans) then
    collect_single_tool_obj_candidates_for_key(text, key, key_idx + length(key), spans, acc)
  else {
    let json_start = last_open_brace_before(text, key_idx);
    if json_start == -1 then
      collect_single_tool_obj_candidates_for_key(text, key, key_idx + length(key), spans, acc)
    else {
      let body = substring(text, json_start, length(text));
      collect_single_tool_obj_candidates_for_key(text, key, key_idx + length(key), spans, acc ++ [{ start: json_start, body: body }])
    }
  }
}

func collect_single_tool_obj_candidates(text: string, spans: [Span], acc: [JsonCandidate]) -> [JsonCandidate] {
  let with_tool = collect_single_tool_obj_candidates_for_key(text, "\"tool\"", 0, spans, acc);
  collect_single_tool_obj_candidates_for_key(text, "\"tool_name\"", 0, spans, with_tool)
}

-- If the trimmed text starts with `[` (root array), add it as a candidate.
func collect_arr_candidate(text: string, spans: [Span], acc: [JsonCandidate]) -> [JsonCandidate] {
  let t = trim(text);
  if startsWith(t, "[") then {
    let arr_idx = find(text, "[");
    if arr_idx == -1 || in_any_span(arr_idx, spans) then acc
    else acc ++ [{ start: arr_idx, body: substring(text, arr_idx, length(text)) }]
  }
  else acc
}

func collect_unfenced_candidates(text: string, spans: [Span], acc: [JsonCandidate]) -> [JsonCandidate] {
  -- Prefer top-level arrays first so `[{"tool":...}, ...]` is parsed as one
  -- candidate, not as a partial single-object prefix.
  let with_arr = collect_arr_candidate(text, spans, acc);
  let with_tool_arrays = collect_obj_candidates(text, 0, spans, with_arr);
  collect_single_tool_obj_candidates(text, spans, with_tool_arrays)
}

-- ── First-valid selection ─────────────────────────────────────────────────────

func is_valid_tool_root(root: Json) -> bool {
  match find_tool_calls_array(root) {
    Some(_) => true,
    None => false
  }
}

func first_valid_tool_json(candidates: [JsonCandidate], spans: [Span]) -> Option[string] {
  match candidates {
    [] => None,
    c :: rest =>
      if in_any_span(c.start, spans) then first_valid_tool_json(rest, spans)
      else match decode(c.body) {
        Err(_) => first_valid_tool_json(rest, spans),
        Ok(root) =>
          if is_valid_tool_root(root) then Some(c.body)
          else first_valid_tool_json(rest, spans)
      }
  }
}

func extract_tool_json(text: string) -> Option[string] {
  let spans      = reasoning_spans(text);
  let fenced     = collect_fenced_candidates(text, 0, []);
  let candidates = collect_unfenced_candidates(text, spans, fenced);
  first_valid_tool_json(candidates, spans)
}

func first_tool_json_candidate(candidates: [JsonCandidate], spans: [Span]) -> Option[string] {
  match candidates {
    [] => None,
    c :: rest =>
      if in_any_span(c.start, spans) then first_tool_json_candidate(rest, spans)
      else Some(c.body)
  }
}

func extract_any_tool_json_candidate(text: string) -> Option[string] {
  let spans      = reasoning_spans(text);
  let fenced     = collect_fenced_candidates(text, 0, []);
  let candidates = collect_unfenced_candidates(text, spans, fenced);
  first_tool_json_candidate(candidates, spans)
}

func find_unescaped_quote(s: string, pos: int, escaped: bool) -> int {
  if pos >= length(s) then -1
  else {
    let ch = substring(s, pos, pos + 1);
    if escaped then find_unescaped_quote(s, pos + 1, false)
    else if ch == "\\" then find_unescaped_quote(s, pos + 1, true)
    else if ch == "\"" then pos
    else find_unescaped_quote(s, pos + 1, false)
  }
}

func next_non_space_char(s: string, pos: int) -> string {
  if pos >= length(s) then ""
  else {
    let ch = substring(s, pos, pos + 1);
    if ch == " " || ch == "\n" || ch == "\t" || ch == "\r"
    then next_non_space_char(s, pos + 1)
    else ch
  }
}

func field_has_suspicious_quote(raw_json: string, field: string, pos: int) -> bool {
  let needle = "\"${field}\":\"";
  let idx = find_from(raw_json, needle, pos);
  if idx == -1 then false
  else {
    let value_start = idx + length(needle);
    let close_idx = find_unescaped_quote(raw_json, value_start, false);
    if close_idx == -1 then true
    else {
      let next = next_non_space_char(raw_json, close_idx + 1);
      let suspicious = not (next == "," || next == "}" || next == "]");
      if suspicious then true
      else field_has_suspicious_quote(raw_json, field, close_idx + 1)
    }
  }
}

func write_like_tool(raw_json: string) -> bool {
  contains(raw_json, "\"tool\":\"WriteFile\"")
    || contains(raw_json, "\"tool\":\"EditFile\"")
}

func malformed_json_hint(raw_json: string) -> string {
  if not write_like_tool(raw_json) then ""
  else {
    let suspicious =
      field_has_suspicious_quote(raw_json, "content", 0)
        || field_has_suspicious_quote(raw_json, "old", 0)
        || field_has_suspicious_quote(raw_json, "new", 0);
    if suspicious
    then " Hint: likely unescaped quote inside a JSON string field (content/old/new). Escape inner quotes as \\\" and emit only JSON in tool-call turns."
    else ""
  }
}

func looks_like_non_json_tool_syntax(text: string) -> bool {
  startsWith(trim(text), "call:")
    || (contains(text, "tool_calls:") && contains(text, "EditFile{"))
    || (contains(text, "tool_calls:") && contains(text, "WriteFile{"))
}

func non_json_tool_syntax_hint() -> string {
  "tool calls must be strict JSON with quoted keys/strings, e.g. ```json {\"tool_calls\":[...]} ```; do not use call:tool_calls:Tool{...} or call:terminal:op:{...} syntax."
}

func find_tool_calls_array(root: Json) -> Option[[Json]] {
  match asArray(root) {
    Some(xs) => Some(xs),
    None =>
      match get(root, "tool_calls") {
        None =>
          match get(root, "tools") {
            None => {
              match get(root, "calls") {
                None => {
                  let raw = raw_tool_name(root);
                  let canonical = canonical_tool_name(raw);
                  if canonical == "ReadFile" || canonical == "Search" || canonical == "WriteFile" || canonical == "Compose" || canonical == "EditFile" || canonical == "BashExec" || canonical == "RunTests" || trim(raw) != ""
                  then Some([root])
                  else None
                },
                Some(j) => asArray(j)
              }
            },
            Some(j) => asArray(j)
          },
        Some(j) => asArray(j)
      }
  }
}

-- ── Think/answer splitting ───────────────────────────────────────────────────

func span_body_start(text: string, s: Span) -> int {
  let tag_end = find_from(text, ">", s.start);
  if tag_end == -1 then s.start else tag_end + 1
}

func span_body_end(text: string, s: Span) -> int {
  if s.end == length(text) then s.end
  else {
    let close_start = find_from(text, "</", span_body_start(text, s));
    if close_start == -1 || close_start > s.end then s.end else close_start
  }
}

-- Collect the inner text of all <think>...</think> blocks concatenated.
func collect_think_text(spans: [Span], text: string) -> string {
  match spans {
    [] => "",
    s :: rest => {
      let body = substring(text, span_body_start(text, s), span_body_end(text, s));
      let tail = collect_think_text(rest, text);
      if tail == "" then body else "${body}\n${tail}"
    }
  }
}

-- Remove all <think>...</think> spans from text, returning the remainder.
func remove_spans(text: string, spans: [Span]) -> string {
  remove_spans_loop(text, spans, 0, "")
}

func remove_spans_loop(text: string, spans: [Span], pos: int, acc: string) -> string {
  let text_len = length(text);
  match spans {
    [] =>
      if pos >= text_len then acc
      else "${acc}${substring(text, pos, text_len)}",
    s :: rest => {
      let before =
        if s.start > pos then substring(text, pos, s.start) else "";
      remove_spans_loop(text, rest, s.end, "${acc}${before}")
    }
  }
}

-- Split `text` into its think-block content and non-think answer.
-- Returns { think: string, answer: string }.
export func split_think_answer(text: string) -> { think: string, answer: string } {
  let spans = reasoning_spans(text);
  match spans {
    [] => { think: "", answer: text },
    _  => {
      let think_text  = collect_think_text(spans, text);
      let answer_text = trim(remove_spans(text, spans));
      { think: think_text, answer: answer_text }
    }
  }
}

export func assistant_history_content(response: string) -> string {
  match split_think_answer(response) {
    {think, answer} =>
      if think == "" then response
      else if trim(answer) == "" then "[assistant produced thinking with no answer]"
      else answer
  }
}

export func assistant_visible_output(response: string) -> string {
  match split_think_answer(response) {
    {think, answer} =>
      if think == "" then response
      else if trim(answer) == "" then "[assistant produced thinking with no answer]"
      else answer
  }
}

export func indicates_continuation_intent(text: string) -> bool {
  let t = toLower(trim(text));
  contains(t, "i will issue the next tool call")
    || contains(t, "tool call in a separate")
    || contains(t, "next tool call")
    || contains(t, "json tool_calls block")
    || contains(t, "in a separate json turn")
    || contains(t, "in a dedicated json turn")
    || contains(t, "separate, compliant json turn")
    || contains(t, "dedicated json turn")
    || contains(t, "i will now use `search`")
    || contains(t, "i will now use search")
    || contains(t, "i will use `search`")
    || contains(t, "i will use search")
    || contains(t, "i will now search")
    || contains(t, "i will search")
    || contains(t, "proceeding to search the repository")
    || contains(t, "proceeding to search the codebase")
    || contains(t, "i will now inspect the repository")
    || contains(t, "i will inspect the repository")
    || contains(t, "i will now inspect the codebase")
    || contains(t, "i will inspect the codebase")
    || contains(t, "i will now readfile")
    || contains(t, "i will use readfile")
    || contains(t, "i will now read the file")
    || contains(t, "i will now read files")
    || contains(t, "i will now read src")
    || contains(t, "i will now read the repository")
    || contains(t, "i will now read the code")
    || contains(t, "i will now run a command")
    || contains(t, "i will run a command")
    || contains(t, "i will now execute")
    || contains(t, "i will execute")
    || contains(t, "i will now use ctx")
    || contains(t, "i will use ctx")
    || contains(t, "i will now use exa")
    || contains(t, "i will use exa")
    || contains(t, "i will now use omnigraph")
    || contains(t, "i will use omnigraph")
    || contains(t, "i will now call ctx")
    || contains(t, "i will call ctx")
    || contains(t, "i will now call exa")
    || contains(t, "i will call exa")
    || contains(t, "i will now call omnigraph")
    || contains(t, "i will call omnigraph")
}

export func parse_tool_calls(text: string) -> ToolParseStatus {
  match extract_tool_json(text) {
    None =>
      match parse_legacy_terminal_call(text) {
        Some(call) => ParsedToolCalls({ calls: [call], warnings: ["parsed legacy call:terminal shorthand"] }),
        None =>
          match parse_legacy_direct_call(text) {
            Some(call) => ParsedToolCalls({ calls: [call], warnings: ["parsed legacy call shorthand"] }),
            None => match extract_any_tool_json_candidate(text) {
        None =>
          if looks_like_non_json_tool_syntax(text)
          then ToolParseError(non_json_tool_syntax_hint())
          else NoToolCalls,
        Some(raw_json) =>
          match decode(raw_json) {
            Err(err) => ToolParseError("invalid tool json: ${err}${malformed_json_hint(raw_json)}"),
            Ok(_) => ToolParseError("tool json must include a tool_calls array${malformed_json_hint(raw_json)}")
          }
      }}},
    Some(raw_json) =>
      match decode(raw_json) {
        Err(err) => ToolParseError("invalid tool json: ${err}${malformed_json_hint(raw_json)}"),
        Ok(root) =>
          match find_tool_calls_array(root) {
            None => ToolParseError("tool json must include a tool_calls array"),
            Some(xs) => {
              let collected = collect_calls(xs, []);
              ParsedToolCalls({ calls: collected.calls, warnings: collected.warnings })
            }
          }
      }
  }
}
