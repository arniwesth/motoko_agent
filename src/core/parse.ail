module src/core/parse

-- M-MOTOKO-RPC-LOOP-FULL-MIGRATION M10b cutover (2026-05-06):
-- The text-based tool_call parser (parse_tool_calls,
-- indicates_continuation_intent, extract_any_tool_json_candidate,
-- looks_like_non_json_tool_syntax, parse_legacy_terminal_call,
-- parse_legacy_direct_call, plus all their helpers) has been deleted.
-- Provider-native typed tool_use is now the only dispatch protocol;
-- see src/core/agent_loop_v2.ail for the replacement.
--
-- All that remains is the small fenced-shell-block extractor used by
-- v2's hybrid mode (extract_bash) and its supporting helpers. Hybrid
-- mode synthesizes a BashExec ToolCall from prose when finish_reason
-- is "stop" and the assistant emits a fenced shell block.

import std/option (Option, Some, None)
import std/string (split, trim, startsWith, substring, length)

-- Quote-aware JSON fence close scanner. Lives here because extract_fence
-- needs to support the legacy ```json fence shape (some hybrid prompts
-- still use it). String-aware so backticks inside JSON strings don't
-- prematurely close the fence.
func find_json_fence_close(hay: string, pos: int, in_str: bool, escaped: bool) -> int {
  let hay_len = length(hay);
  if pos >= hay_len then -1
  else {
    let ch = substring(hay, pos, pos + 1);
    if escaped then
      find_json_fence_close(hay, pos + 1, in_str, false)
    else if in_str then {
      if ch == "\\" then find_json_fence_close(hay, pos + 1, true, true)
      else if ch == "\"" then find_json_fence_close(hay, pos + 1, false, false)
      else find_json_fence_close(hay, pos + 1, true, false)
    }
    else {
      if ch == "`" then {
        let remaining = hay_len - pos;
        if remaining >= 3 &&
           substring(hay, pos + 1, pos + 2) == "`" &&
           substring(hay, pos + 2, pos + 3) == "`"
        then pos
        else find_json_fence_close(hay, pos + 1, false, false)
      }
      else if ch == "\"" then find_json_fence_close(hay, pos + 1, true, false)
      else find_json_fence_close(hay, pos + 1, false, false)
    }
  }
}

export func extract_fence(text: string, fence: string) -> Option[string] {
  let parts = split(text, fence);
  match parts {
    []              => None,
    _ :: []         => None,
    _ :: rest :: _ => {
      if fence == "```json" then {
        let body_pos =
          if length(rest) > 0 && substring(rest, 0, 1) == "\n"
          then 1 else 0;
        let close_idx = find_json_fence_close(rest, body_pos, false, false);
        if close_idx == -1 then None
        else Some(trim(substring(rest, body_pos, close_idx)))
      }
      else {
        let inner_parts = split(rest, "```");
        match inner_parts {
          []              => None,
          _ :: []         => None,
          cmd :: _ :: _   => Some(trim(cmd))
        }
      }
    }
  }
}

func looks_like_shell(cmd: string) -> bool {
  let c = trim(cmd);
  if startsWith(c, "cd ") then true
  else if startsWith(c, "git ") then true
  else if startsWith(c, "ls ") then true
  else if startsWith(c, "ls\n") then true
  else if startsWith(c, "cat ") then true
  else if startsWith(c, "echo ") then true
  else if startsWith(c, "grep ") then true
  else if startsWith(c, "find ") then true
  else if startsWith(c, "mkdir") then true
  else if startsWith(c, "curl ") then true
  else if startsWith(c, "pip ") then true
  else if startsWith(c, "python") then true
  else if startsWith(c, "npm ") then true
  else if startsWith(c, "make ") then true
  else if startsWith(c, "#!/") then true
  else if startsWith(c, "export ") then true
  else if startsWith(c, "source ") then true
  else if startsWith(c, "chmod ") then true
  else if startsWith(c, "cp ") then true
  else if startsWith(c, "mv ") then true
  else if startsWith(c, "rm ") then true
  else false
}

export func first_shell_line(lines: [string]) -> Option[string] {
  match lines {
    []             => None,
    line :: rest   =>
      if looks_like_shell(trim(line))
      then Some(trim(line))
      else first_shell_line(rest)
  }
}

-- Extract a fenced shell block from prose. Tries ```bash, ```sh,
-- ```shell, then a generic ``` block (only if the body looks like a
-- shell command), and finally falls back to scanning lines for a
-- shell-shaped command. Returns None if nothing looks like a shell
-- command. Used by agent_loop_v2's hybrid mode to synthesise a
-- BashExec ToolCall from prose-only responses.
export func extract_bash(text: string) -> Option[string] {
  match extract_fence(text, "```bash") {
    Some(cmd) => Some(cmd),
    None =>
      match extract_fence(text, "```sh\n") {
        Some(cmd) => Some(cmd),
        None =>
          match extract_fence(text, "```shell") {
            Some(cmd) => Some(cmd),
            None =>
              match extract_fence(text, "```\n") {
                Some(cmd) => if looks_like_shell(cmd) then Some(cmd) else None,
                None => first_shell_line(split(text, "\n"))
              }
          }
      }
  }
}
