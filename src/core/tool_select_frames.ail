module src/core/tool_select_frames

import std/json (Json, decode, get, asString)
import std/result (Result, Ok, Err)

export type ToolSelectFrame
  = FrameRun(string)
  | FrameToolRequest(string, string)
  | FrameToolResult(string, string)
  | FrameDone(string)

export type FrameState
  = AwaitRun
  | AwaitToolResult(string)
  | FrameComplete

func string_field(obj: Json, key: string) -> string {
  match get(obj, key) {
    Some(v) => match asString(v) { Some(s) => s, None => "" },
    None => ""
  }
}

export func parse_frame(raw: string) -> Result[ToolSelectFrame, string] {
  match decode(raw) {
    Err(_) => Err("malformed frame"),
    Ok(obj) => {
      let typ = string_field(obj, "type");
      let req_id = string_field(obj, "reqId");
      if typ == "run" then Ok(FrameRun(req_id))
      else if typ == "tool-request" then {
        if req_id == "" then Err("tool-request missing reqId")
        else Ok(FrameToolRequest(req_id, raw))
      }
      else if typ == "tool-result" then {
        if req_id == "" then Err("tool-result missing reqId")
        else Ok(FrameToolResult(req_id, raw))
      }
      else if typ == "done" then Ok(FrameDone(string_field(obj, "status")))
      else Err("unknown frame type: ${typ}")
    }
  }
}

export func accept_frame(state: FrameState, frame: ToolSelectFrame) -> Result[FrameState, string] {
  match state {
    AwaitRun =>
      match frame {
        FrameRun(req_id) => Ok(AwaitToolResult(req_id)),
        _ => Err("out-of-order frame: expected run")
      },
    AwaitToolResult(req_id) =>
      match frame {
        FrameToolRequest(next_id, _) =>
          if next_id == req_id then Err("duplicate tool-request frame")
          else Err("out-of-order tool-request frame"),
        FrameToolResult(result_id, _) =>
          if result_id == req_id then Ok(FrameComplete)
          else Err("tool-result reqId mismatch"),
        FrameDone(_) => Ok(FrameComplete),
        FrameRun(_) => Err("duplicate run frame")
      },
    FrameComplete => Err("frame after completion")
  }
}

pure func result_is_err[a](r: Result[a, string]) -> bool {
  match r {
    Ok(_) => false,
    Err(_) => true
  }
}

pure func test_parse_rejects_malformed_frame() -> bool
  tests [((), true)]
  {
    result_is_err(parse_frame("{"))
  }

pure func test_parse_rejects_unknown_frame() -> bool
  tests [((), true)]
  {
    result_is_err(parse_frame("{\"type\":\"bogus\"}"))
  }

pure func test_accept_rejects_out_of_order_result() -> bool
  tests [((), true)]
  {
    result_is_err(accept_frame(AwaitRun, FrameToolResult("r1", "{}")))
  }

pure func test_accept_rejects_duplicate_request() -> bool
  tests [((), true)]
  {
    match accept_frame(AwaitRun, FrameRun("r1")) {
      Err(_) => false,
      Ok(next) => result_is_err(accept_frame(next, FrameToolRequest("r1", "{}")))
    }
  }

pure func test_accepts_run_then_result() -> bool
  tests [((), true)]
  {
    match accept_frame(AwaitRun, FrameRun("r1")) {
      Err(_) => false,
      Ok(next) =>
        match accept_frame(next, FrameToolResult("r1", "{}")) {
          Ok(FrameComplete) => true,
          _ => false
        }
    }
  }
