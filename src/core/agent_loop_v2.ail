-- src/core/agent_loop_v2.ail
-- Alternative agent loop using upstream std/ai.step() with TYPED tool_calls.
-- Replaces motoko's text-based parse_tool_calls + indicates_continuation_intent
-- string-matching layer with provider-native tool-use protocols (Anthropic
-- tool_use blocks, OpenAI tool_calls field, Gemini functionCall — handled
-- transparently by upstream step()).
--
-- Why a SEPARATE module rather than rewriting rpc_loop:
--   - rpc_loop is 1494 LOC of intricate state-machine code with extension
--     intercept dispatch, ohmy_pi backend split, hybrid mode, continuation
--     intent feedback, and tool gating policies. Replacing in place is
--     high-risk for users who depend on those features.
--   - This v2 loop is the MINIMUM VIABLE agent: step → dispatch → loop.
--     It demonstrates that upstream step() works end-to-end against motoko's
--     existing tool dispatcher, without committing to dropping any of
--     rpc_loop's features.
--   - Selection between rpc_loop (legacy) and run_v2 (this) is a runtime
--     decision via env var MOTOKO_AGENT_V2=1, so users can stress-test the
--     v2 path against real workloads while keeping the legacy path as the
--     default until the migration is fully validated.
--
-- What this loop deliberately DOES NOT include (vs rpc_loop):
--   - Extension intercept dispatch (ContinueWithFeedback / Accept / NoIntercept)
--   - Tool gating policy (apply_tool_policy)
--   - Tool-handle routing (route_tool_handles for compose extensions)
--   - Native vs ohmy_pi backend split
--   - Hybrid mode (extract_bash for shell-prefix shorthand)
--   - Trajectory caching, context-usage telemetry
--
-- These features can be added back incrementally if needed. The point of
-- this v2 module is to prove the upstream typed API works.
--
-- Companion to: src/core/tool_dispatch_adapter (M1), src/core/tool_catalog (M2)

module src/core/agent_loop_v2

import std/ai (step, Message, ToolCall, ToolSchema, StepResult, AIError)
import std/io (println)
import std/json (Json, jo, ja, kv, js, jnum, jb, encode)
import std/list as List (length)
import std/result (Result, Ok, Err)
import std/string (trim, startsWith, substring)
import std/string as Str (length)
import src/core/tool_catalog (tools)
import src/core/tool_contract (ToolResultEnvelope, result_to_json)
import src/core/parse (extract_bash)
import src/core/tool_dispatch_adapter (dispatch_one, tool_call_to_envelope)
import src/core/tool_runtime (backend_for)
import src/core/types (Msg, ToolBackend)
import std/option (Option, Some, None)
import src/core/ext/types (BudgetPlan, ExtCtx, ExtRuntime, ResponseInterceptDecision, FinalizeDecision, ToolPolicyDecision, ToolHandleDecision)
import src/core/ext/runtime (dispatch_response_intercept, dispatch_solver_candidate, dispatch_tool_policy, dispatch_tool_handle)

-- Strip the "openrouter/" model prefix before forwarding to upstream step().
-- OpenRouter's API rejects the prefixed name. The fork's old code stored the
-- prefix as part of the model identifier for routing-style dispatch; with
-- upstream step() the AI handler is configured at --ai time, so the prefix
-- is redundant noise that breaks the upstream API call.
func strip_provider_prefix(model: string) -> string {
  if startsWith(model, "openrouter/") then
    let prefix_len = Str.length("openrouter/") in
    let total = Str.length(model) in
    substring(model, prefix_len, total)
  else
    model
}

-- emit a JSON line to stdout for the TS env-server to forward to the TUI.
-- Same protocol as src/core/ai_compat (M-AI-CALL-STREAM-HELPER side).
func emit_json(payload: Json) -> () ! {IO} {
  println(encode(payload))
}

-- Convert motoko's [Msg] (system / user / assistant text-only) to upstream
-- [Message] (which adds tool_calls + tool_call_id fields). For the initial
-- conversation seed, all messages have empty tool_calls and tool_call_id.
func msgs_to_messages(msgs: [Msg]) -> [Message] {
  match msgs {
    [] => [],
    m :: rest => ({
      role: m.role,
      content: m.content,
      tool_calls: [],
      tool_call_id: ""
    } :: msgs_to_messages(rest))
  }
}

-- Build a [Message] entry for one assistant turn from the StepResult. Carries
-- the typed tool_calls verbatim so the model sees its own tool_call IDs on
-- the next turn (provider correlation).
func step_result_to_message(result: StepResult) -> Message {
  {
    role: "assistant",
    content: result.message.content,
    tool_calls: result.tool_calls,
    tool_call_id: ""
  }
}

-- Build a tool-role Message containing a dispatcher result. The tool_call_id
-- field is the load-bearing wire-format requirement: Anthropic / OpenAI /
-- Gemini all correlate tool_use → tool_result by this id.
func tool_result_message(call: ToolCall, content: string) -> Message {
  {
    role: "tool",
    content: content,
    tool_calls: [],
    tool_call_id: call.id
  }
}

-- Build a tool-role Message from a ToolResultEnvelope returned by an
-- extension's response-intercept (e.g. compose_check_premise). The model
-- didn't emit a tool_call for these — the extension synthesized one — so
-- we use the envelope's own tool_call_id (the extension is responsible for
-- generating one) and JSON-encode the full envelope as the message content.
func envelope_to_tool_message(envelope: ToolResultEnvelope) -> Message {
  {
    role: "tool",
    content: encode(result_to_json(envelope)),
    tool_calls: [],
    tool_call_id: envelope.tool_call_id
  }
}

-- Build the per-turn ExtCtx that motoko's extension hooks receive. Mirrors
-- mk_ext_ctx in rpc.ail but constructs from v2's typed-loop state instead
-- of the legacy AgentState shape. history_slice converts upstream Message
-- to motoko's Msg (text-only) since extensions inspect text not tool_calls.
func mk_v2_ext_ctx(
  task: string,
  step_idx: int,
  model: string,
  cwd: string,
  env_url: string,
  hybrid_tools: bool,
  budget: BudgetPlan,
  history: [Message]
) -> ExtCtx {
  let remaining = if budget.total - step_idx < 0 then 0 else budget.total - step_idx;
  {
    task: task,
    step: step_idx,
    model: model,
    cwd: cwd,
    hybrid_tools: hybrid_tools,
    budget: budget,
    mode: "v2",
    workdir: cwd,
    env_server_url: env_url,
    budget_remaining: remaining,
    history_slice: messages_to_msgs(history),
    state_key: "core:ext:v2"
  }
}

-- Convert upstream [Message] back to motoko's [Msg] for ExtCtx.history_slice.
-- Extensions inspect role + content for prose-based decisions; tool_calls
-- and tool_call_id aren't part of motoko's Msg shape, so they're dropped.
func messages_to_msgs(msgs: [Message]) -> [Msg] {
  match msgs {
    [] => [],
    m :: rest => ({ role: m.role, content: m.content } :: messages_to_msgs(rest))
  }
}

-- M7: Synthesize a BashExec ToolCall from a hybrid-mode shell command
-- extracted from the assistant's prose. The model emitted no typed
-- tool_calls (finish_reason != "tool_calls") but its content contained
-- a fenced shell block (```bash / ```sh / ```shell / ```), so we treat
-- that block as the canonical hybrid shorthand and pass it through the
-- M3-M6 dispatch pipeline as if it were a typed BashExec call.
--
-- This preserves the full M4 policy gate + M5 tool-handle routing + M6
-- backend split for hybrid commands (e.g. an extension can still Deny
-- a hybrid `rm -rf /` just as it would deny a typed call). The
-- synthetic call uses a "hybrid-step-N" id so it doesn't collide with
-- model-emitted tool_call_ids on the wire.
func synthesize_hybrid_bash_call(cmd: string, step_idx: int) -> ToolCall {
  {
    id: "hybrid-step-${show(step_idx)}",
    name: "BashExec",
    arguments: encode(jo([kv("cmd", js(cmd))]))
  }
}

-- Build a structured tool-role Message indicating the ohmy_pi delegation
-- pathway is not yet wired in v2. M6 plumbs split_by_backend through but
-- defers the inbox-based wait_for_tool_results to a follow-up — for now
-- delegated calls return this clear, recoverable error so the model can
-- adapt (e.g. retry with a non-delegated argument shape, or surface that
-- ohmy_pi was selected but unavailable).
func delegated_deferred_message(call: ToolCall) -> Message {
  let payload = encode(jo([
    kv("error", jb(true)),
    kv("delegated_backend_not_wired", jb(true)),
    kv("tool", js(call.name)),
    kv("note", js("v2 split_by_backend selected Delegated; the inbox-based ohmy_pi wait is deferred to a follow-up milestone. Re-run with settings.ohmy_pi=false or use a tool that resolves to the Native backend."))
  ]));
  {
    role: "tool",
    content: payload,
    tool_calls: [],
    tool_call_id: call.id
  }
}

-- Build a denial tool-role Message for a ToolCall the policy gate rejected.
-- The model sees a structured `{denied_by_policy, reason, tool}` JSON in the
-- tool result, correlated by tool_call_id, so it can correct course on the
-- next turn without ambiguity.
func policy_denied_message(call: ToolCall, reason: string) -> Message {
  let denial_payload = encode(jo([
    kv("error", jb(true)),
    kv("denied_by_policy", jb(true)),
    kv("tool", js(call.name)),
    kv("reason", js(reason))
  ]));
  {
    role: "tool",
    content: denial_payload,
    tool_calls: [],
    tool_call_id: call.id
  }
}

-- Dispatch each ToolCall through the full per-call rpc_loop pipeline:
--   1. Convert ToolCall → ToolCallEnvelope (M1 adapter)
--   2. M4 — dispatch_tool_policy: Allow/Deny/NoOpinion
--   3. M5 — dispatch_tool_handle: extension may handle the tool directly
--      (Handled returning ToolResultEnvelope) or Delegate to native
--   4. M6 — backend split: native vs ohmy_pi via backend_for
--   5. dispatch_one for native path; deferred-error envelope for delegated
--
-- Per-call branching:
--   Deny     → tool-role denial Message; skip handle + dispatch
--   Allow/NoOpinion + Handled → tool-role Message from extension's envelope;
--                               skip dispatch_one
--   Allow/NoOpinion + Delegate + backend_for==Native    → tool-role Message
--                                                          from dispatch_one
--   Allow/NoOpinion + Delegate + backend_for==Delegated → tool-role
--                                                          delegated_deferred_message
--                                                          (full ohmy_pi inbox
--                                                          wait deferred to
--                                                          follow-up M6.5)
--
-- Effect row: {FS, Process, IO, Clock} (M4) + {AI, Env, Net, SharedMem,
-- Stream} from on_tool_handle's declared effects = full agent stack.
func dispatch_calls(
  rt: ExtRuntime,
  ctx: ExtCtx,
  calls: [ToolCall],
  workdir: string,
  step_idx: int,
  stream_id: string,
  ohmy_pi: bool
) -> [Message] ! {FS, Process, IO, Clock, AI, Env, Net, SharedMem, Stream} {
  match calls {
    [] => [],
    call :: rest => {
      let envelope = tool_call_to_envelope(call);
      let policy = dispatch_tool_policy(rt, ctx, envelope);
      match policy {
        Deny(reason) => {
          let _ = emit_json(jo([
            kv("type", js("native_tool_denied")),
            kv("step", jnum(_int_to_float(step_idx))),
            kv("stream_id", js(stream_id)),
            kv("tool", js(call.name)),
            kv("id", js(call.id)),
            kv("reason", js(reason))
          ]));
          let denial_msg = policy_denied_message(call, reason);
          denial_msg :: dispatch_calls(rt, ctx, rest, workdir, step_idx, stream_id, ohmy_pi)
        },
        _ => {
          -- M5: ask extensions whether they want to handle this tool directly
          -- (e.g. compose's `Compose` tool dispatches its own pipeline).
          let handle_decision = dispatch_tool_handle(rt, ctx, envelope);
          match handle_decision {
            Handled(result_env) => {
              let _ = emit_json(jo([
                kv("type", js("ext_tool_handled")),
                kv("step", jnum(_int_to_float(step_idx))),
                kv("stream_id", js(stream_id)),
                kv("tool", js(call.name)),
                kv("id", js(call.id)),
                kv("exit_code", jnum(_int_to_float(result_env.exit_code)))
              ]));
              -- Use the call.id (model's typed tool_call_id) instead of the
              -- envelope's id for the tool-role Message correlation —
              -- providers correlate by the model-emitted id, not the
              -- extension-internal id.
              let handled_msg: Message = {
                role: "tool",
                content: encode(result_to_json(result_env)),
                tool_calls: [],
                tool_call_id: call.id
              };
              handled_msg :: dispatch_calls(rt, ctx, rest, workdir, step_idx, stream_id, ohmy_pi)
            },
            Delegate => {
              -- M6: backend split — Native goes through dispatch_one as
              -- before; Delegated returns a structured deferred-error tool
              -- result so the model can adapt. Full ohmy_pi inbox wait
              -- migration is a follow-up (M6.5) — see delegated_deferred_message.
              let backend = backend_for(envelope, ohmy_pi);
              match backend {
                Delegated => {
                  let _ = emit_json(jo([
                    kv("type", js("delegated_tool_deferred")),
                    kv("step", jnum(_int_to_float(step_idx))),
                    kv("stream_id", js(stream_id)),
                    kv("tool", js(call.name)),
                    kv("id", js(call.id))
                  ]));
                  let deferred_msg = delegated_deferred_message(call);
                  deferred_msg :: dispatch_calls(rt, ctx, rest, workdir, step_idx, stream_id, ohmy_pi)
                },
                Native => {
                  let _ = emit_json(jo([
                    kv("type", js("native_tool_calls")),
                    kv("step", jnum(_int_to_float(step_idx))),
                    kv("stream_id", js(stream_id)),
                    kv("tool", js(call.name)),
                    kv("id", js(call.id))
                  ]));
                  let result_content = dispatch_one(workdir, call);
                  let _ = emit_json(jo([
                    kv("type", js("native_tool_results")),
                    kv("step", jnum(_int_to_float(step_idx))),
                    kv("stream_id", js(stream_id)),
                    kv("id", js(call.id)),
                    kv("result", js(result_content))
                  ]));
                  let msg = tool_result_message(call, result_content);
                  msg :: dispatch_calls(rt, ctx, rest, workdir, step_idx, stream_id, ohmy_pi)
                }
              }
            }
          }
        }
      }
    }
  }
}

-- The v2 loop. Iterates until the model returns finish_reason != "tool_calls"
-- (and any solver-candidate hooks accept the result) or step_budget hits zero.
-- Returns the final messages list.
--
-- M3 wiring: between step() and tool dispatch, fires extension hooks at the
-- two existing decision points motoko's rpc_loop uses (DP1 from the design
-- doc). NoIntercept / NoDecision are no-ops; the typed-step protocol means
-- prose-only responses unambiguously stop the loop (no continuation-intent
-- heuristic needed).
func loop_v2(
  rt: ExtRuntime,
  task: string,
  env_url: string,
  hybrid_tools: bool,
  budget: BudgetPlan,
  model: string,
  msgs: [Message],
  workdir: string,
  step_idx: int,
  step_budget: int,
  ohmy_pi: bool
) -> Result[[Message], AIError] ! {AI, FS, Process, IO, Env, Net, SharedMem, Clock, Stream} {
  if step_budget <= 0 then Err({
    code: "Internal",
    message: "v2 loop: step budget exhausted",
    retryable: false
  })
  else {
    let stream_id = "step-${show(step_idx)}";
    let _ = emit_json(jo([
      kv("type", js("thinking_stream_start")),
      kv("step", jnum(_int_to_float(step_idx))),
      kv("stream_id", js(stream_id)),
      kv("model", js(model))
    ]));
    match step(model, msgs, tools()) {
      Err(e) => {
        let _ = emit_json(jo([
          kv("type", js("thinking_stream_end")),
          kv("step", jnum(_int_to_float(step_idx))),
          kv("stream_id", js(stream_id)),
          kv("status", js("errored"))
        ]));
        Err(e)
      },
      Ok(result) => {
        let n_calls = List.length(result.tool_calls);
        let _ = emit_json(jo([
          kv("type", js("thinking_delta")),
          kv("step", jnum(_int_to_float(step_idx))),
          kv("stream_id", js(stream_id)),
          kv("seq", jnum(1.0)),
          kv("text_delta", js(result.message.content))
        ]));
        let _ = emit_json(jo([
          kv("type", js("thinking_stream_end")),
          kv("step", jnum(_int_to_float(step_idx))),
          kv("stream_id", js(stream_id)),
          kv("status", js("completed"))
        ]));
        let _ = emit_json(jo([
          kv("type", js("thinking")),
          kv("step", jnum(_int_to_float(step_idx))),
          kv("text", js(result.message.content)),
          kv("finish_reason", js(result.finish_reason)),
          kv("tool_calls", jnum(_int_to_float(n_calls)))
        ]));

        let assistant_msg = step_result_to_message(result);
        let msgs_with_assistant = msgs ++ [assistant_msg];
        let ctx = mk_v2_ext_ctx(task, step_idx, model, workdir, env_url, hybrid_tools, budget, msgs_with_assistant);

        -- M3 DP1a: response-intercept hook. Extensions can synthesize a
        -- tool result from the model's prose (e.g. compose_check_premise)
        -- without the model having emitted a typed tool_call. When this
        -- fires, we treat the synthesized envelope as a tool result —
        -- append it as a tool-role Message and recurse for the next step.
        match dispatch_response_intercept(rt, ctx, result.message.content) {
          InterceptHandled(envelope) => {
            let _ = emit_json(jo([
              kv("type", js("ext_intercept_handled")),
              kv("step", jnum(_int_to_float(step_idx))),
              kv("tool", js(envelope.tool)),
              kv("exit_code", jnum(_int_to_float(envelope.exit_code)))
            ]));
            let tool_msg = envelope_to_tool_message(envelope);
            let next_msgs = msgs_with_assistant ++ [tool_msg];
            loop_v2(rt, task, env_url, hybrid_tools, budget, model, next_msgs, workdir, step_idx + 1, step_budget - 1, ohmy_pi)
          },
          NoIntercept => {
            if result.finish_reason != "tool_calls" then {
              -- M7 hybrid mode: when prose contains a fenced shell block
              -- and hybrid_tools=true, synthesize a BashExec ToolCall and
              -- run it through the same M3-M6 dispatch pipeline as a typed
              -- tool_call. Skips solver_candidate (the prose isn't a final
              -- answer — it's a shell shorthand the model wants executed).
              let hybrid_attempt: Option[string] = if hybrid_tools then extract_bash(result.message.content) else None;
              match hybrid_attempt {
                Some(cmd) => {
                  let _ = emit_json(jo([
                    kv("type", js("hybrid_bash_extracted")),
                    kv("step", jnum(_int_to_float(step_idx))),
                    kv("cmd", js(cmd))
                  ]));
                  let synth_call = synthesize_hybrid_bash_call(cmd, step_idx);
                  let tool_msgs = dispatch_calls(rt, ctx, [synth_call], workdir, step_idx, stream_id, ohmy_pi);
                  let next_msgs = msgs_with_assistant ++ tool_msgs;
                  loop_v2(rt, task, env_url, hybrid_tools, budget, model, next_msgs, workdir, step_idx + 1, step_budget - 1, ohmy_pi)
                },
                None => {
              -- M3 DP1b: when the model emits prose without tool_calls, give
              -- extensions a final chance to validate / re-prompt via
              -- dispatch_solver_candidate. Three outcomes:
              --   Accept(out)              => emit done with extension's output
              --   ContinueWithFeedback(fb) => inject a user-role feedback msg, recurse
              --   NoDecision               => emit done with the model's own content
              match dispatch_solver_candidate(rt, ctx, result.message.content) {
                Accept(output) => {
                  let _ = emit_json(jo([
                    kv("type", js("done")),
                    kv("step", jnum(_int_to_float(step_idx))),
                    kv("output", js(output)),
                    kv("source", js("ext_solver_accept"))
                  ]));
                  Ok(msgs_with_assistant)
                },
                ContinueWithFeedback(feedback) => {
                  let _ = emit_json(jo([
                    kv("type", js("ext_solver_feedback")),
                    kv("step", jnum(_int_to_float(step_idx))),
                    kv("feedback", js(feedback))
                  ]));
                  let feedback_msg: Message = {
                    role: "user",
                    content: feedback,
                    tool_calls: [],
                    tool_call_id: ""
                  };
                  let next_msgs = msgs_with_assistant ++ [feedback_msg];
                  loop_v2(rt, task, env_url, hybrid_tools, budget, model, next_msgs, workdir, step_idx + 1, step_budget - 1, ohmy_pi)
                },
                NoDecision => {
                  let _ = emit_json(jo([
                    kv("type", js("done")),
                    kv("step", jnum(_int_to_float(step_idx))),
                    kv("output", js(result.message.content))
                  ]));
                  Ok(msgs_with_assistant)
                }
              }
                }
              }
            }
            else {
              -- finish_reason = "tool_calls" → run M4 policy gate per-call
              -- inside dispatch_calls; allowed dispatch via dispatch_one,
              -- denied become tool-role denial messages
              let tool_msgs = dispatch_calls(rt, ctx, result.tool_calls, workdir, step_idx, stream_id, ohmy_pi);
              let next_msgs = msgs_with_assistant ++ tool_msgs;
              loop_v2(rt, task, env_url, hybrid_tools, budget, model, next_msgs, workdir, step_idx + 1, step_budget - 1, ohmy_pi)
            }
          }
        }
      }
    }
  }
}

-- Public entry point. Takes motoko's [Msg] (the v1 shape used by rpc.ail)
-- and translates to upstream [Message], runs the loop, returns the final
-- conversation.
--
-- M3 signature: rpc.ail's run_with_config now passes ExtRuntime, the task
-- string, env_server_url, hybrid_tools flag, and BudgetPlan so v2 can fire
-- the extension-intercept and solver-candidate hooks at the same decision
-- points rpc_loop fires them today.
--
-- M6 signature: ohmy_pi flag added so v2's per-call backend split mirrors
-- rpc.ail's settings.ohmy_pi semantics. ohmy_pi=false (the default for
-- non-pi deployments) keeps everything on the Native backend; ohmy_pi=true
-- routes Read/Write/Edit/Search and shell calls flagged by
-- needs_delegation_for_process to the Delegated path. The full inbox-based
-- delegation wait is deferred — Delegated calls return a structured
-- delegated_deferred_message tool result for now (M6.5 follow-up).
--
-- step_budget defaults to 8 if caller passes <= 0 (mirrors upstream
-- runTools' typical default).
export func run_v2(
  rt: ExtRuntime,
  task: string,
  env_url: string,
  hybrid_tools: bool,
  budget: BudgetPlan,
  model: string,
  initial_msgs: [Msg],
  workdir: string,
  step_budget: int,
  ohmy_pi: bool
) -> Result[[Message], AIError] ! {AI, FS, Process, IO, Env, Net, SharedMem, Clock, Stream} {
  let budget_steps = if step_budget <= 0 then 8 else step_budget;
  let messages = msgs_to_messages(initial_msgs);
  let resolved_model = strip_provider_prefix(model);
  loop_v2(rt, task, env_url, hybrid_tools, budget, resolved_model, messages, workdir, 0, budget_steps, ohmy_pi)
}
