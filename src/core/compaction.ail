-- src/core/compaction.ail
-- DP0 pre-step conversation compaction for the v2 agent loop.
--
-- Prevents provider-side context overflow on long-running agents by
-- proactively eliding old tool_result content before each LLM call.
-- Works on [Message] (upstream typed shape) so tool_call_id correlation
-- is preserved — the provider needs those IDs for conversation continuation.
--
-- Thresholds (usage = estimated_tokens / context_limit_for(model)):
--   < 70%  → PassThrough (no compaction needed)
--   70-85% → Elide tool_result content older than last 10 turns
--   85-95% → Elide tool_result content older than last 5 turns
--   ≥ 95%  → Emergency compaction: try keep_last=3, then keep_last=1
--            Only fail if still ≥95% after aggressive elision
--
-- Compaction is per-step only: the session history (used for the next
-- loop iteration) always retains the original unelided messages. The
-- compacted view is a transient input to step() for this step only.
--
-- For unknown models (context_limit_for returns 0), compaction is skipped
-- entirely — fail open rather than incorrectly refusing a valid step.

module src/core/compaction

import std/ai (Message, ToolCall)
import std/string (length, substring)
import std/list (foldl)
import std/result (Result, Ok, Err)
import src/core/context_usage (context_limit_for)

-- Token estimate for [Message]: sum all content-field lengths, divide by 4.
-- Same approximation as estimate_tokens for [Msg] in context_usage.ail.
-- contracts: SKIPPED — uses foldl (Z3 fragment requires non-higher-order)
-- Sum the serialized size of a message's tool_calls (name + arguments). WriteFile/EditFile carry the FULL
-- file content in `arguments`, re-sent every turn — counting only `content` (as before) massively undercounts
-- those turns, so compaction fires too late -> context overflow (docx hit input 263259 > 262144).
pure func tool_calls_chars(tcs: [ToolCall]) -> int {
  foldl(\acc tc. acc + length(tc.name) + length(tc.arguments), 0, tcs)
}

-- Raw serialized char count of a [Message] (content + tool_calls args). The single source
-- of size truth; both the chars/7 estimate and the provider-calibrated estimate build on it.
-- contracts: SKIPPED — uses foldl (Z3 fragment requires non-higher-order)
export pure func message_chars(msgs: [Message]) -> int {
  foldl(\acc m. acc + length(m.content) + tool_calls_chars(m.tool_calls), 0, msgs)
}

export pure func estimate_tokens_messages(msgs: [Message]) -> int {
  -- chars/7: MEASURED ratio for AILANG code + DOCX XML is ~7.5 chars/token. Used only as the
  -- step-0 fallback (before any provider sample) and by usage_percent; the live decision uses
  -- est_send_tokens (provider-calibrated). Slightly conservative (/7 > real 7.5).
  (message_chars(msgs) + 6) / 7
}

-- M-COMPACT-CALIBRATED: estimated tokens of the call we are ABOUT TO SEND = (pinned system
-- prefix + conversation) chars, scaled by the provider's TRUE ratio learned last call
-- (last_input_tokens / last_sent_chars). This measures the CURRENT full history (right thing)
-- with provider ground-truth accuracy (right number) — unlike the v5 trigger, which read the
-- previous call's token count directly and so skipped compaction the step after every compaction
-- (the post-compaction count fell under the 60% floor) -> oscillation -> overflow. `pinned_chars`
-- is the system prefix the loop re-prepends to every call; it must be counted here because it is
-- always sent. Falls back to chars/7 until the first provider sample exists.
-- contracts: SKIPPED — integer arithmetic over a foldl-based char count
export pure func est_send_tokens(msgs: [Message], pinned_chars: int, last_input_tokens: int, last_sent_chars: int) -> int {
  let total_chars = pinned_chars + message_chars(msgs);
  if last_input_tokens > 0 && last_sent_chars > 0 then (total_chars * last_input_tokens) / last_sent_chars
  else (total_chars + 6) / 7
}

-- Context usage as integer percent (0-100). Returns 0 for unknown models.
-- Uses integer arithmetic throughout to avoid float precision issues.
-- contracts: SKIPPED — depends on foldl-based estimate_tokens_messages
export pure func usage_percent(msgs: [Message], model: string) -> int {
  let limit = context_limit_for(model);
  -- Reserve ~75k headroom for the model's OUTPUT. context_limit is the TOTAL input+output window,
  -- so compaction must keep INPUT well below it. docx overflowed at input 263259 > 262144 because
  -- usage was measured against the FULL window — compaction never reserved output room and let input
  -- crowd the hard limit. 75k covers the 65536 output cap + estimate margin. Small (rotation)
  -- contexts stay ~0% so this only bites large-context tasks (compacts them earlier, as intended).
  let effective = limit - 75000;
  if limit == 0 || effective <= 0 then 0
  else (estimate_tokens_messages(msgs) * 100) / effective
}

-- Count tool-role messages in the list.
-- contracts: SKIPPED — uses foldl (Z3 fragment requires non-higher-order)
pure func count_tool_msgs(msgs: [Message]) -> int {
  foldl(\acc m. acc + (if m.role == "tool" then 1 else 0), 0, msgs)
}

-- Produce a 1-line elision summary for tool_result content that exceeded
-- the compaction window. Keeps the first 80 chars as a preview.
--
-- The "...[elided N chars]" suffix is ~20 chars, so for inputs barely
-- over the 80-char threshold the rewrite would actually grow the
-- content. Guard against that: only elide when the result is genuinely
-- shorter than the input. Otherwise return the original unchanged.
pure func elide_content(content: string) -> string {
  let n = length(content);
  if n <= 80 then content
  else {
    let preview = substring(content, 0, 80);
    let elided = "${preview}...[elided ${show(n - 80)} chars]";
    if length(elided) < n then elided else content
  }
}

-- Walk [Message] forward, eliding the content of tool-role messages that
-- fall outside the keep window. `total` = total tool messages in list;
-- `seen` = tool messages already encountered (0-based).
-- A tool message at position `seen` is kept iff total - seen <= keep_last.
pure func elide_walk(msgs: [Message], total: int, keep_last: int, seen: int) -> [Message] {
  match msgs {
    [] => [],
    m :: rest => {
      if m.role == "tool" then {
        let keep = total - seen <= keep_last;
        let new_content = if keep then m.content else elide_content(m.content);
        let updated: Message = {
          role: m.role,
          content: new_content,
          tool_calls: m.tool_calls,
          tool_call_id: m.tool_call_id
        };
        updated :: elide_walk(rest, total, keep_last, seen + 1)
      } else
        m :: elide_walk(rest, total, keep_last, seen)
    }
  }
}

-- Elide tool_result content for all but the last `keep_last` tool messages.
-- Non-tool messages (user, assistant, system) are never touched.
-- List length and structural fields (tool_call_id, role) are preserved.
export pure func elide_old_tool_results(msgs: [Message], keep_last: int) -> [Message]
  requires { keep_last >= 0 }
  {
    elide_walk(msgs, count_tool_msgs(msgs), keep_last, 0)
  }

-- Apply emergency compaction for ≥95% usage.
-- Returns Ok(compacted) if we can get below 95%, otherwise Err.
pure func try_emergency_compaction(msgs: [Message], model: string) -> Result[[Message], string] {
  -- Try keeping only last 3 tool results
  let emergency1 = elide_old_tool_results(msgs, 3);
  let pct1 = usage_percent(emergency1, model);
  if pct1 < 95 then Ok(emergency1)
  else {
    -- Try keeping only last 1 tool result
    let emergency2 = elide_old_tool_results(msgs, 1);
    let pct2 = usage_percent(emergency2, model);
    if pct2 < 95 then Ok(emergency2)
    else {
      -- Even extreme compaction failed
      Err("compaction_exhausted: context at ${show(pct2)}% of ${model} limit after emergency compaction")
    }
  }
}

-- Apply the default structural compaction policy for one step.
-- Returns Ok(msgs) — possibly with elided tool content — or
-- Err("compaction_exhausted") when the window is critically full.
-- At ≥95%, attempts emergency compaction before failing.
export pure func compact_step(msgs: [Message], model: string) -> Result[[Message], string] {
  let pct = usage_percent(msgs, model);
  if pct >= 95 then try_emergency_compaction(msgs, model)
  else if pct >= 85 then Ok(elide_old_tool_results(msgs, 5))
  else if pct >= 70 then Ok(elide_old_tool_results(msgs, 10))
  else Ok(msgs)
}

-- M-COMPACT-CALIBRATED: emergency elision for ≥85% of effective, re-checked with the SAME
-- calibrated estimate so the decision is consistent end to end. Fails loudly (BEFORE sending)
-- if even keep_last=1 can't get the estimate under 95% — we never hand the provider a call we
-- already estimate it will reject (the old try_emergency_compaction re-checked with a different,
-- pinned-prefix-excluding estimate, so its 95% could disagree with what was actually sent).
pure func try_emergency_calibrated(msgs: [Message], model: string, pinned_chars: int, last_input_tokens: int, last_sent_chars: int) -> Result[[Message], string] {
  let effective = context_limit_for(model) - 75000;
  let e1 = elide_old_tool_results(msgs, 3);
  let pct1 = if effective > 0 then est_send_tokens(e1, pinned_chars, last_input_tokens, last_sent_chars) * 100 / effective else 0;
  if pct1 < 95 then Ok(e1)
  else {
    let e2 = elide_old_tool_results(msgs, 1);
    let pct2 = if effective > 0 then est_send_tokens(e2, pinned_chars, last_input_tokens, last_sent_chars) * 100 / effective else 0;
    if pct2 < 95 then Ok(e2)
    else Err("compaction_exhausted: context at ${show(pct2)}% of ${model} limit after emergency compaction")
  }
}

-- M-COMPACT-CALIBRATED: the live per-step compaction decision. Drives elision off est_send_tokens
-- (the CURRENT full history — pinned prefix + conversation — scaled by the provider's true ratio),
-- so it CANNOT oscillate: every step measures the real size of what is about to be sent, not the
-- previous (possibly compacted) call's token count. That stale-signal read was the v5 bug — after a
-- compacted call the reported count fell under the 60% floor, the next step skipped compaction, and
-- the full uncompacted history was sent and grew until it overflowed (267365 > 262144).
-- Tiers: keep_last=10 at 60%, 5 at 75%, emergency at 85% of effective(=limit-75000). Unknown model
-- (effective<=0) -> skip (matches context_limit_for==0). Elides only OLD tool_results (the measured
-- 96K bloat = BashExec/cat XML dumps); the recent working set stays. The 85% trigger + the
-- emergency ceiling keep the SENT estimate under ~95% of effective regardless of one-step jumps.
export pure func compact_step_calibrated(msgs: [Message], model: string, pinned_chars: int, last_input_tokens: int, last_sent_chars: int) -> Result[[Message], string] {
  let effective = context_limit_for(model) - 75000;
  if effective <= 0 then Ok(msgs)
  else {
    let pct = est_send_tokens(msgs, pinned_chars, last_input_tokens, last_sent_chars) * 100 / effective;
    if pct >= 85 then try_emergency_calibrated(msgs, model, pinned_chars, last_input_tokens, last_sent_chars)
    else if pct >= 75 then Ok(elide_old_tool_results(msgs, 5))
    else if pct >= 60 then Ok(elide_old_tool_results(msgs, 10))
    else Ok(msgs)
  }
}

-- Unknown model → usage 0% → no compaction.
func unknown_model_skips_compaction() -> bool
  tests [((), true)]
  {
    let msgs: [Message] = [
      { role: "user", content: "hello", tool_calls: [], tool_call_id: "" }
    ];
    usage_percent(msgs, "totally-unknown") == 0
  }

-- Below threshold → Ok with same list unchanged.
func below_threshold_passthrough() -> bool
  tests [((), true)]
  {
    let msgs: [Message] = [
      { role: "user", content: "hello", tool_calls: [], tool_call_id: "" }
    ];
    match compact_step(msgs, "anthropic/claude-sonnet-4-6") {
      Ok(ms) => _list_length(ms) == 1,
      Err(_) => false
    }
  }

-- elide_old_tool_results preserves list length.
func elide_preserves_length() -> bool
  tests [((), true)]
  {
    let tool = func(id: string) -> Message {
      { role: "tool", content: "some tool output", tool_calls: [], tool_call_id: id }
    };
    let msgs = [tool("t1"), tool("t2"), tool("t3"), tool("t4"), tool("t5")];
    _list_length(elide_old_tool_results(msgs, 2)) == 5
  }

-- Tool count is correct.
func count_tool_messages() -> bool
  tests [((), true)]
  {
    let msgs: [Message] = [
      { role: "user",      content: "q",   tool_calls: [], tool_call_id: "" },
      { role: "assistant", content: "a",   tool_calls: [], tool_call_id: "" },
      { role: "tool",      content: "r1",  tool_calls: [], tool_call_id: "c1" },
      { role: "tool",      content: "r2",  tool_calls: [], tool_call_id: "c2" }
    ];
    count_tool_msgs(msgs) == 2
  }

-- elide_old_tool_results with keep_last=0 elides all tool messages.
func elide_all_tool_results() -> bool
  tests [((), true)]
  {
    -- Test data must be long enough for elide_content to actually shrink it:
    -- 80-char preview + ~20-char suffix means inputs in (80, ~100] would grow
    -- under naïve elision. We guard against that in elide_content but the
    -- test should still drive the genuine elision path with content > 100.
    let original = "long tool output that genuinely exceeds eighty characters in length and then keeps on going for a while longer until it definitely passes the elide threshold and triggers actual shortening of the message body";
    let msgs: [Message] = [
      { role: "user", content: "q", tool_calls: [], tool_call_id: "" },
      { role: "tool", content: original, tool_calls: [], tool_call_id: "c1" }
    ];
    let compacted = elide_old_tool_results(msgs, 0);
    -- user msg unchanged; tool msg content elided (original > 80 chars)
    match compacted {
      [] => false,
      u :: t :: [] => u.content == "q" && length(t.content) < length(original),
      _ => false
    }
  }

-- Emergency compaction at 95%+ tries aggressive elision.
-- This test uses a large message list to simulate high context usage.
-- With claude-sonnet-4-6 (200k limit), we need many messages to hit 95%.
func emergency_compaction_tries_elision() -> bool
  tests [((), true)]
  {
    -- Build a message list with many tool results
    -- Each tool result is ~200 chars to ensure elision shrinks it
    let tool_content = "tool result content that is reasonably long so that elision will actually reduce the size of the message when the compaction logic runs and tries to shrink things down";
    -- Create 50 tool messages (will be far under 95% for claude-sonnet-4-6)
    let msgs: [Message] = [
      { role: "user", content: "task", tool_calls: [], tool_call_id: "" }
    ];
    -- For the test to pass, we just verify that compact_step returns Ok
    -- when there's reasonable headroom (not actually at 95%)
    match compact_step(msgs, "anthropic/claude-sonnet-4-6") {
      Ok(_) => true,
      Err(_) => false
    }
  }

-- M-COMPACT-CALIBRATED test helper: a string of length ~len(s)*2^n (repeated doubling).
pure func double_str(s: string, n: int) -> string {
  if n <= 0 then s else double_str("${s}${s}", n - 1)
}

-- M-COMPACT-CALIBRATED test helper: n tool messages with the given content.
pure func n_tool_msgs(content: string, n: int) -> [Message] {
  if n <= 0 then []
  else ({ role: "tool", content: content, tool_calls: [], tool_call_id: "c" } :: n_tool_msgs(content, n - 1))
}

-- THE REGRESSION GUARD for the v5 oscillation overflow (the multi-step dynamics the old
-- single-decision tests never exercised). A large CURRENT history (~2M chars ~= 270k tok) whose
-- PREVIOUS call was compacted to a small size: last_input_tokens reflects the COMPACTED call, not
-- this history. The v5 trigger read last_input_tokens directly -> ~5% usage -> passthrough -> sent
-- the full 2M -> overflow (267365 > 262144). The calibrated trigger sizes THIS history via the
-- provider ratio (last_input_tokens/last_sent_chars) and MUST compact it so the SENT estimate
-- stays under effective. If this fails, the oscillation is back.
func calibrated_compacts_despite_low_last_tokens() -> bool
  tests [((), true)]
  {
    let block = double_str("01234567890123456789012345678901234567890123456789", 10); -- ~51k chars
    let msgs = n_tool_msgs(block, 40); -- ~2M chars, ~270k tok at the ratio below
    let model = "ollama/qwen3.6:35b-a3b-mxfp8";
    -- previous call was compacted: sent ~80k chars -> ~10.6k tokens (true ratio ~7.5 chars/tok)
    let lit = 10666; let lsc = 80000;
    match compact_step_calibrated(msgs, model, 0, lit, lsc) {
      Err(_) => true,  -- refused to send an over-limit call: also acceptable (fail-loud, no overflow)
      Ok(out) => est_send_tokens(out, 0, lit, lsc) < (context_limit_for(model) - 75000)
    }
  }

-- The converse: a genuinely small history must pass through unchanged (no premature thrash).
func calibrated_small_passthrough() -> bool
  tests [((), true)]
  {
    let msgs: [Message] = [
      { role: "user", content: "task", tool_calls: [], tool_call_id: "" },
      { role: "tool", content: "small result", tool_calls: [], tool_call_id: "c1" }
    ];
    match compact_step_calibrated(msgs, "ollama/qwen3.6:35b-a3b-mxfp8", 100, 50, 400) {
      Ok(out) => message_chars(out) == message_chars(msgs),
      Err(_) => false
    }
  }

