-- scripts/smoke_compaction_e2e.ail
--
-- Real-provider e2e for the v0.18.11 compaction round-trip fix
-- (Arni's PR #16 422 bug). Sends the EXACT wire shape that motoko's
-- compacted output produces — system + user + assistant-with-tool_calls
-- + tool-with-tool_call_id — and asserts the provider accepts it.
--
-- Pre-fix shape (tool_call_id="") would 422 on strict providers (DeepInfra
-- via OpenRouter — Arni's exact failing case).
-- Post-fix shape (tool_call_id="call_abc123") is accepted.
--
-- Run (requires OPENROUTER_API_KEY):
--   ailang run --caps AI,IO --ai openrouter/auto \
--     --entry main scripts/smoke_compaction_e2e.ail
--
-- Cost: one tiny step against openrouter/auto. ~$0.001-0.005.
-- Pass = "✓ provider accepted ... finish_reason: stop, content: ok"

module scripts/smoke_compaction_e2e

import std/io (println)
import std/ai (Message, ToolCall, ToolSchema, step)
import std/result (Result, Ok, Err)

export func main() -> () ! {AI, IO} = {
  let tc: ToolCall = {
    id: "call_abc123",
    name: "ReadFile",
    arguments: "{\"path\":\"src/foo.ail\"}"
  };
  let read_file_tool: ToolSchema = {
    name: "ReadFile",
    description: "Read a file",
    parameters: "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"}},\"required\":[\"path\"]}"
  };

  -- Mirror motoko_agent's post-tool-dispatch [Message] sequence: a user
  -- prompt, an assistant emitting one tool_call, a tool result with the
  -- matching tool_call_id, and a follow-up nudging the model to reply.
  let msgs: [Message] = [
    { role: "user",      content: "Show me src/foo.ail",
      tool_calls: [],   tool_call_id: "" },
    { role: "assistant", content: "",
      tool_calls: [tc], tool_call_id: "" },
    { role: "tool",      content: "module foo\nexport func main() = ()",
      tool_calls: [],   tool_call_id: "call_abc123" },
    { role: "user",      content: "Thanks. Reply with just 'ok'.",
      tool_calls: [],   tool_call_id: "" }
  ];

  println("calling openrouter/auto with tool_call_id=call_abc123 ...");
  match step("openrouter/auto", msgs, [read_file_tool]) {
    Ok(result) => {
      println("✓ provider accepted the message shape (no 422)");
      println("  finish_reason: ${result.finish_reason}");
      println("  content: ${result.message.content}")
    },
    Err(err) => {
      println("✗ provider error — fix did NOT work or unrelated failure:");
      println("  code: ${err.code}");
      println("  message: ${err.message}")
    }
  }
}
