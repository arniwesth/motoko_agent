-- scripts/smoke_v2_cost_budget.ail
--
-- Layer-1 smoke for M-MOTOKO-COST-BUDGET (commit 7488b57).
--
-- The load-bearing claim is the formula in step_cost_millicents and the
-- threshold logic at 50/75/90% cap. step_cost_millicents is `pure func`
-- (not exported), so this smoke re-implements the same formula and
-- locks in expected outputs. If the production formula changes, the
-- copy here drifts out of sync and a follow-up test should catch it.
--
-- Covers:
--   1. Math: input/output token costs combine correctly per the millicent rates
--   2. Fail-open: rates of zero return zero cost (unmetered/Ollama path)
--   3. Disabled: max cap of zero behaves as no cap
--   4. Threshold pct computation matches motoko's loop logic
--   5. Threshold-fired-once accumulator semantics
--
-- Out of scope (filed as follow-ups):
--   - Live integration: emit_json side-effect of cost_exhausted/cost_warning
--     under a real run_v2 loop. Would need a stub-step fixture or a real
--     LLM call with a tiny cap.
--   - Config loader: max_cost_usd_cents → max_cost_millicents (×1000)
--     conversion. Exported via load_agent but no test fixture for
--     RuntimeConfig today.
--
-- Run:
--   ailang run --caps IO --entry main scripts/smoke_v2_cost_budget.ail

module scripts/smoke_v2_cost_budget

import std/io (println)

-- Re-implements the formula from src/core/agent_loop_v2.ail line 553
-- (step_cost_millicents). Locked here as a regression check.
pure func step_cost(input_tokens: int, output_tokens: int,
                    input_rate_millicents: int, output_rate_millicents: int) -> int {
  (input_tokens * input_rate_millicents +
   output_tokens * output_rate_millicents) / 1000000
}

-- Re-implements the threshold computation from line 675 (loop_v2).
-- pct = (total_cost * 100) / max_cost; new threshold fires only when
-- pct exceeds the highest already-fired threshold.
pure func threshold_fires_at(prev_warned: int, total_cost: int, max_cost: int) -> int {
  if max_cost <= 0 then prev_warned
  else {
    let pct = (total_cost * 100) / max_cost;
    if pct >= 90 && prev_warned < 90 then 90
    else if pct >= 75 && prev_warned < 75 then 75
    else if pct >= 50 && prev_warned < 50 then 50
    else prev_warned
  }
}

func report(name: string, ok: bool) -> () ! {IO} {
  if ok then println("  ✓ ${name}")
  else println("  ✗ ${name}")
}

export func main() -> () ! {IO} = {
  println("=== smoke_v2_cost_budget ===");

  -- 1. GLM-5 rates: input=60000 millicents/1M, output=208000 millicents/1M
  --    1M input + 1M output → 60000 + 208000 = 268000 millicents = 26.8 cents
  let glm5_million_each = step_cost(1000000, 1000000, 60000, 208000);
  report("GLM-5 1M-tokens-each = 268000 millicents (~26.8 cents)",
    glm5_million_each == 268000);

  -- 2. Linearity: half tokens → half cost
  let glm5_half = step_cost(500000, 500000, 60000, 208000);
  report("GLM-5 500k-each = 134000 millicents (linear)",
    glm5_half == 134000);

  -- 3. Tiny step rounds correctly: 100 input + 50 output at GLM-5 rates
  --    100 × 60_000 + 50 × 208_000 = 6_000_000 + 10_400_000 = 16_400_000
  --    16_400_000 / 1_000_000 = 16 millicents = $0.00016 per step
  let glm5_tiny = step_cost(100, 50, 60000, 208000);
  report("GLM-5 100+50 tokens = 16 millicents (~$0.00016)",
    glm5_tiny == 16);

  -- 3b. Genuinely-tiny step floors to 0: 1 input + 1 output
  --    1 × 60_000 + 1 × 208_000 = 268_000 / 1_000_000 = 0 (floors)
  let glm5_floor = step_cost(1, 1, 60000, 208000);
  report("GLM-5 1+1 tokens floors to 0 millicents (integer division)",
    glm5_floor == 0);

  -- 4. Realistic step: 5000 input + 1000 output at GLM-5 rates
  --    5000 × 60000 + 1000 × 208000 = 300_000_000 + 208_000_000 = 508_000_000
  --    / 1_000_000 = 508 millicents = ~$0.005
  let glm5_realistic = step_cost(5000, 1000, 60000, 208000);
  report("GLM-5 5k+1k tokens = 508 millicents (typical step)",
    glm5_realistic == 508);

  -- 5. Fail-open for unmetered (zero rates)
  let unmetered = step_cost(1000000, 1000000, 0, 0);
  report("zero rates → zero cost (Ollama / fail-open path)",
    unmetered == 0);

  -- 6. Sonnet 4.6 at $3 input / $15 output (300_000 / 1_500_000 millicents per 1M)
  --    1k+1k tokens = 300 + 1500 = 1800 millicents = ~1.8 cents
  let sonnet_typical = step_cost(1000, 1000, 300000, 1500000);
  report("Sonnet 4.6 1k+1k tokens = 1800 millicents (~1.8 cents)",
    sonnet_typical == 1800);

  -- 7. Threshold logic — 50% trigger
  --    cap = 150 cents = 150_000 millicents; 50% = 75_000 millicents
  --    Once cost crosses 75_000 with no prior warning → fire 50.
  let t50 = threshold_fires_at(0, 76000, 150000);
  report("50% threshold fires when cost crosses 50% cap with no prior",
    t50 == 50);

  -- 8. Threshold logic — 75% trigger after 50% already fired
  let t75_after_50 = threshold_fires_at(50, 113000, 150000);
  report("75% threshold fires after 50% (prev_warned=50)",
    t75_after_50 == 75);

  -- 9. Threshold logic — fires only once: same level shouldn't re-fire
  let t50_no_refire = threshold_fires_at(50, 80000, 150000);
  report("50% does NOT re-fire when prev_warned=50 already",
    t50_no_refire == 50);

  -- 10. Threshold logic — leapfrog: cost jumps from 0% to 95%, fires 90 directly
  let t90_leapfrog = threshold_fires_at(0, 145000, 150000);
  report("90% fires directly when cost leapfrogs from 0",
    t90_leapfrog == 90);

  -- 11. Disabled cap (max_cost = 0) → no threshold ever fires
  let disabled = threshold_fires_at(0, 9999999, 0);
  report("disabled cap (max=0) → never fires (returns prev_warned)",
    disabled == 0);

  -- 12. Boundary: exactly at threshold counts (>= semantics)
  let t50_boundary = threshold_fires_at(0, 75000, 150000);
  report("at exactly 50% boundary → fires (>= semantics)",
    t50_boundary == 50);

  println("done")
}
