{
  "comments": {
    "lineComment": "--"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*--\\s*#region\\b",
      "end": "^\\s*--\\s*#endregion\\b"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(export\\s+)?(func|type|match|if|let|letrec).*[={]\\s*$",
    "decreaseIndentPattern": "^\\s*[})]"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*--.*$",
      "action": { "indent": "none", "appendText": "-- " }
    },
    {
      "beforeText": ".*\\{\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*\\|.*=>\\s*$",
      "action": { "indent": "indent" }
    }
  ]
}
