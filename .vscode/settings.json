{
  "go.lintTool": "golangci-lint",
  "go.lintFlags": [
    "--fast"
  ],
  "go.lintOnSave": "workspace",
  "go.formatTool": "gofmt",
  "go.formatOnSave": true,
  "[go]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "go.build.buildFlags": [
    "-tags=scripts"
  ],
  "gopls": {
    "build.directoryFilters": [
      "-scripts",
      "-examples/agents"
    ]
  },
  "files.exclude": {
    "scripts/**/*.go": false
  },
  "go.toolsEnvVars": {
    "GOWORK": "off"
  },
  "git.ignoreLimitWarning": true,

  // Terminal tab titles: prefer the OSC-emitted title (`${sequence}`) over
  // the process name (`${process}`). The motoko TUI emits OSC 0 with the
  // string "[λ] motoko" on startup so VS Code shows a useful label
  // instead of the underlying runtime ("bun.exe", "node"). When no OSC
  // sequence is emitted (plain shell terminals) `${sequence}` is blank
  // and the description falls back to the process name.
  "terminal.integrated.tabs.title": "${sequence}",
  "terminal.integrated.tabs.description": "${process}${separator}${task}"
}